# Environment variables — copy to .env (gitignored) and fill in real values.

# Firecrawl API key for the weekly bank scrape pipeline.
# Set to "skip" to dry-run without burning quota.
# See scripts/scrape/_lib.ts.
FIRECRAWL_API_KEY=

# Pexels API key for the stock-image fetcher.
# Get one free at https://www.pexels.com/api/ (200 req/hr).
# Set to "skip" to dry-run without network calls.
# See scripts/images/fetch-stock.ts.
PEXELS_API_KEY=
