---
import BaseLayout from "./BaseLayout.astro";

interface Row {
  cardName: string;
  bankName: string;
  href: string;
  values: (string | number)[];
}

interface Props {
  title: string;
  description?: string;
  columns: string[];
  rows: Row[];
}

const { title, description, columns, rows } = Astro.props;
---

<BaseLayout title={title} description={description} fullWidth>
  <article class="dp-article is-wide">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">Compare</p>
      <h1 class="dp-article-title">{title}</h1>
      {description && <p class="dp-article-lede">{description}</p>}
    </header>

    <div class="dp-compare-wrap">
      <table class="dp-compare-table">
        <thead>
          <tr>
            <th>Card</th>
            {columns.map((c) => <th>{c}</th>)}
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="dp-compare-card">
                <a href={r.href}>{r.cardName}</a>
                <span class="dp-compare-bank">{r.bankName}</span>
              </td>
              {r.values.map((v) => <td>{v}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <section class="dp-prose" style="margin-top: 32px;">
      <slot />
    </section>
  </article>
</BaseLayout>

<style>
  .dp-compare-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
  }
  .dp-compare-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
  }
  .dp-compare-table thead {
    background: var(--bg);
    text-align: left;
  }
  .dp-compare-table th {
    padding: 12px 16px;
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--muted);
    white-space: nowrap;
  }
  .dp-compare-table td {
    padding: 14px 16px;
    border-top: 1px solid var(--line);
    font-size: 14px;
    color: var(--ink-soft);
    vertical-align: top;
  }
  .dp-compare-table tbody tr:hover { background: var(--bg); }
  .dp-compare-card {
    position: sticky;
    left: 0;
    background: var(--paper);
    border-right: 1px solid var(--line);
  }
  .dp-compare-table tbody tr:hover .dp-compare-card { background: var(--bg); }
  .dp-compare-card a {
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.2px;
    color: var(--ink);
    display: block;
  }
  .dp-compare-card a:hover { color: var(--brand); }
  .dp-compare-bank {
    display: block;
    margin-top: 2px;
    font-size: 11px;
    color: var(--muted);
  }
</style>
