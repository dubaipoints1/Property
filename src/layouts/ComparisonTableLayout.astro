---
// Comparison-table layout — Phase H2 (Claude Design handoff alignment).
// Used by /cards/cashback/, /cards/islamic/, /cards/miles/, /cards/compare/.
//
// Page head uses the design-handoff narrow pagehead chrome.

import BaseLayout from "./BaseLayout.astro";

interface Row {
  cardName: string;
  bankName: string;
  href: string;
  values: (string | number)[];
}

interface Props {
  title: string;
  /** On-page H1; falls back to `title`. Pass this without the
   * "| DubaiPoints" brand suffix — that belongs only in the meta title. */
  heading?: string;
  description?: string;
  columns: string[];
  rows: Row[];
}

const { title, heading, description, columns, rows } = Astro.props;
---

<BaseLayout title={title} description={description} fullWidth>
  <header class="dp-pagehead is-narrow">
    <div class="crumb"><a href="/cards/compare/" class="crumb-link">Compare</a></div>
    <h1>{heading ?? title}</h1>
    {description && <p class="deck">{description}</p>}
  </header>

  <article class="dp-cmp-body">
    <div class="dp-compare-wrap">
      <table class="dp-compare-table">
        <thead>
          <tr>
            <th>Card</th>
            {columns.map((c) => <th>{c}</th>)}
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="dp-compare-card" data-label="Card">
                <a href={r.href}>{r.cardName}</a>
                <span class="dp-compare-bank">{r.bankName}</span>
              </td>
              {r.values.map((v, i) => <td data-label={columns[i]}>{v}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <section class="dp-prose dp-cmp-prose">
      <slot />
    </section>
  </article>
</BaseLayout>

<style>
  .dp-cmp-body {
    max-width: 1080px;
    margin: 0 auto;
    padding: 32px 32px 80px;
  }
  .dp-compare-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--paper);
  }
  .dp-compare-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
  }
  .dp-compare-table thead {
    background: var(--shade-1);
    text-align: left;
  }
  .dp-compare-table th {
    padding: 14px 16px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--ink-soft);
    white-space: nowrap;
  }
  .dp-compare-table td {
    padding: 16px;
    border-top: 1px solid var(--line-soft);
    font-size: 14px;
    color: var(--ink-soft);
    vertical-align: top;
    font-variant-numeric: tabular-nums;
  }
  .dp-compare-table tbody tr:hover td { background: var(--shade-1); }
  .dp-compare-card {
    position: sticky;
    left: 0;
    background: var(--paper);
    border-right: 1px solid var(--line);
  }
  .dp-compare-table tbody tr:hover .dp-compare-card { background: var(--shade-1); }
  .dp-compare-card a {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 15px;
    letter-spacing: -0.2px;
    color: var(--ink);
    display: block;
    text-decoration: none;
  }
  .dp-compare-card a:hover { color: var(--green); }
  .dp-compare-bank {
    display: block;
    margin-top: 2px;
    font-size: 11px;
    color: var(--muted);
  }

  .dp-cmp-prose { margin-top: 32px; max-width: 70ch; }
  .dp-cmp-prose > p:first-of-type::first-letter {
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    float: none;
    padding: 0;
    color: inherit;
  }

  /* Mobile: collapse the table into stacked cards. Each row becomes a
     vertical card with key:value pairs; the column header gets injected
     as a label via the data-label attribute. Fixes the "one word per
     line" wrapping that happens when the table can't reach min-width on
     a 375px viewport. */
  @media (max-width: 640px) {
    .dp-cmp-body { padding: 20px 16px 60px; }
    .dp-compare-wrap {
      overflow: visible;
      border: 0;
      background: transparent;
      border-radius: 0;
    }
    .dp-compare-table {
      min-width: 0;
      display: block;
    }
    .dp-compare-table thead { display: none; }
    .dp-compare-table tbody { display: block; }
    .dp-compare-table tr {
      display: block;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 12px;
      margin-bottom: 12px;
      padding: 18px 18px 4px;
    }
    .dp-compare-table tbody tr:hover td { background: transparent; }
    .dp-compare-table td {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 16px;
      border-top: 0;
      border-bottom: 1px solid var(--line-soft);
      padding: 10px 0;
      font-size: 14px;
    }
    .dp-compare-table td:last-child { border-bottom: 0; }
    /* Label injected from data-label attribute on each td */
    .dp-compare-table td[data-label]::before {
      content: attr(data-label);
      flex-shrink: 0;
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: var(--muted);
      align-self: center;
    }
    /* Card cell renders as a header — full width, no label prefix,
       larger card name + bank below */
    .dp-compare-card {
      display: block !important;
      position: static !important;
      background: transparent !important;
      border-right: 0;
      border-bottom: 1px solid var(--line) !important;
      padding-bottom: 12px !important;
      margin-bottom: 6px;
    }
    .dp-compare-card::before { display: none; }
    .dp-compare-card a {
      font-size: 17px;
    }
  }
</style>
