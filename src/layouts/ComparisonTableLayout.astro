---
// Comparison-table layout — Phase H2 (Claude Design handoff alignment).
// Used by /cards/cashback/, /cards/islamic/, /cards/miles/, /cards/compare/.
//
// Page head uses the design-handoff narrow pagehead chrome.

import BaseLayout from "./BaseLayout.astro";

interface Row {
  cardName: string;
  bankName: string;
  href: string;
  values: (string | number)[];
}

interface Props {
  title: string;
  description?: string;
  columns: string[];
  rows: Row[];
}

const { title, description, columns, rows } = Astro.props;
---

<BaseLayout title={title} description={description} fullWidth>
  <header class="dp-pagehead is-narrow">
    <div class="crumb">Compare</div>
    <h1>{title}</h1>
    {description && <p class="deck">{description}</p>}
  </header>

  <article class="dp-cmp-body">
    <div class="dp-compare-wrap">
      <table class="dp-compare-table">
        <thead>
          <tr>
            <th>Card</th>
            {columns.map((c) => <th>{c}</th>)}
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <td class="dp-compare-card">
                <a href={r.href}>{r.cardName}</a>
                <span class="dp-compare-bank">{r.bankName}</span>
              </td>
              {r.values.map((v) => <td>{v}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <section class="dp-prose dp-cmp-prose">
      <slot />
    </section>
  </article>
</BaseLayout>

<style>
  .dp-cmp-body {
    max-width: 1080px;
    margin: 0 auto;
    padding: 32px 32px 80px;
  }
  .dp-compare-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--paper);
  }
  .dp-compare-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
  }
  .dp-compare-table thead {
    background: var(--shade-1);
    text-align: left;
  }
  .dp-compare-table th {
    padding: 14px 16px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.8px; text-transform: uppercase;
    color: var(--ink-soft);
    white-space: nowrap;
  }
  .dp-compare-table td {
    padding: 16px;
    border-top: 1px solid var(--line-soft);
    font-size: 14px;
    color: var(--ink-soft);
    vertical-align: top;
    font-variant-numeric: tabular-nums;
  }
  .dp-compare-table tbody tr:hover td { background: var(--shade-1); }
  .dp-compare-card {
    position: sticky;
    left: 0;
    background: var(--paper);
    border-right: 1px solid var(--line);
  }
  .dp-compare-table tbody tr:hover .dp-compare-card { background: var(--shade-1); }
  .dp-compare-card a {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 15px;
    letter-spacing: -0.2px;
    color: var(--ink);
    display: block;
    text-decoration: none;
  }
  .dp-compare-card a:hover { color: var(--green); }
  .dp-compare-bank {
    display: block;
    margin-top: 2px;
    font-size: 11px;
    color: var(--muted);
  }

  .dp-cmp-prose { margin-top: 32px; max-width: 70ch; }
  .dp-cmp-prose p:first-of-type::first-letter {
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    float: none;
    padding: 0;
    color: inherit;
  }
</style>
