---
// Trust page layout — Phase D (Claude Design handoff).
// Used by /editorial-policy/, /how-we-make-money/, /about/, /team/,
// /newsletter/, /valuations/methodology/.
//
// Shape:
//   pagehead-narrow (eyebrow + h1 + optional deck)
//   ↓
//   meta strip (Last updated · Editorial standards link)
//   ↓
//   single-column body (max 720px) — slot for sectioned prose
//
// No byline (policy docs, not articles).
// No drop-cap (overridden in scoped style).
// No sticky aside (single-column reading).

import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  heading: string;
  deck?: string;
  lastUpdated: Date;
}

const { title, description, eyebrow, heading, deck, lastUpdated } = Astro.props;
const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
---

<BaseLayout title={title} description={description} fullWidth>
  <header class="dp-pagehead is-narrow">
    <div class="crumb">{eyebrow}</div>
    <h1>{heading}</h1>
    {deck && <p class="deck">{deck}</p>}
  </header>

  <div class="dp-trust-meta">
    <span class="k">Last updated</span>
    <span class="v">{fmt(lastUpdated)}</span>
    <span class="dot" aria-hidden="true">·</span>
    <a href="/editorial-policy/">Editorial standards</a>
  </div>

  <article class="dp-trust-body">
    <div class="dp-prose">
      <slot />
    </div>
  </article>
</BaseLayout>
