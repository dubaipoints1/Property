---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  programName: string;
  currencyName: string;
  region: string;
  expiryPolicy: string;
  sweetSpots: { title: string; description: string }[];
  transferPartners: string[];
}

const {
  title,
  description,
  programName,
  currencyName,
  region,
  expiryPolicy,
  sweetSpots,
  transferPartners,
} = Astro.props;
---

<BaseLayout title={title} description={description} fullWidth>
  <article class="dp-article is-wide">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">{region} loyalty programme</p>
      <h1 class="dp-article-title">{programName}</h1>
      <p class="dp-article-lede">Loyalty currency: <strong>{currencyName}</strong>.</p>
    </header>

    <section class="dp-article-section">
      <h2>Tier table</h2>
      <slot name="tiers" />
    </section>

    <section class="dp-article-section">
      <h2>How to earn</h2>
      <slot name="earning" />
    </section>

    {sweetSpots.length > 0 && (
      <section class="dp-article-section">
        <h2>Redemption sweet spots</h2>
        <ul class="dp-sweet-list">
          {sweetSpots.map((s) => (
            <li>
              <p class="title">{s.title}</p>
              <p class="desc">{s.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {transferPartners.length > 0 && (
      <section class="dp-article-section">
        <h2>Transfer partners</h2>
        <ul class="dp-tag-list">
          {transferPartners.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    <section class="dp-article-foot">
      <p><strong>Expiry policy</strong></p>
      <p>{expiryPolicy}</p>
    </section>

    <section class="dp-article-section">
      <h2>Related cards</h2>
      <slot name="related-cards" />
    </section>

    <section class="dp-prose" style="margin-top: 32px;">
      <slot />
    </section>
  </article>
</BaseLayout>

<style>
  .dp-sweet-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 12px;
  }
  .dp-sweet-list li {
    border: 1px solid var(--line);
    border-left: 3px solid var(--gold);
    border-radius: 6px;
    background: var(--paper);
    padding: 14px 16px;
  }
  .dp-sweet-list .title {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: 16px; letter-spacing: -0.2px;
    color: var(--ink); margin-bottom: 4px;
  }
  .dp-sweet-list .desc {
    font-size: 14px; line-height: 1.55;
    color: var(--ink-soft);
  }
  .dp-tag-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 6px;
  }
  .dp-tag-list li {
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.5px; text-transform: capitalize;
    padding: 6px 12px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 4px;
    color: var(--ink-soft);
  }
</style>
