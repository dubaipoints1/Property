---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  programName: string;
  currencyName: string;
  region: string;
  expiryPolicy: string;
  sweetSpots: { title: string; description: string }[];
  transferPartners: string[];
}

const {
  title,
  description,
  programName,
  currencyName,
  region,
  expiryPolicy,
  sweetSpots,
  transferPartners,
} = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="border-b border-slate-200 pb-6">
    <p class="text-xs uppercase tracking-wide text-slate-500">{region} loyalty programme</p>
    <h1 class="mt-1 text-3xl font-semibold text-slate-900">{programName}</h1>
    <p class="mt-2 text-slate-700">Loyalty currency: <strong>{currencyName}</strong>.</p>
  </header>

  <section class="mt-8">
    <h2 class="text-xl font-semibold text-slate-900">Tier table</h2>
    <slot name="tiers" />
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold text-slate-900">How to earn</h2>
    <slot name="earning" />
  </section>

  {
    sweetSpots.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold text-slate-900">Redemption sweet spots</h2>
        <ul class="mt-3 space-y-3">
          {sweetSpots.map((s) => (
            <li class="rounded-md border border-slate-200 bg-white p-3">
              <p class="font-semibold">{s.title}</p>
              <p class="text-sm text-slate-600">{s.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  {
    transferPartners.length > 0 && (
      <section class="mt-8">
        <h2 class="text-xl font-semibold text-slate-900">Transfer partners</h2>
        <ul class="mt-3 flex flex-wrap gap-2">
          {transferPartners.map((p) => (
            <li class="rounded-full bg-slate-100 px-3 py-1 text-xs">{p}</li>
          ))}
        </ul>
      </section>
    )
  }

  <section class="mt-8 rounded-md bg-slate-50 p-4 text-sm text-slate-700">
    <h3 class="font-semibold">Expiry policy</h3>
    <p class="mt-1">{expiryPolicy}</p>
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-semibold text-slate-900">Related cards</h2>
    <slot name="related-cards" />
  </section>

  <div class="prose prose-slate mt-8 max-w-none">
    <slot />
  </div>
</BaseLayout>
