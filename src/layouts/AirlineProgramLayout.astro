---
// Airline programme layout — Phase H2 + F.16 (post-audit restructure).
// Used by /airlines/[slug]/.
//
// Restructure (F.16):
//   - MDX body prose renders FIRST — the editorial content (Tier
//     structure / Who Bonvoy suits / How to earn / What to watch) is
//     what the reader came for.
//   - Reference data (Sweet spots, Transfer partners, Expiry policy)
//     renders below as a structured "Programme reference" block.
//   - Related cards auto-populates from cards.json filtered by
//     loyaltyProgram match. Empty "tiers" / "earning" / "related-cards"
//     slots dropped — they were never filled by the [slug] consumer.

import BaseLayout from "./BaseLayout.astro";
import StockImage from "~/components/StockImage.astro";
import { hasStockEntry } from "~/lib/stockManifest";

interface RelatedCard {
  slug: string;
  name: string;
  bankName: string;
  annualFeeAed: number;
}

interface Props {
  title: string;
  description?: string;
  /** programme slug (e.g. "etihad-guest") — resolves the programme-<slug> hero. */
  slug?: string;
  programName: string;
  currencyName: string;
  region: string;
  expiryPolicy: string;
  sweetSpots: { title: string; description: string }[];
  transferPartners: string[];
  relatedCards?: RelatedCard[];
}

const {
  title,
  description,
  slug,
  programName,
  currencyName,
  region,
  expiryPolicy,
  sweetSpots,
  transferPartners,
  relatedCards = [],
} = Astro.props;

const heroSlug = slug ? `programme-${slug}` : null;
const hasHero = heroSlug ? hasStockEntry(heroSlug) : false;

// JSON-LD: programmes emit a Product entity (the loyalty programme itself)
// + BreadcrumbList. Region and currency name carry through. PR-D
// (29 May 2026).
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://dubaipoints.ae";
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Product",
      "@id": `${canonicalUrl}#programme`,
      name: programName,
      category: "Loyalty programme",
      description: description ?? `${programName} — DubaiPoints loyalty programme guide.`,
      url: canonicalUrl,
      brand: { "@type": "Organization", name: programName },
      additionalProperty: [
        { "@type": "PropertyValue", name: "Currency", value: currencyName },
        { "@type": "PropertyValue", name: "Region", value: region },
      ],
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Airlines", item: `${siteUrl}/airlines/` },
        { "@type": "ListItem", position: 3, name: programName, item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} fullWidth schema={schema}>
  <header class="dp-pagehead is-narrow">
    <div class="crumb">{region} · <a href="/airlines/" class="crumb-link">Loyalty programme</a></div>
    <h1>{programName}</h1>
    <p class="deck">Loyalty currency: <strong>{currencyName}</strong>.</p>

    <div class="dp-metric-strip">
      <div class="metric">
        <span class="v">{sweetSpots.length}<span class="sub">documented</span></span>
        <span class="l">Sweet spots</span>
      </div>
      <div class="metric">
        <span class="v">{transferPartners.length}<span class="sub">programmes</span></span>
        <span class="l">Transfer partners</span>
      </div>
      <div class="metric">
        <span class="v">{relatedCards.length}<span class="sub">UAE cards</span></span>
        <span class="l">Earn into this</span>
      </div>
      <div class="metric">
        <span class="v">{region}</span>
        <span class="l">Region</span>
      </div>
    </div>
  </header>

  <div class="dp-prog-grid">
    <article class="dp-prog-body">
      {hasHero && heroSlug && (
        <StockImage
          slug={heroSlug}
          coverTitle={programName}
          coverCategory="Programme"
          coverSize="hero"
          class="dp-hub-hero"
          loading="eager"
          sizes="(max-width: 800px) 100vw, 720px"
        />
      )}

      <!-- Editorial prose first — this is what the reader came for. -->
      <div class="dp-prose dp-prog-prose">
        <slot />
      </div>

      <!-- Redemption sweet spots: unbounded length, stays in main column. -->
      {sweetSpots.length > 0 && (
        <section class="dp-prog-reference">
          <h2>Programme reference</h2>
          <div class="dp-prog-ref-block">
            <h3>Redemption sweet spots</h3>
            <ul class="dp-sweet-list">
              {sweetSpots.map((s) => (
                <li>
                  <p class="title">{s.title}</p>
                  <p class="desc">{s.description}</p>
                </li>
              ))}
            </ul>
          </div>
        </section>
      )}

      {/* Related cards: auto-populated from the card database by loyaltyProgram.
         JSX comment — HTML comments ship to the browser (2 July leak audit). */}
      {relatedCards.length > 0 && (
        <section class="dp-prog-related">
          <h2>UAE cards that earn into {currencyName}</h2>
          <ul class="dp-prog-related-list">
            {relatedCards.map((c) => (
              <li>
                <a href={`/cards/${c.slug}/`}>
                  <span class="bank">{c.bankName}</span>
                  <span class="name">{c.name}</span>
                  <span class="fee">{c.annualFeeAed === 0 ? "Free" : `AED ${c.annualFeeAed.toLocaleString()}/yr`}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}
    </article>

    <!-- Sticky reference rail (Stage 2): compact programme facts. Source-
         after the article so prose leads on mobile; pinned right on laptop+. -->
    <aside class="dp-prog-aside">
      {transferPartners.length > 0 && (
        <section class="dp-prog-railcard">
          <h3>Transfer partners</h3>
          <ul class="dp-tag-list">
            {transferPartners.map((p) => <li>{p}</li>)}
          </ul>
        </section>
      )}

      <section class="dp-prog-railcard">
        <div class="dp-expiry-block">
          <p class="label">Expiry policy</p>
          <p class="body">{expiryPolicy}</p>
        </div>
      </section>
    </aside>
  </div>
</BaseLayout>

<style>
  /* Stage 2 (2026-05-25 amendment): laptop-aware width. Single column on
     mobile; at >=1024px a 1fr + 300px grid reclaims the right margin with
     a sticky reference rail (transfer partners + expiry). Editorial prose
     stays in the main column and leads on every viewport. */
  .dp-prog-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    max-width: var(--container-listing);
    margin: 0 auto;
    padding: 40px 32px 80px;
  }
  @media (min-width: 1024px) {
    .dp-prog-grid { grid-template-columns: minmax(0, 1fr) 300px; gap: 64px; }
  }
  @media (max-width: 640px) {
    .dp-prog-grid { padding: 28px 20px 56px; gap: 28px; }
  }
  .dp-prog-body { width: 100%; min-width: 0; }

  .dp-prog-aside { display: flex; flex-direction: column; gap: 20px; }
  @media (min-width: 1024px) {
    .dp-prog-aside { position: sticky; top: 32px; align-self: flex-start; }
  }
  .dp-prog-railcard h3 {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--green);
    margin: 0 0 12px;
  }

  .dp-prog-prose { margin-bottom: 48px; }
  .dp-prog-prose > p:first-of-type::first-letter {
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    float: none;
    padding: 0;
    color: inherit;
  }

  /* Programme reference: light grey band with structured data */
  .dp-prog-reference {
    background: var(--shade-1);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 28px 28px 32px;
    margin-bottom: 40px;
  }
  @media (max-width: 640px) {
    .dp-prog-reference { padding: 20px 18px 24px; }
  }
  .dp-prog-reference h2 {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--green);
    margin: 0 0 18px;
    padding: 0;
    border: 0;
  }
  .dp-prog-ref-block { margin-bottom: 24px; }
  .dp-prog-ref-block:last-child { margin-bottom: 0; }
  .dp-prog-ref-block h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: -0.3px;
    color: var(--ink);
    margin: 0 0 12px;
  }

  .dp-sweet-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 10px;
  }
  .dp-sweet-list li {
    background: var(--paper);
    border: 1px solid var(--line);
    border-left: 3px solid var(--green);
    border-radius: 8px;
    padding: 12px 14px;
  }
  .dp-sweet-list .title {
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: 15px; letter-spacing: -0.2px;
    color: var(--ink); margin: 0 0 4px;
  }
  .dp-sweet-list .desc {
    font-size: 13px; line-height: 1.5;
    color: var(--ink-soft); margin: 0;
  }

  .dp-tag-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 6px;
  }
  .dp-tag-list li {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.3px;
    padding: 6px 12px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink-soft);
  }

  .dp-expiry-block {
    background: var(--paper);
    border: 1px solid var(--line);
    border-left: 3px solid var(--gold);
    border-radius: 8px;
    padding: 14px 16px;
  }
  .dp-expiry-block .label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 6px;
  }
  .dp-expiry-block .body {
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }

  /* Related cards — actual card tiles, not empty slot */
  .dp-prog-related h2 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(20px, 2.6vw, 26px);
    letter-spacing: -0.4px;
    color: var(--ink);
    margin: 0 0 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line);
  }
  .dp-prog-related-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 8px;
  }
  .dp-prog-related-list a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 14px 16px;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.15s ease, transform 0.15s ease, background 0.15s ease;
  }
  .dp-prog-related-list a:hover {
    border-color: var(--green);
    background: var(--shade-1);
    transform: translateY(-1px);
  }
  .dp-prog-related-list .bank {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--green);
    white-space: nowrap;
  }
  .dp-prog-related-list .name {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 15px;
    letter-spacing: -0.2px;
    color: var(--ink);
    line-height: 1.3;
  }
  .dp-prog-related-list .fee {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 12px;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  @media (max-width: 640px) {
    .dp-prog-related-list a {
      grid-template-columns: 1fr;
      gap: 4px;
    }
    .dp-prog-related-list .fee {
      margin-top: 4px;
    }
  }
</style>
