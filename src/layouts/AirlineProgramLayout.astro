---
// Airline programme layout — Phase H2 (Claude Design handoff alignment).
// Used by /airlines/[slug]/.
//
// Page head uses the design-handoff narrow pagehead chrome
// (matches /guides/[slug]/, /news/[slug]/, /deals/[slug]/, trust pages).
// Body sections use .dp-prose for typography consistency.

import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  programName: string;
  currencyName: string;
  region: string;
  expiryPolicy: string;
  sweetSpots: { title: string; description: string }[];
  transferPartners: string[];
}

const {
  title,
  description,
  programName,
  currencyName,
  region,
  expiryPolicy,
  sweetSpots,
  transferPartners,
} = Astro.props;
---

<BaseLayout title={title} description={description} fullWidth>
  <header class="dp-pagehead is-narrow">
    <div class="crumb">{region} · Loyalty programme</div>
    <h1>{programName}</h1>
    <p class="deck">Loyalty currency: <strong>{currencyName}</strong>.</p>

    <div class="dp-metric-strip">
      <div class="metric">
        <span class="v">{currencyName}</span>
        <span class="l">Currency</span>
      </div>
      <div class="metric">
        <span class="v">{sweetSpots.length}<span class="sub">documented</span></span>
        <span class="l">Sweet spots</span>
      </div>
      <div class="metric">
        <span class="v">{transferPartners.length}<span class="sub">programmes</span></span>
        <span class="l">Transfer partners</span>
      </div>
      <div class="metric">
        <span class="v">{region}</span>
        <span class="l">Region</span>
      </div>
    </div>
  </header>

  <article class="dp-prog-body">
    <section>
      <h2>Tier table</h2>
      <slot name="tiers" />
    </section>

    <section>
      <h2>How to earn</h2>
      <slot name="earning" />
    </section>

    {sweetSpots.length > 0 && (
      <section>
        <h2>Redemption sweet spots</h2>
        <ul class="dp-sweet-list">
          {sweetSpots.map((s) => (
            <li>
              <p class="title">{s.title}</p>
              <p class="desc">{s.description}</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {transferPartners.length > 0 && (
      <section>
        <h2>Transfer partners</h2>
        <ul class="dp-tag-list">
          {transferPartners.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    <section class="dp-expiry-block">
      <p class="label">Expiry policy</p>
      <p class="body">{expiryPolicy}</p>
    </section>

    <section>
      <h2>Related cards</h2>
      <slot name="related-cards" />
    </section>

    <div class="dp-prose dp-prog-prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .dp-prog-body {
    max-width: 760px;
    margin: 0 auto;
    padding: 40px 32px 80px;
  }
  .dp-prog-body section { margin-bottom: 36px; }
  .dp-prog-body h2 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(20px, 2.6vw, 26px);
    letter-spacing: -0.4px;
    color: var(--ink);
    margin: 0 0 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line);
  }

  .dp-sweet-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 12px;
  }
  .dp-sweet-list li {
    border: 1px solid var(--line);
    border-left: 3px solid var(--green);
    border-radius: 8px;
    background: var(--paper);
    padding: 14px 16px;
  }
  .dp-sweet-list .title {
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: 17px; letter-spacing: -0.2px;
    color: var(--ink); margin: 0 0 4px;
  }
  .dp-sweet-list .desc {
    font-size: 14px; line-height: 1.55;
    color: var(--ink-soft); margin: 0;
  }

  .dp-tag-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: 6px;
  }
  .dp-tag-list li {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.5px;
    padding: 6px 12px;
    background: var(--shade-1);
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--ink-soft);
  }

  .dp-expiry-block {
    background: var(--shade-1);
    border-left: 3px solid var(--gold);
    border-radius: 8px;
    padding: 16px 20px;
  }
  .dp-expiry-block .label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 8px;
  }
  .dp-expiry-block .body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }

  .dp-prog-prose { margin-top: 24px; }
  /* Drop-cap should not apply to programme prose — these are
     reference docs, not editorial features. */
  .dp-prog-prose p:first-of-type::first-letter {
    font-family: inherit;
    font-weight: inherit;
    font-size: inherit;
    line-height: inherit;
    float: none;
    padding: 0;
    color: inherit;
  }
</style>
