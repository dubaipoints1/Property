---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  liveCount: number;
}

const { title, description, liveCount } = Astro.props;
---

<BaseLayout title={title} description={description} fullWidth>
  <article class="dp-article is-wide">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow is-red">Live tracker · {liveCount} offers</p>
      <h1 class="dp-article-title">UAE <em>salary transfer</em> offers.</h1>
      <p class="dp-article-lede">
        Live offers tracked across UAE banks, updated as promotions change.
        Filter by salary band, tenure, and reward type.
      </p>
    </header>

    <section>
      <slot name="tracker" />
    </section>

    <section class="dp-band-grid">
      <slot name="bands" />
    </section>

    <section class="dp-calc-cta">
      <div>
        <h2>Want a personalised ranking?</h2>
        <p>Score every live offer against your salary, card spend, and product preferences.</p>
      </div>
      <a href="/salary-transfer/calculator/">Open the calculator →</a>
    </section>

    <div class="dp-prose" style="margin-top: 28px;">
      <slot />
    </div>

    <slot name="footer" />
  </article>
</BaseLayout>

<style>
  .dp-band-grid {
    margin-top: 32px;
    display: grid; gap: 12px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) { .dp-band-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .dp-band-grid { grid-template-columns: repeat(3, 1fr); } }

  .dp-calc-cta {
    margin-top: 32px;
    padding: 22px 24px;
    border: 1px solid var(--line);
    border-left: 3px solid var(--ink);
    background: var(--paper);
    border-radius: 6px;
    display: flex; flex-direction: column;
    gap: 14px;
  }
  @media (min-width: 768px) {
    .dp-calc-cta {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
    }
  }
  .dp-calc-cta h2 {
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: 18px; letter-spacing: -0.3px;
    color: var(--ink); margin-bottom: 4px;
  }
  .dp-calc-cta p {
    font-size: 13px; line-height: 1.55;
    color: var(--ink-soft); max-width: 60ch;
  }
  .dp-calc-cta a {
    flex-shrink: 0;
    padding: 12px 18px;
    background: var(--ink); color: white;
    border-radius: 5px;
    font-size: 13px; font-weight: 600;
    min-height: 44px;
    display: inline-flex; align-items: center;
    transition: background 0.15s;
    align-self: flex-start;
  }
  .dp-calc-cta a:hover { background: var(--gold); }
</style>
