---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  liveCount: number;
}

const { title, description, liveCount } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="border-b border-slate-200 pb-6">
    <p class="text-xs uppercase tracking-wide text-brand-600">Live tracker</p>
    <h1 class="mt-1 text-3xl font-semibold text-slate-900 sm:text-4xl">
      UAE salary transfer offers
    </h1>
    <p class="mt-2 text-slate-700">
      <strong>{liveCount}</strong> live offers tracked, updated as banks change their
      promotions. Filter by salary band, tenure, and reward type.
    </p>
  </header>

  <section class="mt-6">
    <slot name="tracker" />
  </section>

  <section class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    <slot name="bands" />
  </section>

  <section class="mt-10 rounded-lg border border-slate-200 bg-slate-50 p-5">
    <h2 class="text-lg font-semibold text-slate-900">Want a personalised ranking?</h2>
    <p class="mt-1 text-sm text-slate-700">
      Use the calculator to score every live offer against your salary, card spend
      and product preferences.
    </p>
    <a
      href="/salary-transfer/calculator/"
      class="mt-3 inline-flex items-center rounded-md bg-brand-500 px-4 py-2 text-sm font-semibold text-white no-underline hover:bg-brand-600"
    >
      Open the calculator
    </a>
  </section>

  <div class="prose prose-slate mt-8 max-w-none">
    <slot />
  </div>

  <slot name="footer" />
</BaseLayout>
