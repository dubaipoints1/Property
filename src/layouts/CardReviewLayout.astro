---
import BaseLayout from "./BaseLayout.astro";
import Disclaimer from "~/components/Disclaimer.astro";

interface Props {
  title: string;
  description?: string;
  bankName: string;
  cardName: string;
  network: string;
  annualFee: number;
  fxFee: number;
  minSalary: number;
  earnRates: Record<string, number | undefined>;
  perks: string[];
  pros?: string[];
  cons?: string[];
  editorTake?: string;
  lastVerified: Date;
  verifiedBy?: string;
  sources: string[];
}

const {
  title,
  description,
  bankName,
  cardName,
  network,
  annualFee,
  fxFee,
  minSalary,
  earnRates,
  perks,
  pros = [],
  cons = [],
  editorTake,
  lastVerified,
  verifiedBy,
  sources,
} = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });

const earnRows = Object.entries(earnRates).filter(
  ([, v]) => typeof v === "number",
) as Array<[string, number]>;
---

<BaseLayout title={title} description={description} fullWidth>
  <article class="dp-article">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">{bankName} · {network}</p>
      <h1 class="dp-article-title">{cardName}</h1>
      {description && <p class="dp-article-lede">{description}</p>}
    </header>

    <dl class="dp-stats is-four">
      <div class="dp-stat">
        <dt>Annual fee</dt>
        <dd>AED {annualFee.toLocaleString()}</dd>
      </div>
      <div class="dp-stat">
        <dt>FX fee</dt>
        <dd>{fxFee}%</dd>
      </div>
      <div class="dp-stat">
        <dt>Min salary</dt>
        <dd>AED {minSalary.toLocaleString()}<span style="font-size:11px;color:var(--muted);font-family:'DM Sans',sans-serif;font-weight:400;"> /mo</span></dd>
      </div>
      <div class="dp-stat">
        <dt>Network</dt>
        <dd>{network}</dd>
      </div>
    </dl>

    {editorTake && (
      <aside class="dp-take">
        <p class="label">Our take</p>
        <p>{editorTake}</p>
      </aside>
    )}

    {(pros.length > 0 || cons.length > 0) && (
      <section class="dp-proscons">
        {pros.length > 0 && (
          <div class="dp-proscons-block is-pros">
            <h3>Pros</h3>
            <ul>{pros.map((p) => <li>{p}</li>)}</ul>
          </div>
        )}
        {cons.length > 0 && (
          <div class="dp-proscons-block is-cons">
            <h3>Cons</h3>
            <ul>{cons.map((c) => <li>{c}</li>)}</ul>
          </div>
        )}
      </section>
    )}

    {earnRows.length > 0 && (
      <section class="dp-article-section">
        <h2>Earn rates</h2>
        <table class="dp-data-table">
          <tbody>
            {earnRows.map(([k, v]) => (
              <tr>
                <td>{k.replace(/([A-Z])/g, " $1").replace(/^./, (s) => s.toUpperCase())}</td>
                <td class="num">{v}× per AED 1</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {perks.length > 0 && (
      <section class="dp-article-section">
        <h2>Perks</h2>
        <ul class="dp-bullet-list">
          {perks.map((p) => <li>{p}</li>)}
        </ul>
      </section>
    )}

    <section class="dp-prose">
      <slot />
    </section>

    <footer class="dp-article-foot">
      <p>
        <strong>Last verified:</strong> {fmt(lastVerified)}
        {verifiedBy && <span class="dp-article-meta" style="margin-left:6px;display:inline-flex;"><span class="verified-chip">By {verifiedBy}</span></span>}
      </p>
      {sources.length > 0 && (
        <p>
          <strong>Sources:</strong>{" "}
          {sources.map((s, i) => (
            <>
              {i > 0 && " · "}
              <a href={s} target="_blank" rel="noopener noreferrer">{new URL(s).hostname}</a>
            </>
          ))}
        </p>
      )}
    </footer>

    <Disclaimer variant="card" />
  </article>
</BaseLayout>
