---
// Card review layout — Phase B3 (Claude Design handoff).
// Reference: dubaipoints/project/templates/article.jsx::CardReview.
// Used by /cards/<slug>/.
//
// Shape:
//   navy hero band: card-art mock (1.586:1 placeholder) + crumb + h1
//                   + strap + verdict pill (score / denomination /
//                   verdict label / verified date)
//   ↓
//   2-col body grid at >=1024px:
//     [body] byline + deck + drop-cap prose (slot)
//     [aside] At-a-glance specs + Earn rates by category +
//             Editor's call (dark variant)
//   ↓
//   sources footer (reuses .dp-article-sources from B2)

import BaseLayout from "./BaseLayout.astro";
import Disclaimer from "~/components/Disclaimer.astro";
import StockImage from "~/components/StockImage.astro";
import HeroImage from "~/components/cards/HeroImage.astro";
import JumpToSection from "~/components/cards/JumpToSection.astro";
import { hasStockEntry } from "~/lib/stockManifest";
import { earnIsPercentage } from "~/lib/cardsDataFormat";

interface Props {
  title: string;
  description?: string;
  bankName: string;
  /** bank slug (e.g. "fab", "emirates-nbd") — drives per-issuer tint on card-art mock */
  bankSlug?: string;
  /** card slug — used to look up a per-card photograph in the stock manifest. */
  slug?: string;
  cardName: string;
  network: string;
  annualFee: number;
  fxFee: number;
  minSalary: number;
  earnRates: Record<string, number | undefined>;
  /** L2 earnUnit — drives whether the spec-card earn rows render "5%"
   * (cashback) or "2×" (points). §6 unit-integrity (2026-05-29). */
  earnUnit?: string;
  perks?: string[];
  pros?: string[];
  cons?: string[];
  editorTake?: string;
  category?: string;
  score?: number;
  /** H2 sections derived from MDX `headings`; chip renders when ≥ 2 entries.
   * Closes the Head of UX audit's "no jump-nav on card reviews" finding. */
  tocSections?: Array<{ id: string; label: string }>;
  verdictLabel?: string;
  lastVerified: Date;
  verifiedBy?: string;
  sources: string[];
  deck?: string;
  /** Optional licensed editorial hero photo, rendered between the navy
   * hero band and the body grid. Schema matches `cards` collection
   * `heroImage` field; the filename resolves against
   * `src/assets/cards/library/`. */
  heroImage?: {
    src: string;
    alt: string;
    caption?: string;
    credit?: string;
  };
}

const {
  title,
  description,
  bankName,
  bankSlug,
  slug,
  cardName,
  network,
  annualFee,
  fxFee,
  minSalary,
  earnRates,
  earnUnit,
  perks = [],
  // pros + cons are accepted on the props interface for backward
  // compatibility with existing call sites in src/pages/cards/[slug].astro,
  // but no longer consumed by the layout — see Phase 2a.2.0 (2026-05-20):
  // they are rendered by the MDX-invoked `<ProsCons />` component instead.
  // `editorTake` is also accepted but no longer consumed — Phase 2a.2.3
  // (2026-05-20) moved the "Editor's call" sidebar to <EditorScorecard />.
  editorTake: _editorTake,
  category = "Cards",
  score,
  verdictLabel,
  lastVerified,
  verifiedBy = "DubaiPoints Editorial",
  sources,
  deck,
  heroImage,
  tocSections = [],
} = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });

const initials = verifiedBy
  .split(/\s+/)
  .map((w) => w[0]?.toUpperCase() ?? "")
  .slice(0, 2)
  .join("");

const earnRows = Object.entries(earnRates).filter(
  ([, v]) => typeof v === "number",
) as Array<[string, number]>;

const formatEarnKey = (k: string) =>
  k.replace(/([A-Z])/g, " $1").replace(/^./, (s) => s.toUpperCase());

const fmtScore = (s?: number) => {
  if (s == null) return null;
  return s.toFixed(1).replace(/\.0$/, "");
};

// Stock photograph lookup. Each card may have an editorial photograph
// registered in data/stock/manifest.json under `card-<slug>` (e.g.
// `card-emirates-nbd-skywards-infinite`). When present, the hero band
// renders the photo instead of the CSS-only mock. The mock remains the
// fallback for every card that doesn't yet have a curated photograph.
const stockSlug = slug ? `card-${slug}` : null;
const hasPhoto = stockSlug ? hasStockEntry(stockSlug) : false;

// JSON-LD: every card review emits a Product entity with a FinancialProduct
// additionalType so search engines parse it as a credit card. The fee and
// eligibility carry into offers / brand. BreadcrumbList complements it.
// PR-D (29 May 2026) per SEO + Tech audit P0.
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://dubaipoints.ae";
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["Product", "FinancialProduct"],
      "@id": `${canonicalUrl}#product`,
      name: cardName,
      brand: { "@type": "Organization", name: bankName },
      category: category ?? "Credit card",
      description: description ?? `${cardName} — DubaiPoints credit-card review.`,
      url: canonicalUrl,
      ...(slug ? { sku: slug } : {}),
      ...(typeof score === "number"
        ? {
            aggregateRating: {
              "@type": "AggregateRating",
              ratingValue: score,
              bestRating: 10,
              worstRating: 0,
              ratingCount: 1,
              author: { "@type": "Organization", name: "DubaiPoints" },
            },
          }
        : {}),
      offers: {
        "@type": "Offer",
        priceCurrency: "AED",
        price: annualFee,
        url: canonicalUrl,
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
        { "@type": "ListItem", position: 2, name: "Cards", item: `${siteUrl}/cards/` },
        { "@type": "ListItem", position: 3, name: cardName, item: canonicalUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} fullWidth schema={schema}>

  <!-- Navy hero band: card photograph (when registered) or CSS mock fallback -->
  <header class="dp-cr-hero">
    {hasPhoto && stockSlug ? (
      <figure class="dp-cr-photo" data-bank={bankSlug ?? "default"}>
        <StockImage
          slug={stockSlug}
          coverTitle={cardName}
          coverCategory="Card review"
          coverSize="med"
          class="dp-cr-photo-img"
          loading="eager"
          sizes="(max-width: 720px) 100vw, 360px"
        />
        <figcaption class="dp-cr-photo-cap">
          <span class="b">{bankName}</span>
          <span class="dp-cr-photo-name">{cardName}</span>
          <span class="b">{network}</span>
        </figcaption>
      </figure>
    ) : (
      <div class="dp-cr-mock" data-bank={bankSlug ?? "default"} aria-hidden="true">
        <div class="dp-cr-mock-chip"></div>
        <div class="dp-cr-mock-row">
          <div class="b">{bankName}</div>
          <div class="dp-cr-mock-mark">{network.slice(0, 1)}</div>
        </div>
        <div class="n">{cardName}</div>
        <div class="b">{network}</div>
      </div>
    )}

    <div class="dp-cr-text">
      <div class="crumb">{
        // Avoid the "Cards / Cards / FAB" double when no specific category is
        // passed — collapse "Cards / Cards" to just "Cards".
        category === "Cards"
          ? `Cards / ${bankName}`
          : `Cards / ${category} / ${bankName}`
      }</div>
      <h1>{title}</h1>

      {(score != null || verdictLabel) && (
        <div class="dp-verdict-pill">
          {score != null && (
            <div class="score">
              {fmtScore(score)}<span class="denom">/5</span>
            </div>
          )}
          <div>
            <div class="label">DubaiPoints verdict</div>
            <div class="meta">
              {verdictLabel ? `${verdictLabel} · ` : ""}
              Last verified {fmt(lastVerified)}
            </div>
          </div>
        </div>
      )}

      {description && (
        <p class="strap">
          <span class="strap-label">Welcome bonus</span>
          <span class="strap-value">{description}</span>
        </p>
      )}
    </div>
  </header>

  {heroImage && (
    <div class="dp-cr-hero-photo-wrap">
      <HeroImage {...heroImage} />
    </div>
  )}

  <!-- Body grid: prose + sticky sidebar -->
  <div class="dp-cr-body-grid">
    <article class="dp-cr-body">

      <!-- Byline -->
      <div class="dp-byline-strip" style="margin: 0 0 24px;">
        <div class="av" aria-hidden="true">{initials}</div>
        <div>
          <div class="name">{verifiedBy}</div>
          <div class="when">Filed {fmt(lastVerified)} · Verified against issuer T&Cs</div>
        </div>
      </div>

      {deck && <p class="deck">{deck}</p>}

      <!--
        Phase 2a.2.0 (2026-05-20): the "Our take" callout and the
        pros/cons block were removed from the layout chrome and migrated
        to MDX-invoked components — `<EditorVerdict card="…" />` and
        `<ProsCons card="…" />` in `~/components/cards/`. Layout-side
        rendering would double-render the same content on every page.
        See `.council/briefs/2026-05-20-phase-2a-2-0-pros-cons-verdict-
        amendment.md`.
      -->

      {tocSections.length >= 2 && (
        <JumpToSection sections={tocSections} />
      )}

      <!-- Editorial prose (MDX slot) -->
      <div class="dp-prose">
        <slot />
      </div>

      <Disclaimer variant="card" />
    </article>

    <!-- Sticky sidebar -->
    <aside class="dp-cr-aside">
      <div class="dp-spec-card">
        <h4>At a glance</h4>
        <div class="dp-spec-row"><span class="k">Annual fee</span><span class="v">AED {annualFee.toLocaleString()}</span></div>
        <div class="dp-spec-row"><span class="k">Min salary</span><span class="v">AED {minSalary.toLocaleString()}/mo</span></div>
        <div class="dp-spec-row"><span class="k">FX markup</span><span class="v">{fxFee}%</span></div>
        <div class="dp-spec-row"><span class="k">Network</span><span class="v">{network}</span></div>
      </div>

      {earnRows.length > 0 && (
        <div class="dp-spec-card">
          <h4>Earn rates by category</h4>
          {earnRows.map(([k, v]) => (
            <div class="dp-spec-row">
              <span class="k">{formatEarnKey(k)}</span>
              <span class={`v ${v >= 3 ? "flag" : ""}`}>{earnIsPercentage(earnUnit, [category]) ? `${v}%` : `${v}× per AED 1`}</span>
            </div>
          ))}
        </div>
      )}

      {perks.length > 0 && (() => {
        // Filter junk perks bleeding from the scrape — Arabic-toggle UI
        // strings (`[العربية...`), Markdown image references
        // (`![icon...](http...)`), and other source-HTML artefacts that
        // the scrape normaliser hasn't been taught to strip yet.
        // Permanent fix lives in scripts/scrape/_normaliser.ts (BRE editor
        // + scrape pipeline pass); this is a display-time defence so
        // readers never see the garbage.
        const cleanPerks = perks.filter((p) => {
          const s = (p ?? "").trim();
          if (!s) return false;
          if (s.length < 4) return false;
          if (s.startsWith("[") || s.startsWith("![")) return false;
          if (s.startsWith("(") && s.includes("](")) return false;
          if (/^\\+$/.test(s)) return false;
          if (/^https?:\/\//i.test(s)) return false;
          if (/العربية/.test(s)) return false;
          if (/^icon\./i.test(s)) return false;
          if (/\.alt\]/.test(s)) return false;
          return true;
        });
        return cleanPerks.length > 0 ? (
          <div class="dp-spec-card">
            <h4>Perks</h4>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px;">
              {cleanPerks.slice(0, 6).map((p) => (
                <li style="font-size: 13px; color: var(--ink-soft); line-height: 1.5; padding-left: 12px; position: relative;">
                  <span style="position: absolute; left: 0; color: var(--green); font-weight: 700;">+</span>
                  {p}
                </li>
              ))}
            </ul>
          </div>
        ) : null;
      })()}

      {/* Phase 2a.2.3 (2026-05-20): the layout's `.dp-spec-card.is-call`
         block was removed — it duplicated the EditorVerdict at the top.
         The new <EditorScorecard /> at the end of the MDX body carries
         the tier badge + dimension scores + apply/skip qualifiers. The
         `editorTake` prop stays on the layout interface (call sites
         pass it) but is unused here. */}
    </aside>
  </div>

  <!-- Sources footer -->
  {sources.length > 0 && (
    <footer class="dp-article-sources">
      <p>
        <strong>Last verified:</strong> {fmt(lastVerified)}
      </p>
      <p>
        <strong>Sources:</strong>{" "}
        {sources.map((s, i) => (
          <>
            {i > 0 && " · "}
            <a href={s} target="_blank" rel="noopener noreferrer">{new URL(s).hostname}</a>
          </>
        ))}
      </p>
    </footer>
  )}

</BaseLayout>
