---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
}

const {
  title,
  description = "UAE points and miles — credit card analysis, loyalty programs, and deals.",
  fullWidth = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Font loading: preconnect first, then non-blocking stylesheet.
         Weights pruned to in-use axes only (~9 files vs 14). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Fraunces:ital,wght@0,500;0,600;0,700;1,500&display=swap"
    />
    {
      import.meta.env.PROD && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon='{"token": "REPLACE_WITH_CLOUDFLARE_WEB_ANALYTICS_TOKEN"}'
        />
      )
    }
  </head>
  <body class="dp-body">
    <Header />
    <main class={fullWidth ? "dp-main is-full" : "dp-main"}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
