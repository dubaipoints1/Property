---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import SchemaJsonLd from "~/components/seo/SchemaJsonLd.astro";

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
  /** Override the default OG image for a specific page (absolute or root path). */
  ogImage?: string;
  /** og:type — "website" (default) or "article" for editorial pages. */
  ogType?: "website" | "article";
  /** Per-page structured data (Product / Article / NewsArticle / Organization /
   * BreadcrumbList) injected before the default WebSite + Organization graph.
   * Layout components compose the right shape and hand it through. */
  schema?: unknown;
}

const {
  title,
  description = "UAE points and miles — credit card analysis, loyalty programs, and deals.",
  fullWidth = false,
  ogImage,
  ogType = "website",
  schema,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const siteName = "DubaiPoints";
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://dubaipoints.ae";
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).toString()
  : new URL("/og-default.svg", Astro.site).toString();

// Default WebSite + Organization graph rendered on every page.
// Per-page schema (Product / Article / etc.) renders before this so
// search engines see the page-specific entity first.
const defaultGraph = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": `${siteUrl}/#website`,
      url: `${siteUrl}/`,
      name: siteName,
      description:
        "UAE-focused points-and-miles publication. AED-first credit-card reviews, salary-transfer tracker, loyalty-programme guides.",
      inLanguage: "en-AE",
      publisher: { "@id": `${siteUrl}/#organization` },
    },
    {
      "@type": "Organization",
      "@id": `${siteUrl}/#organization`,
      name: siteName,
      url: `${siteUrl}/`,
      logo: `${siteUrl}/logo-mark.svg`,
      sameAs: [],
    },
  ],
};

// PR-D (29 May 2026): Cloudflare Web Analytics token now gated behind
// PUBLIC_CF_BEACON_TOKEN env var. Build-time env injection only —
// the publisher sets this in Cloudflare Pages → Environment Variables.
// Without it, the beacon is omitted entirely rather than rendering
// a broken script with the literal "REPLACE_WITH_…" placeholder.
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN as string | undefined;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
<!-- Theme initialization — MUST run before any styles to prevent flash -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('dp-theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = saved || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  
  <meta name="viewport" content="width=device-width, initial-scale=1" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/logo-mark.svg" />
    <link rel="mask-icon" href="/logo-mark.svg" color="#1f3a4d" />
    <meta name="theme-color" content="#1f3a4d" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_AE" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Font loading: preconnect first, then non-blocking stylesheet.
         Weights pruned to in-use axes only (~9 files vs 14). -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&family=Fraunces:ital,wght@0,500;0,600;0,700;1,500&display=swap"
    />
    {schema && <SchemaJsonLd schema={schema} />}
    <SchemaJsonLd schema={defaultGraph} />

    {
      import.meta.env.PROD && cfBeaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${cfBeaconToken}"}`}
        />
      )
    }
  </head>
  <body class="dp-body">
    <Header />
    <main class={fullWidth ? "dp-main is-full" : "dp-main"}>
      <slot />
    </main>
    <Footer />

    <!-- Back-to-top — visible after 600px scroll, click smooths to top -->
    <button id="dp-to-top" class="dp-to-top" type="button" aria-label="Back to top">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
           stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
           stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 14 12 8 18 14"></polyline>
      </svg>
    </button>
    <script is:inline>
      (function () {
        var btn = document.getElementById('dp-to-top');
        if (!btn) return;
        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        function update() {
          if (window.scrollY > 600) btn.classList.add('is-visible');
          else btn.classList.remove('is-visible');
        }
        window.addEventListener('scroll', update, { passive: true });
        update();
        btn.addEventListener('click', function () {
          window.scrollTo({ top: 0, behavior: reduced ? 'auto' : 'smooth' });
        });
      })();
    </script>
  </body>
</html>
