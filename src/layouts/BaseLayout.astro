---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
}

const {
  title,
  description = "UAE points and miles — credit card analysis, loyalty programs, and deals.",
  fullWidth = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {
      import.meta.env.PROD && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon='{"token": "REPLACE_WITH_CLOUDFLARE_WEB_ANALYTICS_TOKEN"}'
        />
      )
    }
  </head>
  <body style="display:flex;min-height:100vh;flex-direction:column;">
    <Header />
    {fullWidth ? (
      <main style="flex:1;">
        <slot />
      </main>
    ) : (
      <main style="flex:1;margin:0 auto;width:100%;max-width:80rem;padding:2.5rem 1rem;">
        <slot />
      </main>
    )}
    <Footer />
  </body>
</html>
