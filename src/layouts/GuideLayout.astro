---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  publishedAt?: Date;
  updatedAt?: Date;
  toc?: { id: string; label: string }[];
}

const { title, description, publishedAt, updatedAt, toc = [] } = Astro.props;

const fmt = (d?: Date) =>
  d
    ? d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })
    : null;
---

<BaseLayout title={title} description={description}>
  <article class="grid grid-cols-1 gap-10 lg:grid-cols-4">
    <div class="lg:col-span-3 space-y-6">
      <header class="border-b border-slate-200 pb-6">
        <p class="text-xs uppercase tracking-wide text-slate-500">Guide</p>
        <h1 class="mt-1 text-3xl font-semibold text-slate-900 sm:text-4xl">{title}</h1>
        {description && <p class="mt-2 text-slate-700">{description}</p>}
        <p class="mt-3 text-xs text-slate-500">
          {publishedAt && <>Published {fmt(publishedAt)}</>}
          {updatedAt && publishedAt && updatedAt.getTime() !== publishedAt.getTime() && (
            <span> · Updated {fmt(updatedAt)}</span>
          )}
        </p>
      </header>

      <div class="prose prose-slate max-w-none">
        <slot />
      </div>
    </div>

    <aside class="lg:col-span-1 space-y-6">
      {
        toc.length > 0 && (
          <nav class="rounded-md border border-slate-200 bg-white p-4 text-sm">
            <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-500">
              Contents
            </h3>
            <ul class="mt-2 space-y-1">
              {toc.map((t) => (
                <li>
                  <a href={`#${t.id}`} class="text-slate-700 no-underline hover:text-brand-600">
                    {t.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
      <slot name="related" />
    </aside>
  </article>
</BaseLayout>
