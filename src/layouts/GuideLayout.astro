---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  publishedAt?: Date;
  updatedAt?: Date;
  toc?: { id: string; label: string }[];
}

const { title, description, publishedAt, updatedAt, toc = [] } = Astro.props;

const fmt = (d?: Date) =>
  d
    ? d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })
    : null;

const showUpdated =
  updatedAt && publishedAt && updatedAt.getTime() !== publishedAt.getTime();
---

<BaseLayout title={title} description={description} fullWidth>
  <article class="dp-article is-wide">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">Guide</p>
      <h1 class="dp-article-title">{title}</h1>
      {description && <p class="dp-article-lede">{description}</p>}
      <p class="dp-article-meta">
        {publishedAt && <span><strong>Published</strong> {fmt(publishedAt)}</span>}
        {showUpdated && <span class="sep">·</span>}
        {showUpdated && (
          <span class="verified-chip">Updated {fmt(updatedAt)}</span>
        )}
      </p>
    </header>

    <div class="dp-article-grid">
      <div class="dp-prose">
        <slot />
      </div>

      <aside>
        {toc.length > 0 && (
          <nav class="dp-toc dp-toc-rail">
            <h4>Contents</h4>
            <ul>
              {toc.map((t) => (
                <li><a href={`#${t.id}`}>{t.label}</a></li>
              ))}
            </ul>
          </nav>
        )}
        <slot name="related" />
      </aside>
    </div>
  </article>
</BaseLayout>
