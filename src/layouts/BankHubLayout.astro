---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  bankName: string;
  logo?: string;
  customerService?: {
    phone?: string;
    email?: string;
    website?: string;
  };
}

const { title, description, bankName, customerService } = Astro.props;
---

<BaseLayout title={title} description={description} fullWidth>
  <article class="dp-article is-wide">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">UAE bank</p>
      <h1 class="dp-article-title">{bankName}</h1>
      {description && <p class="dp-article-lede">{description}</p>}
    </header>

    <section class="dp-bank-callout">
      <p class="label">Current salary transfer offer</p>
      <slot name="salary-transfer" />
    </section>

    <section class="dp-article-section">
      <h2>Reward currencies</h2>
      <slot name="currencies" />
    </section>

    <section class="dp-article-section">
      <h2>Cards from {bankName}</h2>
      <slot name="cards" />
    </section>

    <section class="dp-article-section">
      <h2>Recent articles</h2>
      <slot name="articles" />
    </section>

    {customerService && (
      <section class="dp-article-foot">
        <p><strong>Customer service</strong></p>
        {customerService.phone && <p>Phone: {customerService.phone}</p>}
        {customerService.email && (
          <p>Email: <a href={`mailto:${customerService.email}`}>{customerService.email}</a></p>
        )}
        {customerService.website && (
          <p>Web: <a href={customerService.website} target="_blank" rel="noopener">{customerService.website}</a></p>
        )}
      </section>
    )}

    <section class="dp-prose" style="margin-top: 32px;">
      <slot />
    </section>
  </article>
</BaseLayout>

<style>
  .dp-bank-callout {
    border: 1px solid var(--gold);
    border-left-width: 3px;
    border-radius: 6px;
    background: var(--gold-soft);
    padding: 18px 20px;
    margin-bottom: 32px;
  }
  .dp-bank-callout .label {
    font-size: 11px; font-weight: 700; letter-spacing: 2.5px;
    text-transform: uppercase; color: #6b4a14;
    margin-bottom: 10px;
  }
</style>
