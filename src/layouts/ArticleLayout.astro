---
// Editorial article shell — mirrors the .dp-* idiom enforced by
// `EDITORIAL.md` and `CLAUDE.md`. Replaces the prior prose-slate
// implementation as part of the Quiet Ledger redesign (2026-05).
//
// No call sites at the time of rewrite; kept as a layout primitive
// so any future prose page (news post, profile, weekly recap) does
// not reach for Tailwind `prose` and reintroduce a competing
// visual grammar.

import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
  author?: string;
  publishedAt?: Date;
  updatedAt?: Date;
}

const {
  title,
  description,
  eyebrow,
  author = "DubaiPoints Editorial",
  publishedAt,
  updatedAt,
} = Astro.props;

const fmt = (d?: Date) =>
  d
    ? d.toLocaleDateString("en-GB", {
        day: "numeric",
        month: "short",
        year: "numeric",
      })
    : null;

const showUpdated =
  updatedAt && publishedAt && updatedAt.getTime() !== publishedAt.getTime();

const initials = author
  .split(/\s+/)
  .map((w) => w[0]?.toUpperCase() ?? "")
  .slice(0, 2)
  .join("");
---

<BaseLayout title={title} description={description} fullWidth>
  <article class="dp-article">
    <header class="dp-article-head">
      {eyebrow && <p class="dp-article-eyebrow">{eyebrow}</p>}
      <h1 class="dp-article-title">{title}</h1>
      {description && <p class="dp-article-lede">{description}</p>}
      <p class="dp-byline">
        <span class="dp-byline-avatar" aria-hidden="true">{initials}</span>
        <span>By <strong>{author}</strong></span>
        {publishedAt && (
          <>
            <span class="dp-byline-sep">·</span>
            <span>Filed {fmt(publishedAt)}</span>
          </>
        )}
        {showUpdated && (
          <>
            <span class="dp-byline-sep">·</span>
            <span>Updated <strong>{fmt(updatedAt)}</strong></span>
          </>
        )}
      </p>
    </header>

    <section class="dp-prose">
      <slot />
    </section>

    <slot name="related" />

    <footer class="dp-article-foot">
      <p>
        Comments are out of scope at launch. Send tips and corrections to
        <a href="mailto:info@dubaipoints.ae">info@dubaipoints.ae</a>.
      </p>
    </footer>
  </article>
</BaseLayout>
