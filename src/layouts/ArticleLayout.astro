---
// Article layout — Phase B2 + Phase D2/D4 (May 2026 image-forward redesign).
// Reference: dubaipoints/project/templates/article.jsx::Article.
// Used by /guides/<slug>/, /news/<slug>/, /deals/<slug>/.
//
// Shape:
//   pagehead-narrow (gradient + crumb + h1 800 + italic deck)
//   ↓
//   byline strip (avatar + name + filed-date + share/save/print)
//   ↓
//   2-col grid at ≥1024px:
//     [body] hero placeholder + drop-cap prose (slot)
//     [aside] sticky TOC + Trending Now + Insider Intel newsletter card +
//             optional consumer-provided <slot name="related">
//   ↓
//   Related Guides footer (D2) — auto-populated, 3 cards
//   ↓
//   sources footer

import BaseLayout from "./BaseLayout.astro";
import StockImage from "~/components/StockImage.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  description?: string;
  crumb?: string;
  eyebrow?: string;
  deck?: string;
  author?: string;
  authorRole?: string;
  publishedAt?: Date;
  updatedAt?: Date;
  toc?: { id: string; label: string }[];
  sources?: string[];
  showHero?: boolean;
  heroLabel?: string;
  /**
   * Stock-image slug for the article hero. Resolves via the manifest
   * loader (data/stock/manifest.json) — falls back to Cover.astro SVG
   * when no entry exists yet. Per Phase F.6 (May 2026 image-forward
   * redesign), every article gets a real hero once the editor runs
   * `npm run fetch:stock --slug <heroSlug>`.
   */
  heroSlug?: string;
  /** Cover.astro category for the fallback SVG. Defaults to "Guide". */
  heroCategory?: "Guide" | "Review" | "Deal" | "News" | "Programme" | "Topic";
}

const {
  title,
  description,
  crumb,
  deck,
  author = "DubaiPoints Editorial",
  authorRole,
  publishedAt,
  updatedAt,
  toc = [],
  sources = [],
  showHero = false,
  heroLabel = "Hero illustration · 2:1",
  heroSlug,
  heroCategory = "Guide",
} = Astro.props;

const fmt = (d?: Date) =>
  d
    ? d.toLocaleDateString("en-GB", {
        day: "numeric",
        month: "short",
        year: "numeric",
      })
    : null;

const showUpdated =
  updatedAt && publishedAt && updatedAt.getTime() !== publishedAt.getTime();

const initials = author
  .split(/\s+/)
  .map((w) => w[0]?.toUpperCase() ?? "")
  .slice(0, 2)
  .join("");

// Phase D2 / D4 — auto-populated Trending Now sidebar + Related Guides footer.
// The current article is identified by URL prefix-match against guide IDs;
// works whether the consumer is /guides/<slug>/, /news/<slug>/, or /deals/<slug>/.
// News and deals don't match any guide ID so no exclusion happens — correct.
const currentPath = Astro.url.pathname;
const allGuidesForRail = (await getCollection("guides"))
  .filter((g) => !currentPath.endsWith(`/${g.id}/`))
  .sort((a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime());

const trendingGuides = allGuidesForRail.slice(0, 4);
const relatedGuides = allGuidesForRail.slice(0, 3);

const fmtShort = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short" });
---

<BaseLayout title={title} description={description} fullWidth>
  <header class="dp-pagehead is-narrow">
    {crumb && <div class="crumb">{crumb}</div>}
    <h1>{title}</h1>
    {(deck || description) && <p class="deck">{deck ?? description}</p>}
  </header>

  <div class="dp-byline-strip">
    <div class="av" aria-hidden="true">{initials}</div>
    <div>
      <div class="name">
        {author}
        {authorRole && <span style="color: var(--muted); font-weight: 400;"> · {authorRole}</span>}
      </div>
      <div class="when">
        {publishedAt && <>Filed {fmt(publishedAt)}</>}
        {showUpdated && <> · Updated {fmt(updatedAt)}</>}
      </div>
    </div>
    <div class="actions">
      <span>Share</span><span>·</span><span>Save</span><span>·</span><span>Print</span>
    </div>
  </div>

  <div class="dp-article-body-grid">
    <article class="dp-article-body">
      {showHero && (
        heroSlug ? (
          <StockImage
            slug={heroSlug}
            coverTitle={title}
            coverCategory={heroCategory}
            coverSize="hero"
            class="article-hero-image"
            loading="eager"
            sizes="(max-width: 900px) 100vw, 65vw"
          />
        ) : (
          <div class="hero-img">{heroLabel}</div>
        )
      )}
      <div class="dp-prose">
        <slot />
      </div>
    </article>

    <aside class="dp-article-aside">
      {toc.length > 0 && (
        <nav class="dp-toc-card">
          <h4>In this guide</h4>
          <ol>
            {toc.map((t, i) => (
              <li>
                <span class="num">{String(i + 1).padStart(2, "0")}</span>
                <a href={`#${t.id}`}>{t.label}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      {trendingGuides.length > 0 && (
        <nav class="dp-trending-card" aria-label="Trending guides">
          <h4>Trending guides</h4>
          <ol>
            {trendingGuides.map((g, i) => (
              <li>
                <span class="num">{String(i + 1).padStart(2, "0")}</span>
                <a href={`/guides/${g.id}/`}>{g.data.title}</a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      <aside class="dp-aside-newsletter">
        <span class="eyebrow">Insider Intel</span>
        <h4>Friday morning, in your inbox.</h4>
        <p>One email each Friday — salary-transfer changes, new card offers, miles redemptions worth knowing about.</p>
        <a href="/newsletter/" class="cta">Subscribe →</a>
      </aside>

      <slot name="related" />
    </aside>
  </div>

  {relatedGuides.length > 0 && (
    <section class="dp-article-related" aria-label="Related guides">
      <div class="dp-article-related-head">
        <span class="eyebrow">Related</span>
        <h2>More from the guides desk</h2>
      </div>
      <div class="dp-article-related-grid">
        {relatedGuides.map((g) => (
          <a href={`/guides/${g.id}/`} class="dp-article-related-card">
            <StockImage slug={`guide-${g.id}`} coverTitle={g.data.title} coverCategory="Guide" coverSize="med" sizes="(max-width: 900px) 100vw, 33vw" />
            <div class="body">
              <span class="cat">Guide · {fmtShort(g.data.updatedAt)}</span>
              <h3>{g.data.title}</h3>
              <p>{g.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {sources.length > 0 && (
    <footer class="dp-article-sources">
      <p>
        <strong>Sources:</strong>{" "}
        {sources.map((s, i) => (
          <>
            {i > 0 && " · "}
            <a href={s} target="_blank" rel="noopener noreferrer">{new URL(s).hostname}</a>
          </>
        ))}
      </p>
    </footer>
  )}
</BaseLayout>
