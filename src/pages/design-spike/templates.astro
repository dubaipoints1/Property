// ─── Glossary, press, archive, RSS ───────────────────────────────────
const glossaryTerms: Array<[string, string, string]> = [
  ["A", "AECB", "Al Etihad Credit Bureau — the UAE's only credit bureau. Issuers query AECB for a credit score before approving cards or loans."],
  ["A", "AED", "Arab Emirates Dirham — every figure on this site is in AED unless explicitly noted."],
  ["A", "Affiliate / referral link", "A link that pays the publisher a commission if the reader applies. We use them; they don't affect verdicts."],
  ["D", "Devaluation", "When a points programme increases the points required for a redemption without notice, or with little notice. Always permanent."],
  ["D", "DP value", "DubaiPoints' weighted-blend valuation of a points currency, used in every earn-rate calculation. Recalibrated quarterly."],
  ["E", "Earn rate", "Points or cashback earned per AED spent, before any caps, exclusions, or category multipliers."],
  ["F", "FX markup", "The percentage premium an issuer adds to non-AED transactions, on top of the network rate."],
  ["M", "Min salary", "Minimum monthly salary required to be eligible for a card. Almost always required to be salary-transferred to the issuing bank."],
  ["Q", "Qualifying months", "Number of consecutive months a salary must be transferred to qualify for a salary-transfer bonus. FAB raised this from 3 to 4 in Jan 2026."],
  ["S", "Salary transfer", "UAE-specific arrangement where an employer pays salary directly to one bank, in exchange for a bonus, preferential rates, or fee waivers."],
  ["S", "Salik / Darb", "Toll systems in Dubai (Salik) and Abu Dhabi (Darb). Excluded from earn rates on most UAE credit cards."],
  ["S", "Sweet spot", "A redemption where the value extracted significantly exceeds DP value — usually premium-cabin partner award space."],
];
const glossaryLetters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".split("");
const glossaryByLetter: Record<string, typeof glossaryTerms> = {};
for (const t of glossaryTerms) {
  (glossaryByLetter[t[0]] ||= []).push(t);
}
const glossaryOrderedLetters = Object.keys(glossaryByLetter);

