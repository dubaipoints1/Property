                        <div class="nm">{n}</div>
                        <div class="hx">{h}</div>
                      </div>
                    ))}
                  </div>
                </section>
                <section>
                  <h3>Tokens · type</h3>
                  <div class="ty">
                    <div>
                      <div class="lb">Display · Fraunces 800 · -1.2</div>
                      <div class="display">Display.</div>
                    </div>
                    <div>
                      <div class="lb">Headline · Fraunces 700 · -0.6</div>
                      <div class="headline">Headline of an article.</div>
                    </div>
                    <div>
                      <div class="lb">Dek · Fraunces italic 500</div>
                      <div class="dek">The standfirst sits below the headline.</div>
                    </div>
                    <div>
                      <div class="lb">Body · DM Sans 16/1.72</div>
                      <div class="body">Body copy is set in DM Sans at sixteen pixels with a line-height of 1.72 — a slightly looser measure than the default.</div>
                    </div>
                    <div>
                      <div class="lb">Eyebrow · DM Sans 600 · 1.5px tracking</div>
                      <div class="eyebrow-sample">Salary transfer · 9 min · 8 May</div>
                    </div>
                  </div>
                </section>
              </div>
              <WfFooter />
            </div>
          </WfBoard>
        </div>
