              <div class="wf-cardart">
                <div class="wf-cardart-head">
                  <div class="eyebrow">System · per-issuer card art</div>
                  <h2>Each issuer has its own gradient. Cards inherit; templates inherit from the card.</h2>
                  <p>Ends the "everything is navy" problem. The accent ink colour is used for the issuer logo and the card's chip pattern; the gradient is used for the card body and its tile background on feed pages.</p>
                </div>
                <div class="wf-cardart-grid">
                  {issuers.map((iss) => (
                    <div class="wf-cardart-tile">
                      <div class="card" style={`background:linear-gradient(135deg,${iss.from},${iss.to});`}>
                        <div class="bank" style={`color:${iss.ink};`}>{iss.name}</div>
                        <div class="chip" style={`background:${iss.ink};opacity:0.85;`}></div>
                        <div class="num" style={`color:${iss.ink};opacity:0.7;`}>•••• 4242</div>
                      </div>
                      <div class="meta">
                        <div class="nm">{iss.name} · {iss.sub}</div>
                        <div class="hx">{iss.from} → {iss.to}</div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </WfBoard>

          <WfBoard label="Social / OG previews · 1200×630" width={1240} height={760}>
