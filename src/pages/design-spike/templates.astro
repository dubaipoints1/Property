const valBarPct = (floor: string, ceil: string, dp: string): number => {
  if (dp === "—") return 0;
  const f = parseFloat(floor);
  const c = parseFloat(ceil);
  const d = parseFloat(dp);
  if (Number.isNaN(f) || Number.isNaN(c) || Number.isNaN(d) || c === f) return 0;
  return Math.max(15, ((d - f) / (c - f)) * 100);
};

