                      <div class="wm">DubaiPoints<span class="dot">.</span></div>
                      <div class="kind">{og.kind.toUpperCase()}</div>
                    </div>
                    <div class="bd">
                      <h2>{og.title}</h2>
                    </div>
                    <div class="ft">
                      <div>{og.byline}</div>
                      {og.score && (
                        <div class="sc"><span class="n">{og.score}</span><span class="t">/10</span></div>
                      )}
