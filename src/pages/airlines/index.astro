---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const programs = await getCollection("programs");
---

<BaseLayout
  title="Middle East airline programmes"
  description="Skywards, Etihad Guest, Qatar Privilege Club, Saudia Alfursan and more — UAE-relevant frequent flyer programmes covered in depth."
  fullWidth
>
  <article class="dp-article is-wide">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">Airline programmes</p>
      <h1 class="dp-article-title">Frequent flyer programmes <em>UAE residents</em> earn and redeem in.</h1>
      <p class="dp-article-lede">Each programme page covers tiers, sweet spots, transfer partners, and expiry policy — the things that determine whether the Miles you earn are worth what you think they are.</p>

      <div class="dp-dir-pills">
        <a href="/valuations/" class="dp-dir-pill is-feature">View AED valuations →</a>
      </div>
    </header>

    <div class="dp-dir-grid">
      {programs.map((p) => (
        <a href={`/airlines/${p.id}/`} class="dp-dir-tile">
          <span class="eyebrow">{p.data.region} · {p.data.currencyName}</span>
          <span class="title">{p.data.name}</span>
        </a>
      ))}
    </div>
  </article>
</BaseLayout>
