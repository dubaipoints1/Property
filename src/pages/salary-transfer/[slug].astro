---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SalaryTransferTrackerLayout from "~/layouts/SalaryTransferTrackerLayout.astro";
import SalaryTransferTracker from "~/components/islands/SalaryTransferTracker.tsx";
import Disclaimer from "~/components/Disclaimer.astro";
import { getCollection, render } from "astro:content";
import { getLiveOffers, getOffersForBank } from "~/lib/offerAdapter";
import { findBand, formatAED } from "~/lib/salaryTransfer";

export async function getStaticPaths() {
  const bands = [
    { slug: "aed-5000-to-8000", sample: 6000, label: "AED 5,000 – 8,000" },
    { slug: "aed-8000-to-15000", sample: 10000, label: "AED 8,000 – 15,000" },
    { slug: "aed-15000-to-30000", sample: 20000, label: "AED 15,000 – 30,000" },
    { slug: "aed-30000-to-50000", sample: 40000, label: "AED 30,000 – 50,000" },
    { slug: "aed-50000-plus", sample: 60000, label: "AED 50,000+" },
  ];
  const bandPaths = bands.map((b) => ({
    params: { slug: b.slug },
    props: { kind: "band" as const, sample: b.sample, label: b.label },
  }));
  const banks = await getCollection("banks");
  const bankPaths = banks.map((bank) => ({
    params: { slug: bank.id },
    props: { kind: "bank" as const, bankId: bank.id, bankName: bank.data.name },
  }));
  return [...bandPaths, ...bankPaths];
}

const props = Astro.props as
  | { kind: "band"; sample: number; label: string }
  | { kind: "bank"; bankId: string; bankName: string };

let bandOffers: Awaited<ReturnType<typeof getLiveOffers>> = [];
let bankOffers: Awaited<ReturnType<typeof getLiveOffers>> = [];
let renderedNotes: { id: string; Content: any }[] = [];

if (props.kind === "band") {
  const all = await getLiveOffers();
  bandOffers = all.filter((o) => findBand(o.salaryBands, props.sample) !== null);
} else {
  bankOffers = await getOffersForBank(props.bankId);
  const offerEntries = await getCollection(
    "salaryTransferOffers",
    (e) => e.data.bank.id === props.bankId,
  );
  renderedNotes = await Promise.all(
    offerEntries.map(async (e) => {
      const { Content } = await render(e);
      return { id: e.id, Content };
    }),
  );
}
---

{
  props.kind === "band" && (
    <SalaryTransferTrackerLayout
      title={`Salary transfer offers — ${props.label}`}
      description={`Live UAE salary transfer offers available to earners in the ${props.label} band.`}
      liveCount={bandOffers.length}
    >
      <div slot="tracker">
        <SalaryTransferTracker offers={bandOffers} client:load />
      </div>
      <Disclaimer slot="footer" variant="offer" />
    </SalaryTransferTrackerLayout>
  )
}

{
  props.kind === "bank" && (
    <BaseLayout
      title={`${props.bankName} — salary transfer offer details`}
      description={`Deep-dive on ${props.bankName}'s current salary transfer offer: bands, clawback, payout timing, and expat-relevant gotchas.`}
    >
      <header class="border-b border-slate-200 pb-6">
        <p class="text-xs uppercase tracking-wide text-slate-500">Salary transfer</p>
        <h1 class="mt-1 text-3xl font-semibold text-slate-900">{props.bankName}</h1>
        <p class="mt-2 text-sm text-slate-700">
          <a href={`/salary-transfer/history/${props.bankId}/`}>
            View {props.bankName} offer history →
          </a>
        </p>
      </header>

      {bankOffers.length === 0 && (
        <p class="mt-6 rounded-md bg-slate-50 p-4 text-sm text-slate-600">
          No live offer tracked for {props.bankName}.
        </p>
      )}

      {bankOffers.map((o) => {
        const noteEntry = renderedNotes.find((n) => n.id === o.id);
        const NoteContent = noteEntry?.Content;
        return (
          <article class="mt-8 space-y-4 rounded-lg border border-slate-200 bg-white p-6">
            <header class="flex flex-wrap items-baseline justify-between gap-2">
              <h2 class="text-xl font-semibold text-slate-900">{o.name}</h2>
              <span class="text-xs uppercase tracking-wide text-slate-500">
                Last verified {new Date(o.lastVerified).toLocaleDateString("en-GB")}
              </span>
            </header>

            <table class="w-full text-sm">
              <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
                <tr>
                  <th class="px-3 py-2">Salary band</th>
                  <th class="px-3 py-2">Reward</th>
                  <th class="px-3 py-2">Type</th>
                  <th class="px-3 py-2">Pays out</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-200">
                {o.salaryBands.map((b) => (
                  <tr>
                    <td class="px-3 py-2">
                      {formatAED(b.minSalary)} –{" "}
                      {b.maxSalary === null ? "no limit" : formatAED(b.maxSalary)}
                    </td>
                    <td class="px-3 py-2 font-semibold">{formatAED(b.rewardAmount)}</td>
                    <td class="px-3 py-2">{b.rewardType.replace("_", " ")}</td>
                    <td class="px-3 py-2">+{b.monthsToPayout} months</td>
                  </tr>
                ))}
              </tbody>
            </table>

            <section>
              <h3 class="text-sm font-semibold text-slate-900">Requirements</h3>
              <ul class="mt-1 list-disc space-y-1 pl-5 text-sm text-slate-700">
                {o.requirements.map((r) => (
                  <li>{r}</li>
                ))}
              </ul>
            </section>

            <section class="rounded-md bg-rose-50 p-3 text-sm text-rose-900">
              <strong>Clawback:</strong> {o.clawbackTerms}
            </section>

            {NoteContent && (
              <section class="prose prose-slate max-w-none border-t border-slate-200 pt-4">
                <NoteContent />
              </section>
            )}

            <p class="text-xs text-slate-500">
              <a href={o.sourceUrl}>Source</a>
            </p>
          </article>
        );
      })}

      <Disclaimer variant="offer" />
    </BaseLayout>
  )
}
