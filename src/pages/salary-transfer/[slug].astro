---
import BaseLayout from "~/layouts/BaseLayout.astro";
import SalaryTransferTrackerLayout from "~/layouts/SalaryTransferTrackerLayout.astro";
import SalaryTransferTracker from "~/components/islands/SalaryTransferTracker.tsx";
import Disclaimer from "~/components/Disclaimer.astro";
import { getCollection, render } from "astro:content";
import { getLiveOffers, getOffersForBank } from "~/lib/offerAdapter";
import { findBand, formatAED } from "~/lib/salaryTransfer";

export async function getStaticPaths() {
  const bands = [
    { slug: "aed-5000-to-8000", sample: 6000, label: "AED 5,000 – 8,000" },
    { slug: "aed-8000-to-15000", sample: 10000, label: "AED 8,000 – 15,000" },
    { slug: "aed-15000-to-30000", sample: 20000, label: "AED 15,000 – 30,000" },
    { slug: "aed-30000-to-50000", sample: 40000, label: "AED 30,000 – 50,000" },
    { slug: "aed-50000-plus", sample: 60000, label: "AED 50,000+" },
  ];
  const bandPaths = bands.map((b) => ({
    params: { slug: b.slug },
    props: { kind: "band" as const, sample: b.sample, label: b.label },
  }));
  const banks = await getCollection("banks");
  const bankPaths = banks.map((bank) => ({
    params: { slug: bank.id },
    props: { kind: "bank" as const, bankId: bank.id, bankName: bank.data.name },
  }));
  return [...bandPaths, ...bankPaths];
}

const props = Astro.props as
  | { kind: "band"; sample: number; label: string }
  | { kind: "bank"; bankId: string; bankName: string };

let bandOffers: Awaited<ReturnType<typeof getLiveOffers>> = [];
let bankOffers: Awaited<ReturnType<typeof getLiveOffers>> = [];
let renderedNotes: { id: string; Content: any }[] = [];

if (props.kind === "band") {
  const all = await getLiveOffers();
  bandOffers = all.filter((o) => findBand(o.salaryBands, props.sample) !== null);
} else {
  bankOffers = await getOffersForBank(props.bankId);
  const offerEntries = await getCollection(
    "salaryTransferOffers",
    (e) => e.data.bank.id === props.bankId,
  );
  renderedNotes = await Promise.all(
    offerEntries.map(async (e) => {
      const { Content } = await render(e);
      return { id: e.id, Content };
    }),
  );
}
---

{
  props.kind === "band" && (
    <SalaryTransferTrackerLayout
      title={`Salary transfer offers — ${props.label}`}
      description={`Live UAE salary transfer offers available to earners in the ${props.label} band.`}
      liveCount={bandOffers.length}
    >
      <div slot="tracker">
        <SalaryTransferTracker offers={bandOffers} client:load />
      </div>
      <Disclaimer slot="footer" variant="offer" />
    </SalaryTransferTrackerLayout>
  )
}

{
  props.kind === "bank" && (
    <BaseLayout
      title={`${props.bankName} — salary transfer offer details`}
      description={`Deep-dive on ${props.bankName}'s current salary transfer offer: bands, clawback, payout timing, and expat-relevant gotchas.`}
      fullWidth
    >
      <article class="dp-article is-wide">
        <header class="dp-article-head">
          <p class="dp-article-eyebrow">Salary transfer</p>
          <h1 class="dp-article-title">{props.bankName}</h1>
          <p class="dp-article-meta">
            <a href={`/salary-transfer/history/${props.bankId}/`}>
              View {props.bankName} offer history →
            </a>
          </p>
        </header>

        {bankOffers.length === 0 && (
          <p class="dp-tracker-empty">No live offer tracked for {props.bankName}.</p>
        )}

        {bankOffers.map((o) => {
          const noteEntry = renderedNotes.find((n) => n.id === o.id);
          const NoteContent = noteEntry?.Content;
          return (
            <section class="dp-offer-card">
              <header class="dp-offer-head">
                <h2>{o.name}</h2>
                <span class="dp-offer-verified">
                  Last verified {new Date(o.lastVerified).toLocaleDateString("en-GB")}
                </span>
              </header>

              <table class="dp-data-table">
                <thead>
                  <tr>
                    <th>Salary band</th>
                    <th>Reward</th>
                    <th>Type</th>
                    <th>Pays out</th>
                  </tr>
                </thead>
                <tbody>
                  {o.salaryBands.map((b) => (
                    <tr>
                      <td>
                        {formatAED(b.minSalary)} –{" "}
                        {b.maxSalary === null ? "no limit" : formatAED(b.maxSalary)}
                      </td>
                      <td class="num">{formatAED(b.rewardAmount)}</td>
                      <td>{b.rewardType.replace("_", " ")}</td>
                      <td>+{b.monthsToPayout} months</td>
                    </tr>
                  ))}
                </tbody>
              </table>

              <section class="dp-article-section">
                <h3>Requirements</h3>
                <ul class="dp-bullet-list">
                  {o.requirements.map((r) => <li>{r}</li>)}
                </ul>
              </section>

              <aside class="dp-clawback">
                <strong>Clawback:</strong> {o.clawbackTerms}
              </aside>

              {NoteContent && (
                <section class="dp-prose dp-offer-note">
                  <NoteContent />
                </section>
              )}

              <p class="dp-offer-source">
                <a href={o.sourceUrl} target="_blank" rel="noopener">Source →</a>
              </p>
            </section>
          );
        })}

        <Disclaimer variant="offer" />
      </article>
    </BaseLayout>
  )
}

<style>
  .dp-offer-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    padding: 24px;
    margin-bottom: 24px;
  }
  .dp-offer-head {
    display: flex; flex-wrap: wrap;
    align-items: baseline; justify-content: space-between;
    gap: 12px; margin-bottom: 18px;
    padding-bottom: 14px; border-bottom: 1px solid var(--line);
  }
  .dp-offer-head h2 {
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: clamp(18px, 3vw, 22px);
    letter-spacing: -0.3px; color: var(--ink);
  }
  .dp-offer-verified {
    font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
    text-transform: uppercase; color: var(--muted);
  }
  .dp-clawback {
    margin-top: 14px;
    padding: 12px 14px;
    border-left: 3px solid var(--red);
    background: #fef2f2;
    border-radius: 4px;
    font-size: 13px; line-height: 1.55;
    color: #7f1d1d;
  }
  .dp-clawback strong { color: #7f1d1d; }
  .dp-offer-note {
    margin-top: 16px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
  }
  .dp-offer-source {
    margin-top: 14px;
    font-size: 12px; color: var(--muted);
  }
  .dp-offer-source a { color: var(--ink); font-weight: 600; text-decoration: underline; text-underline-offset: 3px; text-decoration-color: var(--line); }
  .dp-offer-source a:hover { color: var(--gold); }
</style>
