---
// Guides index — section-index template (Phase B1, Claude Design handoff).
// Reference: dubaipoints/project/templates/chrome.jsx::SectionIndex.
// Page-head + filter pills + featured grid (1 hero + 2 medium + 4 small) +
// green-mark pull-quote + numbered feed + pagination.

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const guides = (await getCollection("guides")).sort(
  (a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime(),
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short" });

// Pillar treatment: surface the Expat Starter cornerstone if present —
// it slots into the hero card position. Otherwise top-most by updatedAt.
const pillar = guides.find((g) => g.id === "expat-starter");
const others = guides.filter((g) => g.id !== "expat-starter");
const featured = pillar ? [pillar, ...others.slice(0, 6)] : others.slice(0, 7);
const remaining = pillar ? others.slice(6) : others.slice(7);

// Filter facets — informal categories until guides schema gains a `category`.
const filters = [
  { label: "All", active: true },
  { label: "Salary transfer" },
  { label: "Account opening" },
  { label: "Redemptions" },
  { label: "Valuations" },
  { label: "Tax & compliance" },
];
---

<BaseLayout
  title="Guides — UAE points and miles"
  description="Long-form, AED-first guides to UAE credit-card eligibility, salary-transfer mechanics, miles redemption strategy, and expat-specific friction."
  fullWidth
>
  <div class="dp-pagehead">
    <div class="crumb">DubaiPoints / Guides</div>
    <h1>Guides</h1>
    <p>Long-form analysis on UAE banking, salary transfer, points valuations and redemption strategy. Updated as products change — not on a schedule.</p>
  </div>

  <div class="dp-filters">
    {filters.map((f) => (
      <span class={`dp-filter-pill${f.active ? " is-active" : ""}`}>{f.label}</span>
    ))}
    <span class="dp-sort">Sort: <strong>Newest</strong> ▾</span>
  </div>

  {featured.length > 0 && (
    <section class="dp-featured-band">
      <div class="dp-featured-eyebrow">
        <span>Featured this week</span>
        <span class="rule"></span>
        <span class="meta">Curated by editors · refreshed Mondays</span>
      </div>
      <div class="dp-featured-grid">
        {featured[0] && (
          <a href={`/guides/${featured[0].id}/`} class="dp-story-card hero">
            <div class="cover">Cover · Guide</div>
            <div class="body">
              <div class="meta"><span class="cat">Guide</span><span>{fmt(featured[0].data.updatedAt)}</span></div>
              <h3>{featured[0].data.title}</h3>
              <p>{featured[0].data.description}</p>
              <div class="by">By DubaiPoints Editorial</div>
            </div>
          </a>
        )}
        {featured[1] && (
          <a href={`/guides/${featured[1].id}/`} class="dp-story-card med">
            <div class="cover">Cover · Guide</div>
            <div class="body">
              <div class="meta"><span class="cat">Guide</span><span>{fmt(featured[1].data.updatedAt)}</span></div>
              <h3>{featured[1].data.title}</h3>
              <p>{featured[1].data.description}</p>
            </div>
          </a>
        )}
        {featured[2] && (
          <a href={`/guides/${featured[2].id}/`} class="dp-story-card med">
            <div class="cover">Cover · Guide</div>
            <div class="body">
              <div class="meta"><span class="cat">Guide</span><span>{fmt(featured[2].data.updatedAt)}</span></div>
              <h3>{featured[2].data.title}</h3>
              <p>{featured[2].data.description}</p>
            </div>
          </a>
        )}
        {featured.slice(3, 7).map((g) => (
          <a href={`/guides/${g.id}/`} class="dp-story-card sm">
            <div class="cover">Cover</div>
            <div class="body">
              <div class="meta"><span class="cat">Guide</span><span>{fmt(g.data.updatedAt)}</span></div>
              <h3>{g.data.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="dp-pullquote">
    <div class="mark">"</div>
    <blockquote>
      The only UAE points publication that pays its own annual fees, refuses advertorial, and prints the date next to every verdict.
    </blockquote>
    <div class="attr"><span class="rule"></span>Editorial standard · est. 2026</div>
  </div>

  {remaining.length > 0 && (
    <>
      <div class="dp-list-head">
        <div class="t">All guides</div>
        <div class="m">Sorted by date · {remaining.length} more below</div>
      </div>
      <div class="dp-feed">
        {remaining.map((g, i) => {
          const n = i + featured.length + 1;
          return (
            <a href={`/guides/${g.id}/`} class="dp-feed-row">
              <div>
                <div class="num">{String(n).padStart(2, "0")}</div>
                <div class="feed-eyebrow">Guide</div>
              </div>
              <div>
                <h3>{g.data.title}</h3>
                <div class="summary">{g.data.description}</div>
              </div>
              <div class="thumb">Cover · Guide</div>
              <div class="when">{fmt(g.data.updatedAt)}</div>
            </a>
          );
        })}
      </div>
    </>
  )}

  <div class="dp-page-nav">
    <span style="font-size:12px;color:var(--muted);">
      Showing all {guides.length} guide{guides.length === 1 ? "" : "s"}
    </span>
  </div>
</BaseLayout>
