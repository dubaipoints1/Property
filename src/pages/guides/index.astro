---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const guides = (await getCollection("guides")).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout
  title="Guides — UAE points and miles"
  description="Long-form guides to UAE credit card eligibility, salary transfer mechanics, miles redemption strategy, and expat-specific friction."
>
  <header class="border-b border-slate-200 pb-6">
    <h1 class="text-3xl font-semibold text-slate-900">Guides</h1>
    <p class="mt-2 text-slate-700">Deep, evergreen reference content.</p>
  </header>

  <ul class="mt-6 grid gap-4 sm:grid-cols-2">
    {
      guides.map((g) => (
        <li>
          <a
            href={`/guides/${g.id}/`}
            class="block rounded-md border border-slate-200 bg-white p-4 no-underline hover:border-brand-500"
          >
            <h2 class="font-semibold text-slate-900">{g.data.title}</h2>
            <p class="mt-1 text-sm text-slate-600">{g.data.description}</p>
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
