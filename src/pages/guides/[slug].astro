---
import ArticleLayout from "~/layouts/ArticleLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const guides = await getCollection("guides");
  return guides.map((g) => ({ params: { slug: g.id }, props: { guide: g } }));
}

const { guide } = Astro.props;
const { Content, headings } = await render(guide);

// Surface H2s as TOC entries — already anchored by Astro/MDX.
const toc = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ id: h.slug, label: h.text }));
---

<ArticleLayout
  title={guide.data.title}
  description={guide.data.description}
  crumb="DubaiPoints / Guides"
  eyebrow="GUIDE"
  publishedAt={guide.data.publishedAt}
  updatedAt={guide.data.updatedAt}
  toc={toc}
  showHero
  heroSlug={`guide-${guide.id}`}
  heroCategory="Guide"
  heroLabel="Guide hero · illustration"
>
  <Content />
</ArticleLayout>
