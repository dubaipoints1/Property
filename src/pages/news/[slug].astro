---
import { getCollection, render } from "astro:content";
import BaseLayout from "~/layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("news");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });

const showUpdated =
  post.data.updatedAt &&
  post.data.updatedAt.getTime() !== post.data.publishedAt.getTime();
---

<BaseLayout
  title={`${post.data.title} — DubaiPoints`}
  description={post.data.description}
  fullWidth
>
  <article class="dp-article">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">{post.data.category.replace(/-/g, " ")}</p>
      <h1 class="dp-article-title">{post.data.title}</h1>
      <p class="dp-article-lede">{post.data.description}</p>
      <p class="dp-article-meta">
        <span><strong>Filed</strong> {fmt(post.data.publishedAt)}</span>
        {showUpdated && (
          <>
            <span class="sep">·</span>
            <span class="verified-chip">Updated {fmt(post.data.updatedAt!)}</span>
          </>
        )}
      </p>
    </header>

    <section class="dp-prose">
      <Content />
    </section>

    {post.data.sources.length > 0 && (
      <footer class="dp-article-foot">
        <p>
          <strong>Sources</strong>{" "}
          {post.data.sources.map((s, i) => (
            <>
              {i > 0 && " · "}
              <a href={s} target="_blank" rel="noopener noreferrer">{new URL(s).hostname}</a>
            </>
          ))}
        </p>
      </footer>
    )}
  </article>
</BaseLayout>
