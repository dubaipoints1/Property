---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("news"))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const fmtShort = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short" });
---

<BaseLayout
  title="News — DubaiPoints"
  description="UAE points-and-miles news: salary-transfer offer updates, card launches, programme changes, and regulatory shifts that affect UAE residents."
  fullWidth
>
  <article class="dp-article is-wide">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">News</p>
      <h1 class="dp-article-title">UAE points and rewards news</h1>
      <p class="dp-article-lede">
        Salary-transfer changes, card launches, programme shifts, and the
        regulatory updates that affect UAE residents — every figure in AED,
        every claim sourced.
      </p>
    </header>

    {posts.length === 0 ? (
      <section class="dp-prose news-empty">
        <p>
          <strong>No news posts yet.</strong> The newsroom is being assembled.
        </p>
        <p>
          When stories land, they appear here in reverse-chronological order
          and on the homepage feed under the <em>Latest analysis</em> tab.
          You can also follow the <a href="/rss.xml">site-wide RSS feed</a> to
          get every post as it ships, or subscribe to <a href="/newsletter/">the
          Friday brief</a> for the weekly recap.
        </p>
        <p>
          Have a tip? <a href="mailto:info@dubaipoints.ae">Email us</a>.
        </p>
      </section>
    ) : (
      <section class="news-list">
        {posts.map((post) => (
          <a href={`/news/${post.id}/`} class="news-row">
            <span class="news-cat">{post.data.category.replace(/-/g, " ")}</span>
            <span class="news-title">{post.data.title}</span>
            <span class="news-meta">
              {fmtShort(post.data.publishedAt)}
              {post.data.updatedAt && (
                <> · updated {fmtShort(post.data.updatedAt)}</>
              )}
            </span>
            <span class="news-desc">{post.data.description}</span>
          </a>
        ))}
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .news-empty p {
    margin-bottom: 14px;
  }

  .news-list {
    display: flex; flex-direction: column;
    border-top: 1px solid var(--ink);
  }
  .news-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 6px;
    padding: 22px 0;
    border-bottom: 1px solid var(--line);
  }
  @media (min-width: 768px) {
    .news-row {
      grid-template-columns: 130px minmax(0, 1fr) 130px;
      gap: 24px;
      align-items: baseline;
    }
  }
  .news-cat {
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--green);
  }
  .news-title {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: clamp(18px, 2vw, 22px);
    line-height: 1.3; letter-spacing: -0.3px;
    color: var(--ink); text-wrap: balance;
  }
  .news-row:hover .news-title {
    text-decoration: underline;
    text-decoration-color: var(--link);
    text-underline-offset: 4px;
  }
  .news-meta {
    font-size: 12px; color: var(--muted);
    letter-spacing: 0.2px;
  }
  @media (min-width: 768px) { .news-meta { text-align: right; } }
  .news-desc {
    font-size: 14px; color: var(--ink-soft); line-height: 1.55;
    grid-column: 1;
  }
  @media (min-width: 768px) { .news-desc { grid-column: 2; } }
</style>
