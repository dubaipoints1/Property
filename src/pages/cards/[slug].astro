---
import CardReviewLayout from "~/layouts/CardReviewLayout.astro";
import { getCollection, getEntry, render } from "astro:content";
import {
  getCardData,
  getAllCards,
  earnRatesNumeric,
} from "~/lib/cardsData";
import {
  topEarnEntry,
  CATEGORY_LABELS_FOR_TOP,
  formatEarnValue,
} from "~/lib/cardsDataFormat";

// Generate one route per card in the data layer (L2). Even cards without
// editorial MDX (L3) get a page — it just renders attributes only.
export async function getStaticPaths() {
  return getAllCards().map((card) => ({
    params: { slug: card.slug },
    props: { slug: card.slug },
  }));
}

const { slug } = Astro.props;
const data = getCardData(slug);
if (!data) {
  throw new Error(`No card data for slug: ${slug}`);
}

// Editorial layer (L3) — optional; render with empty body when absent.
const editorial = (await getCollection("cards")).find((c) => c.id === slug);
const rendered = editorial ? await render(editorial) : null;
const Content = rendered?.Content ?? null;

// Jump-nav: every card review authors its own <JumpToSection> in the MDX
// body with editor-curated labels (the component's documented convention;
// 55/55 reviews carry it). Do NOT also derive a tocSections list here and
// pass it to the layout — that was PR-F (29 May 2026), which double-rendered
// the nav on every review because the MDX-side one is invisible to a
// template-level audit. Removed 2 July 2026.

// Bank reference resolves through the banks content collection; falls back to slug.
const bankEntry = await getEntry("banks", data.bank);
const bankName = bankEntry?.data.name ?? data.bank;

// Per §9 — composed meta title + description from L2 attributes. Closes
// the SEO Strategist audit's "meta title pattern not applied editorially"
// and "card review descriptions are the welcome-bonus string" P1s.
// Month stamp computed from L2 lastVerified so the title can never
// silently roll over a month boundary (10 June 2026 staleness sweep —
// the previous hardcoded "(May 2026)" went stale the day the calendar
// turned).
const verifiedStamp = new Date(data.lastVerified).toLocaleDateString("en-GB", {
  month: "long",
  year: "numeric",
});
const cardTitle = `${data.name} review (${verifiedStamp}) | DubaiPoints`;
// On-page H1: same headline without the brand suffix — "| DubaiPoints"
// belongs in the <title> tag, not rendered above the fold.
const cardHeading = `${data.name} review (${verifiedStamp})`;
const top = topEarnEntry(data.earnRates as Record<string, unknown>);
const topLabel = top ? CATEGORY_LABELS_FOR_TOP[top.key] ?? top.key : null;
const feeFragment = data.annualFee.amount === 0 ? "No annual fee" : `AED ${data.annualFee.amount.toLocaleString()} annual fee`;
// Provenance-gated min-salary fragment: if eligibility is unverified
// we drop the AED figure from the SERP description entirely rather
// than emit "min salary AED 5,000" as if confirmed (3 June 2026
// audit P0 H3 — same pattern as the FX-fee provenance gate).
const minSalaryFragment = data.eligibility.invitationOnly
  ? "invitation-only"
  : data._provenance?.eligibility === "needs-review"
  ? null
  : data.eligibility.minSalary > 0
  ? `min salary AED ${data.eligibility.minSalary.toLocaleString()}`
  : "no min salary";
const earnFragment = top && topLabel ? `${formatEarnValue(top.value, data.earnUnit, data.categories)} ${topLabel}` : null;
const cardDescription = [
  // Card names often already start with the bank ("Emirates NBD Go4it
  // Gold") — only prefix when they don't, else the SERP description
  // reads "Emirates NBD Emirates NBD Go4it Gold review".
  data.name.toLowerCase().startsWith(bankName.toLowerCase())
    ? `${data.name} review`
    : `${bankName} ${data.name} review`,
  feeFragment,
  minSalaryFragment,
  earnFragment,
  "AED-first verdict from DubaiPoints",
]
  .filter(Boolean)
  .join(" · ");
---

<CardReviewLayout
  title={cardTitle}
  heading={cardHeading}
  description={cardDescription}
  bankName={bankName}
  bankSlug={data.bank}
  slug={slug}
  cardName={data.name}
  network={data.network}
  annualFee={data.annualFee.amount}
  fxFee={data.fxFee}
  minSalary={data.eligibility.minSalary}
  earnRates={earnRatesNumeric(data.earnRates)}
  earnUnit={data.earnUnit}
  categories={data.categories}
  fxFeeProvenance={data._provenance?.fxFee}
  eligibilityProvenance={data._provenance?.eligibility}
  invitationOnly={data.eligibility.invitationOnly === true}
  perks={data.perks}
  pros={editorial?.data.pros}
  cons={editorial?.data.cons}
  editorTake={editorial?.data.editorTake}
  lastVerified={data.lastVerified}
  verifiedBy={editorial?.data.verifiedBy}
  sources={data.sources}
  welcomeBonus={data.welcomeBonus}
  heroImage={editorial?.data.heroImage}
  category={data.categories?.[0]}
>
  {Content && <Content />}
</CardReviewLayout>
