---
import CardReviewLayout from "~/layouts/CardReviewLayout.astro";
import { getCollection, getEntry, render } from "astro:content";
import {
  getCardData,
  getAllCards,
  earnRatesNumeric,
  welcomeBonusDisplay,
} from "~/lib/cardsData";

// Generate one route per card in the data layer (L2). Even cards without
// editorial MDX (L3) get a page — it just renders attributes only.
export async function getStaticPaths() {
  return getAllCards().map((card) => ({
    params: { slug: card.slug },
    props: { slug: card.slug },
  }));
}

const { slug } = Astro.props;
const data = getCardData(slug);
if (!data) {
  throw new Error(`No card data for slug: ${slug}`);
}

// Editorial layer (L3) — optional; render with empty body when absent.
const editorial = (await getCollection("cards")).find((c) => c.id === slug);
const rendered = editorial ? await render(editorial) : null;
const Content = rendered?.Content ?? null;
const headings = rendered?.headings ?? [];

// Bank reference resolves through the banks content collection; falls back to slug.
const bankEntry = await getEntry("banks", data.bank);
const bankName = bankEntry?.data.name ?? data.bank;
---

<CardReviewLayout
  title={`${data.name} review`}
  description={welcomeBonusDisplay(data.welcomeBonus)}
  bankName={bankName}
  bankSlug={data.bank}
  slug={slug}
  cardName={data.name}
  network={data.network}
  annualFee={data.annualFee.amount}
  fxFee={data.fxFee}
  minSalary={data.eligibility.minSalary}
  earnRates={earnRatesNumeric(data.earnRates)}
  perks={data.perks}
  pros={editorial?.data.pros}
  cons={editorial?.data.cons}
  editorTake={editorial?.data.editorTake}
  lastVerified={data.lastVerified}
  verifiedBy={editorial?.data.verifiedBy}
  sources={data.sources}
  heroImage={editorial?.data.heroImage}
  headings={headings}
>
  {Content && <Content />}
</CardReviewLayout>
