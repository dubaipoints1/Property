---
import ComparisonTableLayout from "~/layouts/ComparisonTableLayout.astro";
import { getEntry } from "astro:content";
import {
  getActiveCards,
  welcomeBonusHeadline,
  annualFeeLabel,
} from "~/lib/cardsData";
import { formatEarnValue } from "~/lib/cardsDataFormat";

const milesCards = getActiveCards().filter(
  (c) => c.categories.includes("travel") || c.categories.includes("co-brand"),
);
const rows = await Promise.all(
  milesCards.map(async (c) => {
    const bank = await getEntry("banks", c.bank);
    const fee = annualFeeLabel(c);
    return {
      cardName: c.name,
      bankName: bank?.data.name ?? c.bank,
      href: `/cards/${c.slug}/`,
      values: [
        fee.qual ? `${fee.amount} (${fee.qual})` : fee.amount,
        c._provenance?.fxFee === "needs-review" ? "—" : `${c.fxFee}%`,
        `${formatEarnValue(c.earnRates.everythingElse ?? 0, c.earnUnit, c.categories)}${c.earnUnit && c.earnUnit.toLowerCase().includes("per") ? " per AED" : ""}`,
        welcomeBonusHeadline(c.welcomeBonus) || "—",
      ],
    };
  }),
);
---

<ComparisonTableLayout
  title={`Best UAE miles credit cards (${new Date().toLocaleDateString("en-GB", { month: "long", year: "numeric" })}) | DubaiPoints`}
  heading={`Best UAE miles credit cards (${new Date().toLocaleDateString("en-GB", { month: "long", year: "numeric" })})`}
  description="Side-by-side comparison of UAE credit cards earning Skywards Miles, Etihad Guest Miles, and convertible TouchPoints / ENBD Plus / Mashreq Salaam."
  columns={["Annual fee", "FX fee", "Base earn", "Welcome bonus"]}
  rows={rows}
/>
