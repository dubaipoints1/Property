---
import ComparisonTableLayout from "~/layouts/ComparisonTableLayout.astro";
import { getEntry } from "astro:content";
import { getAllCards } from "~/lib/cardsData";

const milesCards = getAllCards().filter(
  (c) => c.categories.includes("travel") || c.categories.includes("co-brand"),
);
const rows = await Promise.all(
  milesCards.map(async (c) => {
    const bank = await getEntry("banks", c.bank);
    return {
      cardName: c.name,
      bankName: bank?.data.name ?? c.bank,
      href: `/cards/${c.slug}/`,
      values: [
        `AED ${c.annualFee.amount.toLocaleString()}`,
        `${c.fxFee}%`,
        `${c.earnRates.everythingElse}× per AED`,
        c.welcomeBonus ?? "—",
      ],
    };
  }),
);
---

<ComparisonTableLayout
  title="Best UAE miles credit cards"
  description="Side-by-side comparison of UAE credit cards earning Skywards Miles, Etihad Guest Miles, and convertible TouchPoints / ENBD Plus / Mashreq Salaam."
  columns={["Annual fee", "FX fee", "Base earn", "Welcome bonus"]}
  rows={rows}
/>
