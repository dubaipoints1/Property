---
import ComparisonTableLayout from "~/layouts/ComparisonTableLayout.astro";
import { getEntry } from "astro:content";
import {
  getActiveCards,
  welcomeBonusHeadline,
  annualFeeLabel,
} from "~/lib/cardsData";

const cashbackCards = getActiveCards().filter((c) =>
  c.categories.includes("cashback"),
);
const rows = await Promise.all(
  cashbackCards.map(async (c) => {
    const bank = await getEntry("banks", c.bank);
    const fee = annualFeeLabel(c);
    return {
      cardName: c.name,
      bankName: bank?.data.name ?? c.bank,
      href: `/cards/${c.slug}/`,
      values: [
        fee.qual ? `${fee.amount} (${fee.qual})` : fee.amount,
        c._provenance?.fxFee === "needs-review" ? "—" : `${c.fxFee}%`,
        c._provenance?.eligibility === "needs-review"
          ? "—"
          : `AED ${c.eligibility.minSalary.toLocaleString()}/mo`,
        welcomeBonusHeadline(c.welcomeBonus) || "—",
      ],
    };
  }),
);
---

<ComparisonTableLayout
  title="Best UAE cashback credit cards"
  description="Side-by-side comparison of the cashback-earning UAE credit cards we cover. Annual fee, FX fee, minimum salary, and current welcome bonus."
  columns={["Annual fee", "FX fee", "Min salary", "Welcome bonus"]}
  rows={rows}
/>
