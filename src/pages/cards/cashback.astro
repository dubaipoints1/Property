---
import ComparisonTableLayout from "~/layouts/ComparisonTableLayout.astro";
import { getCollection, getEntry } from "astro:content";

const cards = await getCollection("cards", (c) => c.data.categories.includes("cashback"));
const rows = await Promise.all(
  cards.map(async (c) => {
    const bank = await getEntry(c.data.bank);
    return {
      cardName: c.data.name,
      bankName: bank?.data.name ?? c.data.bank.id,
      href: `/cards/${c.id}/`,
      values: [
        `AED ${c.data.annualFee.amount.toLocaleString()}`,
        `${c.data.fxFee}%`,
        `AED ${c.data.eligibility.minSalary.toLocaleString()}/mo`,
        c.data.welcomeBonus ?? "—",
      ],
    };
  }),
);
---

<ComparisonTableLayout
  title="Best UAE cashback credit cards"
  description="Side-by-side comparison of the cashback-earning UAE credit cards we cover. Annual fee, FX fee, minimum salary, and current welcome bonus."
  columns={["Annual fee", "FX fee", "Min salary", "Welcome bonus"]}
  rows={rows}
>
  <p class="mt-6 text-sm text-slate-600">
    Phase 4 will populate this page with 12 reviewed cashback cards. Phase 1.5
    only seeds the comparison framework.
  </p>
</ComparisonTableLayout>
