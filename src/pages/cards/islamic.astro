---
import ComparisonTableLayout from "~/layouts/ComparisonTableLayout.astro";
import { getEntry } from "astro:content";
import { getAllCards, welcomeBonusDisplay } from "~/lib/cardsData";

const islamicCards = getAllCards().filter((c) => c.categories.includes("Islamic"));
const rows = await Promise.all(
  islamicCards.map(async (c) => {
    const bank = await getEntry("banks", c.bank);
    return {
      cardName: c.name,
      bankName: bank?.data.name ?? c.bank,
      href: `/cards/${c.slug}/`,
      values: [
        `AED ${c.annualFee.amount.toLocaleString()}`,
        `${c.fxFee}%`,
        `AED ${c.eligibility.minSalary.toLocaleString()}/mo`,
        welcomeBonusDisplay(c.welcomeBonus) || "—",
      ],
    };
  }),
);
---

<ComparisonTableLayout
  title="Sharia-compliant UAE credit cards"
  description="UAE Islamic credit cards from Emirates Islamic, ADIB, DIB and others. No interest (riba) charged; profit-rate or fee-based structure."
  columns={["Annual fee", "FX fee", "Min salary", "Welcome bonus"]}
  rows={rows}
/>
