---
// Card compare — Phase F picker (2026-05-20).
// Accepts ?cards=slug1,slug2,slug3,slug4 (max 4). With no param, the
// page falls back to the static top-3-by-welcome-bonus default that
// shipped in Phase C (and preserves that as the no-params view).
//
// The picker is a <details> + GET form — no client-side JS required.
// The URL the form posts to is the comparison itself, which makes
// the comparison shareable.
//
// All side-by-side surfaces use the new src/components/cards/* set
// (FeeBlock, EarnRateTable, EligibilityChips, WelcomeBonusCallout,
// VerifiedStamp) so the comparison renders the same data tokens the
// hubs and finder render.

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import { getActiveCards, welcomeBonusDisplay } from "~/lib/cardsData";
import {
  earnIsPercentage,
  formatEarnValue,
  topEarnEntry,
  CATEGORY_LABELS_FOR_TOP,
  compareByWelcomeValue,
} from "~/lib/cardsDataFormat";
import FeeBlock from "~/components/cards/FeeBlock.astro";
import EarnRateTable from "~/components/cards/EarnRateTable.astro";
import EligibilityChips from "~/components/cards/EligibilityChips.astro";
import WelcomeBonusCallout from "~/components/cards/WelcomeBonusCallout.astro";
import VerifiedStamp from "~/components/cards/VerifiedStamp.astro";

const MAX_CARDS = 4;

const allCards = getActiveCards();
const allBySlug = new Map(allCards.map((c) => [c.slug, c]));

// ── Read ?cards=... ─────────────────────────────────────────────────
const rawParam = Astro.url.searchParams.get("cards") ?? "";
const requestedSlugs = rawParam
  .split(",")
  .map((s) => s.trim())
  .filter((s) => s.length > 0)
  .filter((s) => allBySlug.has(s));

// De-dupe while preserving order, cap at MAX_CARDS.
const seen = new Set<string>();
const selectedSlugs: string[] = [];
for (const slug of requestedSlugs) {
  if (seen.has(slug)) continue;
  seen.add(slug);
  selectedSlugs.push(slug);
  if (selectedSlugs.length >= MAX_CARDS) break;
}

// Default — top-3 by AED-normalised welcome value when no ?cards= present.
const isDefault = selectedSlugs.length === 0;
const defaultSlugs = isDefault
  ? allCards
      .filter((c) => c.welcomeBonus)
      .sort(compareByWelcomeValue)
      .slice(0, 3)
      .map((c) => c.slug)
  : [];

const finalSlugs = isDefault ? defaultSlugs : selectedSlugs;

const cardsRaw = await Promise.all(
  finalSlugs
    .map((slug) => allBySlug.get(slug))
    .filter((c): c is NonNullable<typeof c> => Boolean(c))
    .map(async (card) => {
      const bank = await getEntry("banks", card.bank);
      return { card, bankName: bank?.data.name ?? card.bank };
    }),
);

// ── Picker data — all cards grouped by bank for the <details> form ──
const allByBank: Map<string, Array<typeof cardsRaw[number]>> = new Map();
for (const card of allCards) {
  const bank = await getEntry("banks", card.bank);
  const bankName = bank?.data.name ?? card.bank;
  if (!allByBank.has(bankName)) allByBank.set(bankName, []);
  allByBank.get(bankName)!.push({ card, bankName });
}
const bankGroups = [...allByBank.entries()].sort(([a], [b]) =>
  a.localeCompare(b),
);

const selectedSet = new Set(finalSlugs);

// Pick a representative earn-rate metric per card. Routes through the
// canonical `topEarnEntry` + `CATEGORY_LABELS_FOR_TOP` so this surface
// renders the same label AtAGlance, EarnRateTable.is-top and SpecCard
// use — closes the same regression class PR #204 fixed in SpecCard
// (local-CATEGORY_LABELS leak of raw L2 keys like "partnerBrands" /
// "online" / "utilities" / "everythingElse" to the reader).
const earnLine = (card: (typeof cardsRaw)[number]["card"]) => {
  const top = topEarnEntry(card.earnRates as Record<string, unknown>);
  const r = card.earnRates;
  const everythingElse = typeof r.everythingElse === "number" ? r.everythingElse : 0;
  const pct = earnIsPercentage(card.earnUnit, card.categories);
  const fmtRest = pct ? `${everythingElse}%` : `${everythingElse}× per AED 1`;
  if (!top || top.key === "everythingElse") {
    return pct ? `${everythingElse}% all spend` : fmtRest;
  }
  const topLabel = CATEGORY_LABELS_FOR_TOP[top.key] ?? top.key;
  const topFmt = formatEarnValue(top.value, card.earnUnit, card.categories);
  const restFmt = formatEarnValue(everythingElse, card.earnUnit, card.categories);
  return `${topFmt} ${topLabel.toLowerCase()}, ${restFmt} rest`;
};
---

<BaseLayout
  title="Compare UAE credit cards side-by-side | DubaiPoints"
  description="Pick up to four UAE credit cards and compare them side by side across eligibility, earn rates, welcome bonuses, and verified-on date."
  fullWidth
>
  <div class="dp-pagehead">
    <div class="crumb">DubaiPoints / Cards / Compare</div>
    <h1>Compare cards</h1>
    <p>
      Side-by-side spec comparison. Pick up to four cards to compare; with no
      selection we default to the three highest welcome-bonus cards we cover.
      The URL is shareable.
    </p>

    <div class="dp-tools-stats">
      <span>
        <span class="lbl">Cards covered:</span>
        <strong>{allCards.length}</strong>
      </span>
      <span>
        <span class="lbl">Showing:</span>
        <strong>
          {cardsRaw.length} {isDefault ? "top welcome-bonus cards" : "selected"}
        </strong>
      </span>
      <span>
        <span class="lbl">Methodology:</span>
        <strong>
          <a href="/editorial-policy/" style="color: var(--link);">Read →</a>
        </strong>
      </span>
    </div>
  </div>

  <!-- ── Picker ───────────────────────────────────────────────────── -->
  <section class="dp-compare-picker">
    <details>
      <summary>
        <span class="dp-compare-picker-title">Pick cards to compare</span>
        <span class="dp-compare-picker-hint">
          Up to {MAX_CARDS} cards · grouped by bank
        </span>
      </summary>
      <form method="get" action="/cards/compare/" class="dp-compare-picker-form">
        <fieldset>
          <legend class="sr-only">Select up to {MAX_CARDS} cards</legend>
          {bankGroups.map(([bankName, items]) => (
            <div class="dp-compare-picker-group">
              <h3>{bankName}</h3>
              <ul>
                {items.map(({ card }) => (
                  <li>
                    <label>
                      <input
                        type="checkbox"
                        name="cards"
                        value={card.slug}
                        checked={selectedSet.has(card.slug)}
                      />
                      <span>{card.name}</span>
                    </label>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </fieldset>
        <div class="dp-compare-picker-actions">
          <button type="submit">Update comparison</button>
          <a href="/cards/compare/" class="reset">Reset to defaults</a>
          <span class="caveat">
            We'll keep the first {MAX_CARDS} you tick.
          </span>
        </div>
      </form>
    </details>
  </section>

  {cardsRaw.length === 0 ? (
    <div
      style="padding: 64px 32px; text-align: center; color: var(--ink-soft);"
    >
      <p style="font-size: 16px;">
        None of the requested cards are in our database.
      </p>
      <p style="font-size: 14px; margin-top: 8px;">
        <a href="/cards/compare/" style="color: var(--link);">
          Reset to defaults →
        </a>
      </p>
    </div>
  ) : (
    <section class="dp-compare-grid" aria-label="Card comparison">
      {cardsRaw.map(({ card, bankName }) => {
        const wbDisplay = card.welcomeBonus
          ? welcomeBonusDisplay(card.welcomeBonus)
          : "";
        const showWelcome =
          card.welcomeBonus !== undefined &&
          card.welcomeBonus !== null &&
          wbDisplay.length > 0;
        return (
          <article class="dp-compare-col" data-bank={card.bank}>
            <header class="dp-compare-col-head">
              <span class="bank">{bankName}</span>
              <h2>
                <a href={`/cards/${card.slug}/`}>{card.name}</a>
              </h2>
              <span class="network">{card.network}</span>
            </header>

            <div class="dp-compare-col-section">
              <h4>Annual fee</h4>
              <FeeBlock
                annualFee={card.annualFee}
                fxFee={card.fxFee}
                waiver={card.annualFeeWaiver}
                joiningFee={card.joiningFee}
              />
            </div>

            <div class="dp-compare-col-section">
              <h4>Top category</h4>
              <p class="line">{earnLine(card)}</p>
            </div>

            <div class="dp-compare-col-section">
              <h4>Earn rates</h4>
              <EarnRateTable
                earnRates={card.earnRates}
                earnUnit={card.earnUnit}
              />
            </div>

            {showWelcome && card.welcomeBonus && (
              <div class="dp-compare-col-section">
                <h4>Welcome offer</h4>
                <WelcomeBonusCallout
                  welcomeBonus={card.welcomeBonus}
                  welcomeBonusDisplay={wbDisplay}
                />
              </div>
            )}

            <div class="dp-compare-col-section">
              <h4>Eligibility</h4>
              <EligibilityChips eligibility={card.eligibility} />
            </div>

            <div class="dp-compare-col-section">
              <h4>Loyalty programme</h4>
              <p class="line">{card.loyaltyProgram ?? "—"}</p>
            </div>

            <footer class="dp-compare-col-foot">
              <VerifiedStamp lastVerified={card.lastVerified} />
              <a href={`/cards/${card.slug}/`} class="cta">
                Read review →
              </a>
            </footer>
          </article>
        );
      })}
    </section>
  )}

  <div class="dp-tools-actions" style="margin-top: 32px;">
    <span style="font-size: 13px; color: var(--ink-soft);">
      Up to <strong>{MAX_CARDS}</strong> cards per comparison. Data is
      audited quarterly; each card's last-verified date sits in its footer.
    </span>
    <span><a href="/cards/">All cards →</a></span>
  </div>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Picker ───────────────────────────────────────────────────── */
  .dp-compare-picker {
    max-width: var(--container-listing);
    margin: 24px auto 0;
    padding: 0 32px;
  }
  .dp-compare-picker details {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    overflow: hidden;
  }
  .dp-compare-picker summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 24px;
    cursor: pointer;
    list-style: none;
  }
  .dp-compare-picker summary::-webkit-details-marker {
    display: none;
  }
  .dp-compare-picker summary::after {
    content: "▾";
    color: var(--ink-soft);
    font-size: 12px;
    transition: transform 0.18s ease;
  }
  .dp-compare-picker details[open] summary::after {
    transform: rotate(180deg);
  }
  .dp-compare-picker-title {
    font-family: "Fraunces", serif;
    font-weight: 500;
    font-size: 18px;
    color: var(--ink);
  }
  .dp-compare-picker-hint {
    font-size: 12px;
    color: var(--ink-soft);
    margin-left: auto;
  }
  .dp-compare-picker-form {
    padding: 16px 24px 24px;
    border-top: 1px solid var(--line);
  }
  .dp-compare-picker-form fieldset {
    border: 0;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 24px;
  }
  .dp-compare-picker-group h3 {
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green);
    margin: 0 0 8px;
  }
  .dp-compare-picker-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 4px;
  }
  .dp-compare-picker-group label {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    line-height: 1.4;
    color: var(--ink);
    cursor: pointer;
    padding: 4px 0;
  }
  .dp-compare-picker-group input {
    accent-color: var(--ink);
    margin-top: 3px;
    flex-shrink: 0;
  }
  .dp-compare-picker-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 24px;
    padding-top: 16px;
    border-top: 1px solid var(--line-soft);
  }
  .dp-compare-picker-actions button {
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.3px;
    padding: 10px 20px;
    background: var(--ink);
    color: var(--paper);
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .dp-compare-picker-actions button:hover {
    background: var(--green);
  }
  .dp-compare-picker-actions .reset {
    font-size: 12px;
    font-weight: 600;
    color: var(--ink-soft);
    border-bottom: 1px solid currentColor;
    padding-bottom: 1px;
  }
  .dp-compare-picker-actions .reset:hover {
    color: var(--green);
  }
  .dp-compare-picker-actions .caveat {
    font-size: 12px;
    color: var(--muted);
    margin-left: auto;
  }

  /* ── Comparison grid ──────────────────────────────────────────── */
  .dp-compare-grid {
    max-width: var(--container-listing);
    margin: 24px auto 0;
    padding: 0 32px;
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    align-items: start;
  }
  .dp-compare-col {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 20px;
    display: grid;
    gap: 16px;
    font-family: "DM Sans", system-ui, sans-serif;
  }
  .dp-compare-col-head {
    display: grid;
    gap: 4px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line-soft);
  }
  .dp-compare-col-head .bank {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green);
  }
  .dp-compare-col-head h2 {
    margin: 0;
    font-family: "Fraunces", serif;
    font-weight: 500;
    font-size: 20px;
    letter-spacing: -0.3px;
    line-height: 1.2;
    color: var(--ink);
    text-wrap: balance;
  }
  .dp-compare-col-head h2 a {
    color: inherit;
  }
  .dp-compare-col-head h2 a:hover {
    color: var(--green);
  }
  .dp-compare-col-head .network {
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: 0.3px;
    margin-top: 4px;
  }
  .dp-compare-col-section h4 {
    margin: 0 0 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--muted);
  }
  .dp-compare-col-section .line {
    margin: 0;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.4;
  }
  .dp-compare-col-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 4px;
    padding-top: 16px;
    border-top: 1px solid var(--line-soft);
  }
  .dp-compare-col-foot .cta {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.3px;
    color: var(--ink);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: color 0.15s ease;
  }
  .dp-compare-col-foot .cta:hover {
    color: var(--green);
  }

  @media (max-width: 720px) {
    .dp-compare-picker,
    .dp-compare-grid {
      padding-inline: 20px;
    }
    .dp-compare-picker summary {
      padding: 14px 16px;
      flex-wrap: wrap;
    }
    .dp-compare-picker-hint {
      width: 100%;
      margin-left: 0;
    }
    .dp-compare-picker-form {
      padding: 16px;
    }
    .dp-compare-picker-actions .caveat {
      margin-left: 0;
      width: 100%;
    }
    .dp-compare-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
