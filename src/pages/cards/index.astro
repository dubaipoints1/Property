---
import BaseLayout from "~/layouts/BaseLayout.astro";
import BankLogo from "~/components/BankLogo.astro";
import { getCollection, getEntry } from "astro:content";

const cards = await getCollection("cards");
const cardsWithBanks = await Promise.all(
  cards.map(async (c) => {
    const bank = await getEntry(c.data.bank);
    return { card: c, bankName: bank?.data.name ?? c.data.bank.id };
  }),
);
cardsWithBanks.sort((a, b) =>
  a.card.data.eligibility.minSalary - b.card.data.eligibility.minSalary,
);

const categories = [
  { slug: "cashback", label: "Cashback" },
  { slug: "miles", label: "Miles" },
  { slug: "islamic", label: "Islamic" },
];
---

<BaseLayout
  title="UAE credit cards — directory"
  description="Every UAE credit card we cover, sorted by minimum monthly salary. Browse the directory or jump into a category."
  fullWidth
>
  <article class="dp-article is-wide">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">Cards</p>
      <h1 class="dp-article-title">UAE credit cards.</h1>
      <p class="dp-article-lede">Every card we cover, sorted by minimum monthly salary — the first eligibility filter that matters in the UAE. Click a card for the full review and verdict.</p>

      <div class="dp-dir-pills">
        <a href="/cards/compare/" class="dp-dir-pill is-feature">Compare side-by-side →</a>
        {categories.map((c) => (
          <a href={`/cards/${c.slug}/`} class="dp-dir-pill">{c.label}</a>
        ))}
      </div>
    </header>

    <div class="dp-dir-grid">
      {cardsWithBanks.map(({ card, bankName }) => (
        <a href={`/cards/${card.id}/`} class="dp-dir-tile">
          <span class="eyebrow">
            <BankLogo slug={card.data.bank.id} name={bankName} size="sm" />
            <span>{bankName} · {card.data.network}</span>
          </span>
          <span class="title">{card.data.name}</span>
          <span class="desc">{card.data.welcomeBonus ?? "Annual fee waiver: " + (card.data.annualFeeWaiver ?? "see review")}</span>
          <span class="meta">
            AED {card.data.annualFee.amount.toLocaleString()}/yr ·
            {" "}AED {card.data.eligibility.minSalary.toLocaleString()}/mo min
          </span>
        </a>
      ))}
    </div>
  </article>
</BaseLayout>
