---
// Homepage — design-handoff idiom (Phase H1, Claude Design handoff bundle).
// Structure mirrors the section-index template (B1) plus a richer hero and
// a card-spotlight band that reuses the per-issuer .dp-cr-mock from G2.
//
// Sections
//   1. Masthead hero (eyebrow / date / h1 / strap / meta strip)
//   2. Featured band (1 hero + 2 medium + 4 small) — newest guides + deals
//   3. Pull-quote (editorial standard)
//   4. Latest feed (8 mixed-type items, numbered)
//   5. Favourite cards spotlight (per-issuer card-art tiles)
//   6. Newsletter band (green CTA)

import BaseLayout from "~/layouts/BaseLayout.astro";
import Cover from "~/components/Cover.astro";
import StockImage from "~/components/StockImage.astro";
import { getCollection } from "astro:content";
import { getAllCards } from "~/lib/cardsData";
import { getLiveOffers } from "~/lib/offerAdapter";

const todayMs = Date.now();

const fmtShort = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short" });

// ── Source collections ───────────────────────────────────────────────────
const allGuides = await getCollection("guides");
const allDeals = await getCollection("deals");
const allPrograms = await getCollection("programs");
const cards = getAllCards();

// Master Your Miles tiles — surfaces the programs collection.
// Section grows as Travel-Experiences Editor adds /content/programs/*.mdx.
// Today: 1 programme (Skywards) + 3 grid slots gracefully empty + a
// trailing "Browse all" wayfinding tile to /airlines/.
const milesTiles = allPrograms
  .slice()
  .sort((a, b) => a.data.name.localeCompare(b.data.name))
  .slice(0, 3);

const liveDeals = allDeals
  .filter((d) => d.data.expiresOn.getTime() >= todayMs)
  .sort((a, b) => a.data.expiresOn.getTime() - b.data.expiresOn.getTime());

const guidesSorted = [...allGuides].sort(
  (a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime(),
);

const cardSpotlights = cards
  .filter((c) => c.welcomeBonus)
  .sort((a, b) => (b.welcomeBonusValue ?? 0) - (a.welcomeBonusValue ?? 0));

// ── Hero "Latest" strip — 3 content-driven rows replacing the nav tiles ───
const newestCard = [...cards].sort(
  (a, b) =>
    new Date(b.lastVerified).getTime() - new Date(a.lastVerified).getTime(),
)[0];
const liveOffers = await getLiveOffers();
const topGuide = guidesSorted[0];

// ── Featured band — top 7 mixed (1 hero + 2 med + 4 sm) ─────────────────
type Featured = {
  href: string; cat: string; title: string; deck?: string; date: Date;
};
const featuredPool: Featured[] = [
  ...guidesSorted.map((g) => ({
    href: `/guides/${g.id}/`,
    cat: "Guide",
    title: g.data.title,
    deck: g.data.description,
    date: g.data.updatedAt,
  })),
  ...liveDeals.map((d) => ({
    href: `/deals/${d.id}/`,
    cat: "Deal",
    title: d.data.title,
    deck: `${d.data.category} · ends ${fmtShort(d.data.expiresOn)}`,
    date: d.data.expiresOn,
  })),
  ...cardSpotlights.slice(0, 4).map((c) => ({
    href: `/cards/${c.slug}/`,
    cat: "Review",
    title: c.name,
    deck: `${c.bank} · annual fee AED ${c.annualFee.toLocaleString()}`,
    date: c.lastVerified,
  })),
];
const featured = featuredPool
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 7);

// ── Latest feed (8 mixed items, numbered) ────────────────────────────────
const latest = featuredPool
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 8);

// ── Favourite cards (top 6 by welcome-bonus value) ──────────────────────
const favouriteCards = cardSpotlights.slice(0, 6);

// ── Filter pill destinations ────────────────────────────────────────────
const filters = [
  { label: "All cards",  href: "/cards/" },
  { label: "Cashback",   href: "/cards/cashback/" },
  { label: "Miles",      href: "/cards/miles/" },
  { label: "Islamic",    href: "/cards/islamic/" },
  { label: "Compare",    href: "/cards/compare/" },
];
---

<BaseLayout
  title="DubaiPoints — UAE Miles, Deals & Banking Hacks"
  description="Independent UAE-resident-led guides to credit cards, salary-transfer bonuses, miles redemptions and lifestyle deals. Every figure in AED, every card checked."
  fullWidth
>
  <!-- ── 1. Masthead hero ─────────────────────────────────────────────── -->
  <!--
    Image-forward hero (Phase B.1, May 2026 redesign).
    Left column: kicker / headline / subhead / single Latest-link.
    Right column: <StockImage> with overlay sweet-spot chip linking to
    the top guide. Image falls back to Cover.astro SVG until the
    matching manifest entry lands (Phase E.2).
  -->
  <header class="dp-pagehead is-hero">
    <div class="hp-hero-grid">
      <div class="hp-hero-text">
        <span class="kicker">Dubai · Independent · Reader-funded</span>
        <h1>UAE rewards, <em>decoded</em>.</h1>
        <p>
          Independent UAE analysis of credit cards, salary transfer,
          miles and deals — every figure in dirhams, dated and verified.
        </p>
        {newestCard && (
          <a href={`/cards/${newestCard.slug}/`} class="hp-hero-cta">
            Read the latest review · {newestCard.name} →
          </a>
        )}
      </div>

      <div class="hp-hero-media">
        <StockImage
          slug="homepage-hero-cabin"
          coverTitle="UAE rewards, decoded."
          coverCategory="Editorial"
          coverSize="hero"
          class="hp-hero-image"
          loading="eager"
          sizes="(max-width: 900px) 100vw, 50vw"
        />
        {topGuide && (
          <a href={`/guides/${topGuide.id}/`} class="hp-hero-chip">
            <span class="hp-hero-chip-eyebrow">Sweet spot</span>
            <span class="hp-hero-chip-title">{topGuide.data.title}</span>
            <span class="hp-hero-chip-meta">Updated {fmtShort(topGuide.data.updatedAt)} ›</span>
          </a>
        )}
      </div>
    </div>
  </header>

  <!-- "Latest" strip — 3 content-driven entry points (replaces nav tiles).
       Moved out of the hero in Phase B.1 to give the image-forward hero
       room to breathe. Still sits above the fold on most viewports. -->
  <div class="hero-latest-wrap">
    <div class="hero-latest">
      {newestCard && (
        <a href={`/cards/${newestCard.slug}/`} class="hero-latest-row">
          <span class="cat">Latest review</span>
          <span class="t">{newestCard.name}</span>
          <span class="m">verified {fmtShort(new Date(newestCard.lastVerified))}</span>
        </a>
      )}

      <a href="/salary-transfer/" class="hero-latest-row is-live">
        <span class="cat"><span class="dot" aria-hidden="true"></span>Live tracker</span>
        <span class="t">
          {liveOffers.length === 0
            ? "Salary-transfer offers"
            : `${liveOffers.length} salary-transfer offer${liveOffers.length === 1 ? "" : "s"} live`}
        </span>
        <span class="m">refreshed daily</span>
      </a>

      {topGuide && (
        <a href={`/guides/${topGuide.id}/`} class="hero-latest-row">
          <span class="cat">Top guide</span>
          <span class="t">{topGuide.data.title}</span>
          <span class="m">updated {fmtShort(topGuide.data.updatedAt)}</span>
        </a>
      )}
    </div>
  </div>

  <!-- Decorative section divider between hero and featured band -->
  <div class="dp-section-divider" aria-hidden="true">
    <span class="rule"></span>
    <span class="dot"></span>
    <span class="rule"></span>
  </div>

  <!-- ── 2. Featured band ─────────────────────────────────────────────── -->
  {featured.length > 0 && (
    <section class="dp-featured-band">
      <div class="dp-featured-eyebrow">
        <span>Featured this week</span>
        <span class="rule"></span>
        <span class="meta">Curated by editors · refreshed Mondays</span>
      </div>
      <div class="dp-featured-grid">
        {featured[0] && (
          <a href={featured[0].href} class="dp-story-card hero">
            <Cover title={featured[0].title} category={featured[0].cat} size="hero" />
            <div class="body">
              <div class="meta"><span class="cat">{featured[0].cat}</span><span>{fmtShort(featured[0].date)}</span></div>
              <h3>{featured[0].title}</h3>
              {featured[0].deck && <p>{featured[0].deck}</p>}
              <div class="by">By DubaiPoints Editorial</div>
            </div>
          </a>
        )}
        {featured.slice(1, 3).map((f) => (
          <a href={f.href} class="dp-story-card med">
            <Cover title={f.title} category={f.cat} size="med" />
            <div class="body">
              <div class="meta"><span class="cat">{f.cat}</span><span>{fmtShort(f.date)}</span></div>
              <h3>{f.title}</h3>
              {f.deck && <p>{f.deck}</p>}
            </div>
          </a>
        ))}
        {featured.slice(3, 7).map((f) => (
          <a href={f.href} class="dp-story-card sm">
            <Cover title={f.title} category={f.cat} size="sm" />
            <div class="body">
              <div class="meta"><span class="cat">{f.cat}</span><span>{fmtShort(f.date)}</span></div>
              <h3>{f.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── 3. Pull-quote ────────────────────────────────────────────────── -->
  <div class="dp-pullquote">
    <div class="mark">"</div>
    <blockquote>
      Independent UAE rewards reporting. Every verdict dated, every figure in dirhams, every recommendation held to the same standard whether the bank is an advertiser or not.
    </blockquote>
    <div class="attr"><span class="rule"></span>Editorial standard · est. 2026</div>
  </div>

  <!-- ── 4. Latest feed ───────────────────────────────────────────────── -->
  <div class="dp-list-head">
    <div class="t">The latest</div>
    <div class="m">Newest stories across guides, reviews and deals · refreshed daily</div>
  </div>
  <div class="dp-feed">
    {latest.map((f, i) => (
      <a href={f.href} class="dp-feed-row">
        <div>
          <div class="num">{String(i + 1).padStart(2, "0")}</div>
          <div class="feed-eyebrow">{f.cat}</div>
        </div>
        <div>
          <h3>{f.title}</h3>
          {f.deck && <div class="summary">{f.deck}</div>}
        </div>
        <Cover category={f.cat} size="thumb" />
        <div class="when">{fmtShort(f.date)}</div>
      </a>
    ))}
  </div>

  <div class="dp-page-nav">
    <a href="/news/" class="more-link">More stories →</a>
  </div>

  <!-- ── 5. Favourite cards spotlight ─────────────────────────────────── -->
  <section class="hp-cards-band">
    <div class="hp-cards-head">
      <div class="dp-featured-eyebrow">
        <span>Cards to consider this month</span>
        <span class="rule"></span>
        <span class="meta">Verified against issuer T&Cs</span>
      </div>
      <h2>Favourite cards.</h2>
      <p>Reviewed against UAE eligibility, not US norms. Every card checked against the issuer's published Schedule of Charges.</p>
      <div class="hp-cards-pills">
        {filters.map((p) => (
          <a href={p.href} class="dp-filter-pill">{p.label}</a>
        ))}
      </div>
    </div>

    <div class="hp-cards-grid">
      {favouriteCards.map((c) => (
        <a href={`/cards/${c.slug}/`} class="hp-card-cell">
          <div class="dp-cr-mock" data-bank={c.bank} aria-hidden="true">
            <div class="dp-cr-mock-chip"></div>
            <div class="dp-cr-mock-row">
              <div class="b">{c.bank}</div>
              <div class="dp-cr-mock-mark">{c.network.slice(0, 1)}</div>
            </div>
            <div class="n">{c.name}</div>
            <div class="b">{c.network}</div>
          </div>
          <div class="hp-card-meta">
            <span class="eyebrow">Review</span>
            <span class="title">{c.name}</span>
            <span class="specs">
              AED {c.annualFee.toLocaleString()}/yr ·
              AED {(c.eligibility?.minSalary ?? 0).toLocaleString()}/mo min
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="dp-page-nav">
      <a href="/cards/" class="more-link">All reviewed cards →</a>
    </div>
  </section>

  <!-- ── 6. Master Your Miles ─────────────────────────────────────────── -->
  <!--
    Master Your Miles — Phase B.2 of the May 2026 image-forward redesign.
    Surfaces the `programs` content collection on the homepage. Today the
    collection has one entry (Skywards); section grows as Travel-Experiences
    Editor adds /content/programs/*.mdx files. Stops at 3 programme tiles +
    1 "Browse all" wayfinding tile to keep the grid consistent at 4 columns.
  -->
  <section class="hp-miles-band">
    <div class="hp-miles-head">
      <div class="dp-featured-eyebrow">
        <span>Master your miles</span>
        <span class="rule"></span>
        <span class="meta">UAE-relevant loyalty programmes</span>
      </div>
      <h2>Where the dirhams turn into miles.</h2>
      <p>Programme-by-programme: tiers, sweet spots, transfer partners and expiry policy — the bits that decide whether your balance is worth what you think it is.</p>
    </div>

    <div class="hp-miles-grid">
      {milesTiles.map((p) => (
        <a href={`/airlines/${p.id}/`} class="hp-miles-tile">
          <div class="hp-miles-tile-head">
            <span class="eyebrow">{p.data.region}</span>
            <span class="currency">{p.data.currencyName}</span>
          </div>
          <h3 class="hp-miles-tile-title">{p.data.name}</h3>
          {p.data.sweetSpots[0] && (
            <p class="hp-miles-tile-spot">
              <span class="hp-miles-tile-spot-label">Sweet spot</span>
              {p.data.sweetSpots[0].title}
            </p>
          )}
          <span class="hp-miles-tile-cta">Programme guide →</span>
        </a>
      ))}

      <a href="/airlines/" class="hp-miles-tile is-wayfinder">
        <div class="hp-miles-tile-head">
          <span class="eyebrow">Index</span>
          <span class="currency">All programmes</span>
        </div>
        <h3 class="hp-miles-tile-title">Browse every programme</h3>
        <p class="hp-miles-tile-spot">
          Skywards, Etihad Guest, Qatar Privilege Club, Marriott Bonvoy and the rest — A-Z.
        </p>
        <span class="hp-miles-tile-cta">All programmes →</span>
      </a>
    </div>
  </section>

  <!-- ── 7. Newsletter band ───────────────────────────────────────────── -->
  <section class="hp-news-band">
    <div class="inner">
      <span class="eyebrow">The DubaiPoints brief</span>
      <h2>Friday morning, in your inbox.</h2>
      <p>One email each Friday with the week's salary-transfer changes, new card offers, miles redemptions worth knowing about, and lifestyle deals. AED-first, no fluff.</p>
      <div class="cta">
        <a href="/newsletter/" class="btn primary">Subscribe</a>
        <a href="/rss.xml" class="btn ghost">RSS feeds</a>
      </div>
      <p class="micro">
        We never sell email addresses or browsing data. <a href="/editorial-policy/">Editorial policy</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* Homepage-specific glue. The design-handoff classes (.dp-pagehead,
     .dp-featured-band, .dp-feed, .dp-cr-mock, .dp-filter-pill) come from
     global.css. This file extends the hero and adds two homepage-only
     bands (cards spotlight + newsletter). */

  .dp-pagehead.is-hero {
    background: linear-gradient(to bottom, var(--shade-1) 0%, var(--paper) 100%);
    padding: 56px 32px 40px;
  }
  /* Two-column hero grid — text left, image right.
     Stacks on mobile (text first to preserve LCP). */
  .hp-hero-grid {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: 48px;
    align-items: center;
  }
  .hp-hero-text { text-align: left; }
  .dp-pagehead.is-hero .kicker {
    display: inline-block;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--green);
    margin-bottom: 18px;
  }
  .dp-pagehead.is-hero h1 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(34px, 5vw, 60px);
    line-height: 1.04;
    letter-spacing: -1.4px;
    color: var(--ink);
    text-wrap: balance;
    margin: 0 0 18px;
    max-width: 14ch;
  }
  .dp-pagehead.is-hero h1 em {
    font-style: italic;
    color: var(--green);
    font-weight: 500;
  }
  .dp-pagehead.is-hero p {
    max-width: 48ch;
    margin: 0 0 24px;
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    text-wrap: pretty;
  }
  .hp-hero-cta {
    display: inline-flex;
    align-items: center;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.2px;
    color: var(--green);
    border-bottom: 2px solid var(--green);
    padding-bottom: 4px;
    transition: opacity 0.15s ease;
  }
  .hp-hero-cta:hover { opacity: 0.75; }

  /* Image column — wraps StockImage so its <Cover> SVG fallback fills the slot.
     Chip is absolute-positioned bottom-left, mirroring the Replit handoff. */
  .hp-hero-media {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--shade-1);
    box-shadow: 0 18px 36px -18px rgba(15, 31, 46, 0.18);
  }
  .hp-hero-media :global(.hp-hero-image),
  .hp-hero-media :global(svg.dp-cover) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hp-hero-chip {
    position: absolute;
    left: 16px;
    bottom: 16px;
    right: 16px;
    max-width: 360px;
    background: var(--paper);
    border-radius: 12px;
    padding: 12px 14px 14px;
    display: grid;
    gap: 4px;
    box-shadow: 0 10px 28px -10px rgba(15, 31, 46, 0.25);
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .hp-hero-chip:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px -10px rgba(15, 31, 46, 0.3);
  }
  .hp-hero-chip-eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green);
  }
  .hp-hero-chip-title {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 15px;
    line-height: 1.3;
    letter-spacing: -0.2px;
    color: var(--ink);
    text-wrap: balance;
  }
  .hp-hero-chip-meta {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.3px;
  }

  /* "Latest" strip — 3 content-driven rows. Lives below the hero
     after Phase B.1 (was inside the hero pre-redesign). Reads as
     inbox-style entries rather than chrome. */
  .hero-latest-wrap {
    background: var(--paper);
    padding: 28px 32px 0;
  }
  .hero-latest {
    margin: 0 auto;
    max-width: 1100px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--paper);
    overflow: hidden;
    text-align: left;
  }
  .hero-latest-row {
    display: grid;
    grid-template-columns: 130px 1fr auto;
    gap: 16px;
    padding: 14px 18px;
    border-bottom: 1px solid var(--line-soft);
    text-decoration: none;
    transition: background 0.15s ease;
    align-items: center;
  }
  .hero-latest-row:last-child { border-bottom: 0; }
  .hero-latest-row:hover { background: var(--shade-1); }
  .hero-latest-row .cat {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .hero-latest-row.is-live .cat { color: var(--green); }
  .hero-latest-row.is-live .cat .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--green);
    animation: hp-pulse 2.4s ease-in-out infinite;
  }
  .hero-latest-row .t {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 15px;
    color: var(--ink);
    letter-spacing: -0.2px;
    line-height: 1.3;
    text-wrap: balance;
  }
  .hero-latest-row .m {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.3px;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  @keyframes hp-pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }
  @media (prefers-reduced-motion: reduce) {
    .hero-latest-row.is-live .cat .dot { animation: none; }
  }

  @media (max-width: 900px) {
    .hp-hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .dp-pagehead.is-hero h1 { max-width: 18ch; }
    .hp-hero-media { aspect-ratio: 16 / 10; }
  }
  @media (max-width: 768px) {
    .dp-pagehead.is-hero { padding: 40px 20px 28px; }
    .hp-hero-grid { gap: 24px; }
    .hero-latest-wrap { padding: 24px 20px 0; }
    .hp-hero-chip {
      left: 12px; right: 12px; bottom: 12px;
      max-width: none;
    }
    .hero-latest-row {
      grid-template-columns: 1fr auto;
      gap: 4px 12px;
      padding: 14px 16px;
    }
    .hero-latest-row .cat {
      grid-column: 1 / -1;
      margin-bottom: 2px;
    }
    .hero-latest-row .t { grid-column: 1 / 2; }
    .hero-latest-row .m { grid-column: 2 / 3; align-self: start; padding-top: 4px; }
  }

  /* Decorative section divider — Fraunces-flavoured ornament */
  .dp-section-divider {
    display: flex; align-items: center; justify-content: center;
    gap: 14px;
    max-width: 1180px;
    margin: 0 auto;
    padding: 32px 32px 0;
  }
  .dp-section-divider .rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--line) 40%, var(--line) 60%, transparent);
    max-width: 280px;
  }
  .dp-section-divider .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .dp-section-divider { padding: 24px 20px 0; gap: 10px; }
    .dp-section-divider .rule { max-width: 100px; }
