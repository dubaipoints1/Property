---
import HomepageLayout from "~/layouts/HomepageLayout.astro";
import SalaryTransferTracker from "~/components/islands/SalaryTransferTracker.tsx";
import { getLiveOffers } from "~/lib/offerAdapter";
import { getCollection } from "astro:content";

const offers = await getLiveOffers();
const guides = await getCollection("guides");
const cards = await getCollection("cards");
---

<HomepageLayout
  title="dubaipoints.ae — UAE salary transfer, cards and miles"
  description="Live salary transfer tracker, cashback card analysis, and regional Middle East airline programmes. AED throughout, UAE eligibility front and centre."
>
  <div slot="hero-tracker" class="mt-6">
    <SalaryTransferTracker offers={offers} client:load />
  </div>

  <div slot="hero-pinned" class="rounded-lg border border-slate-200 bg-white p-5">
    <p class="text-xs uppercase tracking-wide text-slate-500">Pinned</p>
    <h3 class="mt-1 text-lg font-semibold text-slate-900">
      <a href="/salary-transfer/calculator/">Try the salary transfer calculator</a>
    </h3>
    <p class="mt-2 text-sm text-slate-700">
      Enter your salary, card spend and product preferences. Every live offer is
      ranked in cash-equivalent AED terms.
    </p>
  </div>

  <div slot="latest" class="grid gap-4 sm:grid-cols-2">
    {
      guides.map((g) => (
        <a
          href={`/guides/${g.id}/`}
          class="rounded-lg border border-slate-200 bg-white p-4 no-underline hover:border-brand-500"
        >
          <h3 class="text-base font-semibold text-slate-900">{g.data.title}</h3>
          <p class="mt-1 text-sm text-slate-600">{g.data.description}</p>
        </a>
      ))
    }
  </div>

  <div slot="points" class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-5 text-sm text-slate-600">
    Points hacks pillar coming in Phase 4 — UAE transfer ratio chart, card
    stacking by category, Skywards Everyday at Dubai retailers, and more.
  </div>

  <div slot="cards" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      cards.map((c) => (
        <a
          href={`/cards/${c.id}/`}
          class="rounded-lg border border-slate-200 bg-white p-4 no-underline hover:border-brand-500"
        >
          <p class="text-xs uppercase tracking-wide text-slate-500">{c.data.network}</p>
          <h3 class="mt-1 text-base font-semibold text-slate-900">{c.data.name}</h3>
          <p class="mt-1 text-xs text-slate-600">
            Annual fee: AED {c.data.annualFee.amount.toLocaleString()}
          </p>
        </a>
      ))
    }
  </div>
</HomepageLayout>
