---
// Homepage — Phase F (May 2026 mockup-fidelity rebuild).
// Reference: Replit Canvas mockup, page 01 (Fly further / Pay less).
//
// Composition mirrors the mockup top-to-bottom:
//   1. Image-forward hero (text left + email signup + image right with SWEET-SPOT chip)
//   2. Stats band (4 live-truth numbers)
//   3. Fresh Intel (3 editorial cards: latest guides + newest card review)
//   4. UAE Wallet Setup (dark section + cards mockup + live "avg welcome bonus" stat)
//   5. Master Your Miles (Phase B.2 — reads `programs` collection)
//   6. Newsletter band (Phase H1 — kept)
//
// Dropped from prior layout (Chairman directive 2026-05-14 "I need it to look like that"):
//   - Hero "Latest" strip (3 inbox-style rows)
//   - Decorative section divider
//   - Featured band (1 hero + 2 med + 4 small story cards)
//   - Editorial pullquote
//   - Numbered Latest feed
//   - Favourite cards spotlight
//
// Photo slots: every <StockImage> resolves to its `guide-<id>` / `intel-*` /
// `wallet-hero-*` / `hero-cabin` slug at build. Until `npm run fetch:stock`
// populates `data/stock/manifest.json` with a matching entry, each slot
// renders the Cover.astro SVG fallback (per Phase E.1 design). The
// editorial layout is correct today; photos light up on first key-backed
// fetch.

import BaseLayout from "~/layouts/BaseLayout.astro";
import StockImage from "~/components/StockImage.astro";
import { getCollection } from "astro:content";
import { getAllCards } from "~/lib/cardsData";

const allGuides = await getCollection("guides");
const allPrograms = await getCollection("programs");
const allBanks = await getCollection("banks");
const cards = getAllCards();

const fmtShort = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short" });

// ── Hero sweet-spot chip — points at the top programme's first sweet-spot ──
const flagshipProgramme = allPrograms.find((p) => p.id === "skywards") ?? allPrograms[0];
const heroSweetSpot = flagshipProgramme?.data.sweetSpots[0];

// ── Stats band — verifiable live-truth metrics ───────────────────────────
// All four numbers source from data files at build; no fabrication.
const stats: { value: string; label: string }[] = [
  { value: `${cards.length}+`, label: "Cards reviewed" },
  { value: `${allBanks.length}`, label: "UAE banks tracked" },
  { value: "Daily", label: "Tracker refresh" },
  { value: "100%", label: "Independent" },
];

// ── Fresh Intel — top 3 mixed content (newest guides + newest card review) ─
const guidesSorted = [...allGuides].sort(
  (a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime(),
);
const newestCard = [...cards].sort(
  (a, b) =>
    new Date(b.lastVerified).getTime() - new Date(a.lastVerified).getTime(),
)[0];

type IntelItem = {
  href: string;
  category: string;
  title: string;
  excerpt: string;
  meta: string;
  imageSlug: string;
  coverCategory: "Guide" | "Review" | "Deal" | "News" | "Programme" | "Topic";
};

const intel: IntelItem[] = [];
if (guidesSorted[0]) {
  const g = guidesSorted[0];
  intel.push({
    href: `/guides/${g.id}/`,
    category: "Sweet Spots",
    title: g.data.title,
    excerpt: g.data.description,
    meta: `Updated ${fmtShort(g.data.updatedAt)}`,
    imageSlug: `guide-${g.id}`,
    coverCategory: "Guide",
  });
}
if (guidesSorted[1]) {
  const g = guidesSorted[1];
  intel.push({
    href: `/guides/${g.id}/`,
    category: "Banking",
    title: g.data.title,
    excerpt: g.data.description,
    meta: `Updated ${fmtShort(g.data.updatedAt)}`,
    imageSlug: `guide-${g.id}`,
    coverCategory: "Guide",
  });
}
if (newestCard) {
  intel.push({
    href: `/cards/${newestCard.slug}/`,
    category: "Card Review",
    title: newestCard.name,
    excerpt: `${newestCard.bank} · annual fee AED ${newestCard.annualFee.toLocaleString()}`,
    meta: `Verified ${fmtShort(new Date(newestCard.lastVerified))}`,
    imageSlug: `card-${newestCard.slug}`,
    coverCategory: "Review",
  });
}

// ── UAE Wallet Setup — live average welcome bonus across reviewed cards ───
const welcomeBonusValues = cards
  .map((c) => c.welcomeBonusValue ?? 0)
  .filter((v) => v > 0);
const avgWelcomeBonusK =
  welcomeBonusValues.length > 0
    ? Math.round(
        welcomeBonusValues.reduce((a, b) => a + b, 0) /
          welcomeBonusValues.length /
          1000,
      )
    : 0;

// ── Master Your Miles tiles ─────────────────────────────────────────────
// Order: Skywards (UAE flag carrier) first, then alpha by name. Pages
// past the 4th tile fall off — the section is a curated showcase, not
// the full /airlines/ index. The "Browse all programmes" link below
// the grid covers discovery for the tail.
const milesTiles = allPrograms
  .slice()
  .sort((a, b) => {
    if (a.id === "skywards") return -1;
    if (b.id === "skywards") return 1;
    return a.data.name.localeCompare(b.data.name);
  })
  .slice(0, 4);
---

<BaseLayout
  title="DubaiPoints — UAE Miles, Deals & Banking Hacks"
  description="Independent UAE-resident-led guides to credit cards, salary-transfer bonuses, miles redemptions and lifestyle deals. Every figure in AED, every card checked."
  fullWidth
>
  <!-- ── 1. Hero ──────────────────────────────────────────────────────── -->
  <header class="dp-pagehead is-hero">
    <div class="hp-hero-grid">
      <div class="hp-hero-text">
        <span class="kicker">The UAE's points &amp; miles publication</span>
        <h1>Fly further.<br /><em>Pay less.</em></h1>
        <p>
          The exact strategies, card combos, and points redemptions you need
          to travel the world from Dubai in business class for the price of
          economy — every figure in dirhams, dated and verified.
        </p>
        <form class="hp-hero-form" action="/newsletter/" method="get">
          <label class="hp-hero-form-label" for="hp-hero-email">Email</label>
          <input
            id="hp-hero-email"
            type="email"
            name="email"
            placeholder="Enter your email"
            autocomplete="email"
            required
          />
          <button type="submit">Join the brief →</button>
        </form>
        <p class="hp-hero-micro">No spam. Just high-value hacks. Unsubscribe anytime.</p>
      </div>

      <div class="hp-hero-media">
        <StockImage
          slug="hero-cabin"
          coverTitle="UAE rewards, decoded."
          coverCategory="Editorial"
          coverSize="hero"
          class="hp-hero-image"
          loading="eager"
          sizes="(max-width: 900px) 100vw, 50vw"
        />
        {heroSweetSpot && flagshipProgramme && (
          <a href={`/airlines/${flagshipProgramme.id}/`} class="hp-hero-chip">
            <span class="hp-hero-chip-eyebrow">Sweet spot</span>
            <span class="hp-hero-chip-title">{heroSweetSpot.title}</span>
            <span class="hp-hero-chip-meta">{flagshipProgramme.data.currencyName} ›</span>
          </a>
        )}
      </div>
    </div>
  </header>

  <!-- ── 2. Stats band ───────────────────────────────────────────────── -->
  <section class="hp-stats-band" aria-label="Site at a glance">
    <div class="hp-stats-grid">
      {stats.map((s) => (
        <div class="hp-stat">
          <span class="hp-stat-value">{s.value}</span>
          <span class="hp-stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ── 3. Fresh Intel ──────────────────────────────────────────────── -->
  <section class="hp-intel-band">
    <div class="hp-intel-head">
      <h2>Fresh Intel</h2>
      <p>Latest reviews, sweet spots and banking moves — every claim verified against the issuer's Schedule of Charges.</p>
      <a href="/guides/" class="hp-intel-more">All intel →</a>
    </div>
    <div class="hp-intel-grid">
      {intel.map((item) => (
        <a href={item.href} class="hp-intel-card">
          <StockImage
            slug={item.imageSlug}
            coverTitle={item.title}
            coverCategory={item.coverCategory}
            coverSize="med"
            class="hp-intel-card-image"
            sizes="(max-width: 900px) 100vw, 33vw"
          />
          <div class="hp-intel-card-body">
            <span class="hp-intel-card-cat">{item.category}</span>
            <h3>{item.title}</h3>
            <p>{item.excerpt}</p>
            <span class="hp-intel-card-meta">{item.meta}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── 4. UAE Wallet Setup (dark band) ──────────────────────────────── -->
  <section class="hp-wallet-band">
    <div class="hp-wallet-grid">
      <div class="hp-wallet-text">
        <h2>The UAE Wallet Setup</h2>
        <p>
          Stop swiping a single generic cashback card. The combinations on
          this list cover the three things UAE spend actually lands on —
          recurring rent, supermarket shops, and the dining out you do anyway.
        </p>
        <ul class="hp-wallet-list">
          <li>
            <a href="/cards/cashback/">
              <span class="hp-wallet-list-t">Best for everyday spend</span>
              <span class="hp-wallet-list-d">Capped-and-uncapped cashback cards ranked by net return after the annual fee.</span>
            </a>
          </li>
          <li>
            <a href="/cards/miles/">
              <span class="hp-wallet-list-t">Best for travel & miles</span>
              <span class="hp-wallet-list-d">Skywards, Etihad Guest and transfer-partner cards with lounge access included.</span>
            </a>
          </li>
          <li>
            <a href="/calculator/">
              <span class="hp-wallet-list-t">Best welcome bonuses</span>
              <span class="hp-wallet-list-d">Live ranking of card welcome offers — sortable by your monthly AED spend.</span>
            </a>
          </li>
        </ul>
        <a href="/cards/" class="hp-wallet-cta">Explore card rankings →</a>
      </div>

      <div class="hp-wallet-media">
        <StockImage
          slug="wallet-hero-cards"
          coverTitle="Card combinations, AED-first."
          coverCategory="Review"
          coverSize="hero"
          class="hp-wallet-image"
          sizes="(max-width: 900px) 100vw, 50vw"
        />
        {avgWelcomeBonusK > 0 && (
          <div class="hp-wallet-stat" role="figure" aria-label="Average welcome bonus across reviewed cards">
            <span class="hp-wallet-stat-value">{avgWelcomeBonusK}k</span>
            <span class="hp-wallet-stat-label">Average welcome bonus<br />on reviewed cards</span>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- ── 5. Master Your Miles (Phase B.2) ─────────────────────────────── -->
  <section class="hp-miles-band">
    <div class="hp-miles-head">
      <div class="dp-featured-eyebrow">
        <span>Master your miles</span>
        <span class="rule"></span>
        <span class="meta">UAE-relevant loyalty programmes</span>
      </div>
      <h2>Where the dirhams turn into miles.</h2>
      <p>Programme-by-programme: tiers, sweet spots, transfer partners and expiry policy — the bits that decide whether your balance is worth what you think it is.</p>
    </div>

    <div class="hp-miles-grid">
      {milesTiles.map((p) => (
        <a href={`/airlines/${p.id}/`} class="hp-miles-tile">
          <div class="hp-miles-tile-head">
            <span class="eyebrow">{p.data.region}</span>
            <span class="currency">{p.data.currencyName}</span>
          </div>
          <h3 class="hp-miles-tile-title">{p.data.name}</h3>
          {p.data.sweetSpots[0] && (
            <p class="hp-miles-tile-spot">
              <span class="hp-miles-tile-spot-label">Sweet spot</span>
              {p.data.sweetSpots[0].title}
            </p>
          )}
          <span class="hp-miles-tile-cta">Programme guide →</span>
        </a>
      ))}
    </div>

    <div class="hp-miles-foot">
      <a href="/airlines/" class="hp-miles-more">Browse every programme →</a>
    </div>
  </section>

  <!-- ── 6. Newsletter band ───────────────────────────────────────────── -->
  <section class="hp-news-band">
    <div class="inner">
      <span class="eyebrow">The DubaiPoints brief</span>
      <h2>Friday morning, in your inbox.</h2>
      <p>One email each Friday with the week's salary-transfer changes, new card offers, miles redemptions worth knowing about, and lifestyle deals. AED-first, no fluff.</p>
      <div class="cta">
        <a href="/newsletter/" class="btn primary">Subscribe</a>
        <a href="/rss.xml" class="btn ghost">RSS feeds</a>
      </div>
      <p class="micro">
        We never sell email addresses or browsing data. <a href="/editorial-policy/">Editorial policy</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ─────────────────────────────────────────────────────────── */
  .dp-pagehead.is-hero {
    background: linear-gradient(to bottom, var(--shade-1) 0%, var(--paper) 100%);
    padding: 56px 32px 48px;
  }
  .hp-hero-grid {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: 48px;
    align-items: center;
  }
  .hp-hero-text { text-align: left; }
  .dp-pagehead.is-hero .kicker {
    display: inline-block;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--green);
    padding: 6px 14px;
    border: 1px solid var(--green);
    border-radius: 999px;
    margin-bottom: 22px;
  }
  .dp-pagehead.is-hero h1 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(38px, 6vw, 68px);
    line-height: 1.02;
    letter-spacing: -1.6px;
    color: var(--ink);
    text-wrap: balance;
    margin: 0 0 20px;
  }
  .dp-pagehead.is-hero h1 em {
    font-style: italic;
    color: var(--green);
    font-weight: 500;
  }
  .dp-pagehead.is-hero p {
    max-width: 50ch;
    margin: 0 0 24px;
    font-size: clamp(15px, 1.4vw, 17px);
    line-height: 1.6;
    color: var(--ink-soft);
    text-wrap: pretty;
  }
  .hp-hero-form {
    display: flex;
    gap: 0;
    max-width: 460px;
    border: 1px solid var(--line);
    background: var(--paper);
    border-radius: 999px;
    padding: 6px 6px 6px 18px;
    box-shadow: 0 6px 20px -12px rgba(15, 31, 46, 0.18);
  }
  .hp-hero-form-label {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
  }
  .hp-hero-form input[type="email"] {
    flex: 1; min-width: 0;
    border: 0; background: transparent;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 14px;
    color: var(--ink);
    padding: 8px 4px;
    outline: none;
  }
  .hp-hero-form input[type="email"]::placeholder { color: var(--muted); }
  .hp-hero-form button {
    border: 0; cursor: pointer;
    background: var(--green);
    color: white;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.3px;
    padding: 0 18px;
    height: 38px;
    border-radius: 999px;
    transition: background 0.15s ease, transform 0.15s ease;
    white-space: nowrap;
  }
  .hp-hero-form button:hover { background: #15293a; }
  .hp-hero-form button:active { transform: scale(0.98); }
  .hp-hero-micro {
    font-size: 12px;
    color: var(--muted);
    margin: 10px 0 0;
    max-width: 460px;
  }
  /* Image column + overlay chip */
  .hp-hero-media {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--shade-1);
    box-shadow: 0 22px 44px -22px rgba(15, 31, 46, 0.22);
  }
  .hp-hero-media :global(.hp-hero-image),
  .hp-hero-media :global(svg.dp-cover) {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .hp-hero-chip {
    position: absolute;
    left: 16px; right: 16px; bottom: 16px;
    max-width: 360px;
    background: var(--paper);
    border-radius: 12px;
    padding: 12px 14px 14px;
    display: grid; gap: 4px;
    box-shadow: 0 12px 28px -10px rgba(15, 31, 46, 0.28);
    text-decoration: none;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .hp-hero-chip:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 32px -10px rgba(15, 31, 46, 0.32);
  }
  .hp-hero-chip-eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--green);
  }
  .hp-hero-chip-title {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 15px;
    line-height: 1.3;
    letter-spacing: -0.2px;
    color: var(--ink);
    text-wrap: balance;
  }
  .hp-hero-chip-meta {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.3px;
  }

  /* ── Stats band ──────────────────────────────────────────────────── */
  .hp-stats-band {
    background: var(--bg);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 24px 32px;
  }
  .hp-stats-grid {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .hp-stat {
    display: grid;
    gap: 4px;
  }
  .hp-stat-value {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(28px, 3.2vw, 36px);
    letter-spacing: -0.8px;
    color: var(--green);
    line-height: 1;
  }
  .hp-stat-label {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 12px;
    color: var(--ink-soft);
    letter-spacing: 0.2px;
  }

  /* ── Fresh Intel ─────────────────────────────────────────────────── */
  .hp-intel-band {
    padding: 56px 32px 48px;
    max-width: 1180px;
    margin: 0 auto;
  }
  .hp-intel-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: end;
    gap: 16px 24px;
    margin-bottom: 28px;
  }
  .hp-intel-head h2 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(28px, 3.8vw, 40px);
    letter-spacing: -1px;
    color: var(--ink);
    margin: 0;
  }
  .hp-intel-head p {
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.5;
    margin: 0;
    max-width: 50ch;
  }
  .hp-intel-more {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
    color: var(--green);
    border-bottom: 2px solid var(--green);
    padding-bottom: 2px;
    transition: opacity 0.15s ease;
  }
  .hp-intel-more:hover { opacity: 0.75; }
  .hp-intel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .hp-intel-card {
    display: grid;
    grid-template-rows: auto 1fr;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .hp-intel-card:hover {
    transform: translateY(-2px);
    border-color: var(--ink-soft);
    box-shadow: 0 14px 30px -16px rgba(15, 31, 46, 0.18);
  }
  .hp-intel-card :global(.hp-intel-card-image) {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid var(--line);
  }
  .hp-intel-card :global(svg.dp-cover) {
    width: 100%;
    display: block;
    border-bottom: 1px solid var(--line);
  }
  .hp-intel-card-body {
    padding: 18px 20px 20px;
    display: grid; gap: 8px;
  }
  .hp-intel-card-cat {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--green);
  }
  .hp-intel-card h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: -0.3px;
    line-height: 1.25;
    color: var(--ink);
    margin: 0;
    text-wrap: balance;
  }
  .hp-intel-card:hover h3 { color: var(--green); }
  .hp-intel-card-body p {
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin: 0;
  }
  .hp-intel-card-meta {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.2px;
    margin-top: 4px;
  }

  /* ── UAE Wallet Setup (dark band) ────────────────────────────────── */
  .hp-wallet-band {
    background: var(--ink);
    color: var(--paper);
    padding: 64px 32px 72px;
  }
  .hp-wallet-grid {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }
  .hp-wallet-text h2 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(28px, 4vw, 42px);
    letter-spacing: -1px;
    color: var(--paper);
    margin: 0 0 16px;
    text-wrap: balance;
  }
  .hp-wallet-text > p {
    font-size: 15px;
    line-height: 1.6;
    color: rgba(251, 250, 246, 0.78);
    margin: 0 0 28px;
    max-width: 52ch;
  }
  .hp-wallet-list {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    display: grid;
    gap: 14px;
  }
  .hp-wallet-list a {
    display: grid;
    grid-template-columns: 8px 1fr;
    gap: 14px;
    text-decoration: none;
    padding: 8px 0;
    border-bottom: 1px solid rgba(251, 250, 246, 0.12);
    transition: padding-left 0.18s ease;
  }
  .hp-wallet-list a::before {
    content: '';
    align-self: start;
    margin-top: 8px;
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--mint);
  }
  .hp-wallet-list a:hover { padding-left: 4px; }
  .hp-wallet-list-t {
    display: block;
