---
// Homepage — TPG-adapted 5-section spec (locked 2026-05-08-bis).
// Brief: .council/research/2026-05/tpg-redesign-brief.md.
// Supersedes the Quiet Ledger 4-section build (PR #23).
//
// Sections:
//   1. Typographic hero
//   2. Feature card (navy band) — newest guide, .dp-feature-card pattern
//   3. Latest analysis — .dp-tabs (The latest / Credit cards / Loyalty programs)
//      → tabs are anchor links to dedicated pages, not JS state
//   4. "Explore our favourite cards" (navy band) — filter pills + .dp-card-tile grid
//   5. Newsletter (green band) + RSS pointer

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getAllCards } from "~/lib/cardsData";

const todayMs = Date.now();
const today = new Date();

const fmtFull = (d: Date) =>
  d.toLocaleDateString("en-GB", {
    day: "numeric", month: "long", year: "numeric",
  });
const fmtShort = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short" });
const fmtUS = (d: Date) =>
  d.toLocaleDateString("en-US", {
    month: "long", day: "2-digit", year: "numeric",
  });

// ── Source collections ───────────────────────────────────────────────────
const allGuides = await getCollection("guides");
const allDeals = await getCollection("deals");
const cards = getAllCards();

const liveDeals = allDeals
  .filter((d) => d.data.expiresOn.getTime() >= todayMs)
  .sort((a, b) => a.data.expiresOn.getTime() - b.data.expiresOn.getTime());

const guidesSorted = [...allGuides].sort(
  (a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime(),
);

const cardSpotlights = cards
  .filter((c) => c.welcomeBonus)
  .sort((a, b) => (b.welcomeBonusValue ?? 0) - (a.welcomeBonusValue ?? 0));

// ── Feature card — newest guide ─────────────────────────────────────────
const featureGuide = guidesSorted[0];

// ── Latest feed (8 items, mixed types, reverse-chronological) ───────────
type FeedItem = {
  href: string; cat: string; title: string; date: Date; detail: string;
};
const feed: FeedItem[] = [
  ...allGuides.map((g) => ({
    href: `/guides/${g.id}/`,
    cat: "Guides",
    title: g.data.title,
    date: g.data.updatedAt,
    detail: g.data.description,
  })),
  ...liveDeals.map((d) => ({
    href: `/deals/${d.id}/`,
    cat: "Deals",
    title: d.data.title,
    date: d.data.expiresOn,
    detail: `${d.data.category} · ends ${fmtShort(d.data.expiresOn)}`,
  })),
  ...cardSpotlights.slice(0, 6).map((c) => ({
    href: `/cards/${c.slug}/`,
    cat: "Reviews",
    title: c.name,
    date: c.lastVerified,
    detail: `${c.bank} · annual fee AED ${c.annualFee.toLocaleString()}`,
  })),
];
const latest = feed
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 8);

// ── Favourite cards — top 8 by welcome-bonus value ──────────────────────
const favouriteCards = cardSpotlights.slice(0, 8);

// ── Filter pill destinations ────────────────────────────────────────────
const filterPills = [
  { label: "All cards",  href: "/cards/" },
  { label: "Cashback",   href: "/cards/cashback/" },
  { label: "Miles",      href: "/cards/miles/" },
  { label: "Islamic",    href: "/cards/islamic/" },
  { label: "Compare",    href: "/cards/compare/" },
  { label: "Banks",      href: "/banks/" },
  { label: "Airlines",   href: "/airlines/" },
];
---

<BaseLayout
  title="DubaiPoints — UAE Miles, Deals & Banking Hacks"
  description="Independent UAE-resident-led guides to credit cards, salary-transfer bonuses, miles redemptions and lifestyle deals. Every figure in AED, every card checked."
  fullWidth={true}
>
  <div class="hp-root">

    <!-- ── 1. HERO — typographic, no images ──────────────────────────── -->
    <section class="hp-hero-section">
      <div class="hp-wrap">
        <header class="hp-masthead">
          <span class="hp-masthead-eyebrow">DubaiPoints</span>
          <span class="hp-masthead-date">{fmtFull(today)} · Dubai</span>
          <a href="/salary-transfer/" class="hp-masthead-live">Live · salary transfer tracker</a>
        </header>

        <h1 class="hp-hero-h1">UAE rewards rewarded.</h1>
        <p class="hp-hero-strap">
          Independent UAE-resident-led analysis of credit cards, salary-transfer
          bonuses, miles redemptions, and lifestyle deals — every figure in AED,
          every card checked against UAE eligibility rules.
        </p>
      </div>
    </section>

    <!-- ── 2. FEATURE CARD — navy band ───────────────────────────────── -->
    {featureGuide && (
      <section class="hp-feature-section">
        <div class="hp-wrap">
          <div class="hp-section-eyebrow-row">
            <span class="hp-section-eyebrow">Editor's read</span>
            <a href="/guides/" class="hp-section-more">All guides →</a>
          </div>

          <a href={`/guides/${featureGuide.id}/`} class="dp-feature-card">
            <div class="feat-mask" aria-hidden="true"></div>
            <div class="feat-body">
              <span class="feat-eyebrow">Guides</span>
              <h2 class="feat-title">{featureGuide.data.title}</h2>
              <p class="feat-meta">
                {fmtUS(featureGuide.data.updatedAt)}
                <span class="hp-bullet"> · </span>
                Updated {fmtShort(featureGuide.data.updatedAt)}
              </p>
            </div>
            <span class="feat-arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </section>
    )}

    <!-- ── 3. LATEST ANALYSIS — tabs + feed ───────────────────────────── -->
    <section class="hp-latest-section">
      <div class="hp-wrap">
        <div class="hp-latest-head">
          <h2>Navigate with more news, reviews + guides</h2>
          <p class="hp-latest-strap">
            Independent analysis from Dubai. Every figure in AED, every claim sourced.
          </p>
        </div>

        <nav class="dp-tabs" aria-label="Filter by content type">
          <a href="#latest" class="dp-tab is-active">The latest</a>
          <a href="/cards/" class="dp-tab">Credit cards</a>
          <a href="/airlines/" class="dp-tab">Loyalty programs</a>
        </nav>

        <ul class="hp-latest-list" id="latest">
          {latest.map((f) => (
            <li class="hp-latest-row">
              <a href={f.href} class="hp-latest-link">
                <span class="hp-latest-cat">{f.cat}</span>
                <span class="hp-latest-title">{f.title}</span>
                <span class="hp-latest-detail">{f.detail}</span>
                <span class="hp-latest-date">{fmtShort(f.date)}</span>
              </a>
            </li>
          ))}
        </ul>

        <div class="hp-latest-foot">
          <a href="/guides/" class="hp-find-more">Find more stories →</a>
        </div>
      </div>
    </section>

    <!-- ── 4. EXPLORE OUR FAVOURITE CARDS — navy band ────────────────── -->
    <section class="hp-cards-section dp-band-navy">
      <div class="hp-wrap">
        <div class="hp-cards-head">
          <h2>Explore our favourite cards</h2>
          <p class="hp-cards-strap">
            Reviewed against UAE eligibility, not US norms. Every card checked
            against the issuer's published Schedule of Charges.
          </p>
        </div>

        <div class="dp-filter-pills hp-cards-pills">
          {filterPills.map((p) => (
            <a href={p.href} class="dp-filter-pill">{p.label}</a>
          ))}
        </div>

        <div class="hp-cards-grid">
          {favouriteCards.map((c) => (
            <a href={`/cards/${c.slug}/`} class="dp-card-tile">
              <div class="art">
                <span class="art-bank">{c.bank}</span>
                <span class="art-name">{c.name}</span>
                <span class="art-network">{c.network}</span>
              </div>
              <div class="body">
                <span class="eyebrow">Review</span>
                <span class="title">{c.name}</span>
                <div class="specs">
                  <span><strong>AED {c.annualFee.toLocaleString()}</strong> / yr</span>
                  <span><strong>AED {(c.eligibility?.minSalary ?? 0).toLocaleString()}</strong> / mo min</span>
                </div>
                <span class="review-cta">Read review →</span>
              </div>
            </a>
          ))}
        </div>

        <div class="hp-cards-foot">
          <a href="/cards/" class="hp-find-more is-on-navy">See all reviewed cards →</a>
        </div>
      </div>
    </section>

    <!-- ── 5. NEWSLETTER — emerald band ──────────────────────────────── -->
    <section class="hp-newsletter-section dp-band-green">
      <div class="hp-wrap">
        <div class="hp-newsletter">
          <p class="hp-news-eyebrow">The DubaiPoints brief</p>
          <h2>Friday morning, in your inbox.</h2>
          <p class="hp-news-strap">
            One email each Friday with the week's salary-transfer changes, new
            card offers, and lifestyle deals worth knowing about. AED-first, no
            fluff. Per-band RSS feeds available too.
          </p>
          <div class="hp-news-actions">
            <a href="/newsletter/" class="hp-news-btn hp-news-btn-primary">
              Subscribe
            </a>
            <a href="/rss.xml" class="hp-news-btn hp-news-btn-ghost">
              RSS feeds
            </a>
          </div>
          <p class="hp-news-microcopy">
            We never sell email addresses or browsing data.
            <a href="/editorial-policy/">Editorial policy</a>.
          </p>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ════════════════════════════════════════════════════════════════════
     Homepage — TPG-adapted (Chunk 2 of the revamp).
     Tokens come from src/styles/global.css. Components defined globally:
     .dp-feature-card, .dp-tabs, .dp-filter-pills, .dp-card-tile,
     .dp-band-navy, .dp-band-green. This file holds homepage-specific
     layout glue only.
     ════════════════════════════════════════════════════════════════════ */
  .hp-root { background: var(--paper); color: var(--ink); }

  .hp-wrap {
    width: 100%; max-width: 1180px;
    margin: 0 auto;
    padding-inline: 16px;
  }
  @media (min-width: 768px)  { .hp-wrap { padding-inline: 24px; } }
  @media (min-width: 1024px) { .hp-wrap { padding-inline: 32px; } }

  /* ── Section eyebrow row (used above feature card) ──────────────────── */
  .hp-section-eyebrow-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
  }
  .hp-section-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--green);
  }
  .hp-section-more {
    font-size: 11px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .hp-section-more:hover { color: var(--link); }

  .hp-find-more {
    display: inline-flex; align-items: center;
    font-size: 14px; font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--link);
  }
  .hp-find-more:hover { color: var(--link-deep); }
  .hp-find-more.is-on-navy { color: white; }
  .hp-find-more.is-on-navy:hover { color: rgba(255,255,255,0.85); }

  /* ── Section 1: Hero — typographic ───────────────────────────────────── */
  .hp-hero-section {
    padding-block: 24px 56px;
    border-bottom: 1px solid var(--line);
  }
  @media (min-width: 1024px) {
    .hp-hero-section { padding-block: 32px 88px; }
  }

  .hp-masthead {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
    border-bottom: 1px solid var(--ink);
    padding-block: 0 14px;
    margin-bottom: 36px;
  }
  .hp-masthead-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--ink);
  }
  .hp-masthead-date {
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.4px;
    color: var(--ink-soft);
  }
  .hp-masthead-live {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--red);
  }
  .hp-masthead-live:hover { text-decoration: underline; text-underline-offset: 3px; }

  .hp-hero-h1 {
    font-family: 'Fraunces', serif; font-weight: 700;
    font-size: clamp(40px, 8.4vw, 96px);
    line-height: 0.96; letter-spacing: -2.4px;
    color: var(--ink); text-wrap: balance;
    max-width: 11ch;
  }
  .hp-hero-strap {
    margin-top: 20px;
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.55; color: var(--ink-soft);
    max-width: 60ch;
    text-wrap: pretty;
  }

  /* ── Section 2: Feature card ─────────────────────────────────────────── */
  .hp-feature-section {
    padding-block: 40px 56px;
    border-bottom: 1px solid var(--line);
  }
  @media (min-width: 1024px) {
    .hp-feature-section { padding-block: 56px 80px; }
  }
  .hp-bullet { color: rgba(255,255,255,0.4); }

  /* ── Section 3: Latest analysis ──────────────────────────────────────── */
  .hp-latest-section {
    padding-block: 48px 56px;
    border-bottom: 1px solid var(--line);
  }
  @media (min-width: 1024px) {
    .hp-latest-section { padding-block: 72px 80px; }
  }
  .hp-latest-head { margin-bottom: 28px; max-width: 740px; }
  .hp-latest-head h2 {
    font-family: 'Fraunces', serif; font-weight: 700;
    font-size: clamp(28px, 5vw, 44px);
    line-height: 1.08; letter-spacing: -1.2px;
    color: var(--ink); text-wrap: balance;
  }
  .hp-latest-strap {
    margin-top: 12px;
    font-size: 16px; line-height: 1.55;
    color: var(--ink-soft);
    max-width: 56ch;
  }

  .hp-latest-list { list-style: none; padding: 0; margin: 0; }
  .hp-latest-row { border-bottom: 1px solid var(--line); }
  .hp-latest-row:last-child { border-bottom: none; }
  .hp-latest-link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4px;
    padding: 18px 0;
  }
  @media (min-width: 768px) {
    .hp-latest-link {
      grid-template-columns: 130px minmax(0, 1fr) 100px;
      gap: 24px; align-items: baseline;
      padding: 20px 0;
    }
  }
  .hp-latest-cat {
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--green);
  }
  .hp-latest-title {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: clamp(17px, 2vw, 20px);
    line-height: 1.3; letter-spacing: -0.3px;
    color: var(--ink); text-wrap: balance;
  }
  .hp-latest-link:hover .hp-latest-title {
    text-decoration: underline;
    text-decoration-color: var(--link);
    text-underline-offset: 4px;
  }
  .hp-latest-detail {
    font-size: 13px; color: var(--ink-soft); line-height: 1.5;
    grid-column: 1;
  }
  @media (min-width: 768px) { .hp-latest-detail { grid-column: 2; } }
  .hp-latest-date {
    font-size: 12px; color: var(--muted);
    grid-column: 1;
  }
  @media (min-width: 768px) {
    .hp-latest-date { grid-column: 3; text-align: right; }
  }

  .hp-latest-foot { margin-top: 28px; text-align: center; }

  /* ── Section 4: Favourite cards (navy band) ──────────────────────────── */
  .hp-cards-section {
    padding-block: 56px 64px;
  }
  @media (min-width: 1024px) {
    .hp-cards-section { padding-block: 88px 96px; }
  }
  .hp-cards-head { margin-bottom: 28px; max-width: 740px; }
  .hp-cards-head h2 {
    font-family: 'Fraunces', serif; font-weight: 700;
    font-size: clamp(28px, 5vw, 44px);
    line-height: 1.08; letter-spacing: -1.2px;
    text-wrap: balance;
  }
  .hp-cards-strap {
    margin-top: 12px;
    font-size: 16px; line-height: 1.55;
    color: rgba(255,255,255,0.78);
    max-width: 56ch;
  }
  .hp-cards-pills { margin-bottom: 32px; }
  .hp-cards-grid {
    display: grid; gap: 16px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px)  { .hp-cards-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .hp-cards-grid { grid-template-columns: repeat(4, 1fr); } }
  .hp-cards-foot { margin-top: 36px; text-align: center; }

  /* ── Section 5: Newsletter (green band) ──────────────────────────────── */
  .hp-newsletter-section {
    padding-block: 56px 72px;
  }
  @media (min-width: 1024px) {
    .hp-newsletter-section { padding-block: 88px 104px; }
  }
  .hp-newsletter { max-width: 720px; margin: 0 auto; text-align: left; }
  .hp-news-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: white;
    margin-bottom: 14px;
  }
  .hp-newsletter h2 {
    font-family: 'Fraunces', serif; font-weight: 700;
    font-size: clamp(28px, 5vw, 44px);
    line-height: 1.06; letter-spacing: -1.2px;
    text-wrap: balance;
  }
  .hp-news-strap {
    margin-top: 16px;
    font-size: 16px; line-height: 1.55;
    color: rgba(255,255,255,0.88);
    max-width: 56ch;
  }
  .hp-news-actions {
    margin-top: 22px;
    display: flex; flex-wrap: wrap; gap: 12px;
  }
  .hp-news-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 12px 22px; min-height: 44px;
    border-radius: 999px;
    font-size: 13px; font-weight: 700;
    letter-spacing: 1px;
    text-align: center;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .hp-news-btn-primary {
    background: white; color: var(--green-band);
    border: 1px solid white;
  }
  .hp-news-btn-primary:hover { background: rgba(255,255,255,0.9); }
  .hp-news-btn-ghost {
    background: transparent; color: white;
    border: 1px solid rgba(255,255,255,0.6);
  }
  .hp-news-btn-ghost:hover { border-color: white; }
  .hp-news-microcopy {
    margin-top: 20px;
    font-size: 12px; color: rgba(255,255,255,0.65);
    line-height: 1.5;
  }
  .hp-news-microcopy a { text-decoration: underline; text-underline-offset: 3px; }
</style>
