---
// Homepage — Quiet Ledger 4-section spec.
// .council/sessions/2026-05-08-revamp.md (chunk 1).
// Replaces the prior 7-section, 427-line scoped-CSS implementation with
// the .dp-* idiom + a small set of homepage-only layout primitives.

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getAllCards } from "~/lib/cardsData";

const todayMs = Date.now();
const today = new Date();

const fmtFull = (d: Date) =>
  d.toLocaleDateString("en-GB", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
const fmtShort = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short" });

// ── Source collections ───────────────────────────────────────────────────
const allGuides = await getCollection("guides");
const allDeals = await getCollection("deals");
const allSalaryOffers = await getCollection("salaryTransferOffers");
const cards = getAllCards();

const liveDeals = allDeals
  .filter((d) => d.data.expiresOn.getTime() >= todayMs)
  .sort((a, b) => a.data.expiresOn.getTime() - b.data.expiresOn.getTime());

const guidesSorted = [...allGuides].sort(
  (a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime(),
);

const cardSpotlights = cards
  .filter((c) => c.welcomeBonus)
  .sort((a, b) => (b.welcomeBonusValue ?? 0) - (a.welcomeBonusValue ?? 0));

// ── Section 1 — typographic index (5 lead stories, no images) ───────────
const indexStories = [
  ...guidesSorted.slice(0, 2).map((g) => ({
    cat: "Guide",
    href: `/guides/${g.id}/`,
    title: g.data.title,
    meta: `Updated ${fmtShort(g.data.updatedAt)}`,
  })),
  ...liveDeals.slice(0, 2).map((d) => ({
    cat: "Deal",
    href: `/deals/${d.id}/`,
    title: d.data.title,
    meta: `Ends ${fmtShort(d.data.expiresOn)}`,
  })),
  ...cardSpotlights.slice(0, 1).map((c) => ({
    cat: "Card review",
    href: `/cards/${c.slug}/`,
    title: c.name,
    meta: `Verified ${fmtShort(c.lastVerified)}`,
  })),
].slice(0, 5);

// ── Section 2 — Live: salary transfer + deals rail ──────────────────────
const liveSalaryOffers = allSalaryOffers
  .filter((o) => !o.data.archived && o.data.validUntil.getTime() >= todayMs)
  .map((o) => {
    const maxReward = Math.max(
      ...o.data.salaryBands.map((b) => b.rewardAmount),
    );
    const minSalary = Math.min(
      ...o.data.salaryBands.map((b) => b.minSalary),
    );
    return { entry: o, maxReward, minSalary };
  })
  .sort((a, b) => b.maxReward - a.maxReward)
  .slice(0, 4);

const railDeals = liveDeals.slice(0, 4);

// ── Section 3 — Latest analysis (combined feed, reverse chronological) ──
type FeedItem = {
  href: string;
  cat: string;
  title: string;
  date: Date;
  detail: string;
};
const feed: FeedItem[] = [
  ...allGuides.map((g) => ({
    href: `/guides/${g.id}/`,
    cat: "Guide",
    title: g.data.title,
    date: g.data.updatedAt,
    detail: g.data.description,
  })),
  ...liveDeals.map((d) => ({
    href: `/deals/${d.id}/`,
    cat: "Deal",
    title: d.data.title,
    date: d.data.expiresOn,
    detail: `Ends ${fmtShort(d.data.expiresOn)}`,
  })),
  ...cardSpotlights.slice(0, 6).map((c) => ({
    href: `/cards/${c.slug}/`,
    cat: "Card review",
    title: c.name,
    date: c.lastVerified,
    detail: `${c.bank} · annual fee AED ${c.annualFee.toLocaleString()}`,
  })),
];
const recentFeed = feed
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 8);
---

<BaseLayout
  title="DubaiPoints — UAE Miles, Deals & Banking Hacks"
  description="Independent UAE-resident-led guides to credit cards, salary-transfer bonuses, miles redemptions and lifestyle deals. Every figure in AED, every card checked."
  fullWidth={true}
>
  <div class="hp-root">

    <!-- ── 1. MASTHEAD-DATELINE + 5-STORY INDEX ──────────────────────── -->
    <section class="hp-masthead-section">
      <div class="hp-wrap">

        <header class="hp-masthead">
          <span class="hp-eyebrow">DubaiPoints</span>
          <span class="hp-dateline">{fmtFull(today)} · Dubai</span>
          <a href="/salary-transfer/" class="hp-live-tag">Live · salary transfer tracker</a>
        </header>

        <div class="hp-hero">
          <h1>UAE rewards, banking, and travel — without the marketing.</h1>
          <p class="hp-strap">
            Independent UAE-resident-led analysis of credit cards, salary-transfer
            bonuses, miles redemptions, and lifestyle deals — every figure in AED,
            every card checked against UAE eligibility rules.
          </p>
        </div>

        <div class="hp-index">
          <div class="hp-index-head">In today's brief</div>
          <div class="hp-index-list">
            {indexStories.map((s) => (
              <a href={s.href} class="hp-index-item">
                <span class="hp-index-cat">{s.cat}</span>
                <span class="hp-index-title">{s.title}</span>
                <span class="hp-index-meta">{s.meta}</span>
              </a>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- ── 2. LIVE: SALARY TRANSFER + DEALS RAIL ─────────────────────── -->
    <section class="hp-live-section">
      <div class="hp-wrap">
        <div class="hp-section-head">
          <h2>Live this week</h2>
          <span class="hp-section-meta">Updated {fmtFull(today)}</span>
        </div>

        <div class="hp-live-grid">

          <div class="hp-live-col">
            <div class="hp-col-head">
              <h3>Salary transfer offers</h3>
              <a href="/salary-transfer/" class="hp-col-more">All offers →</a>
            </div>
            {liveSalaryOffers.length === 0 ? (
              <p class="hp-empty">No live offers tracked. Check the tracker page.</p>
            ) : (
              <ul class="hp-live-list">
                {liveSalaryOffers.map(({ entry, maxReward, minSalary }) => (
                  <li class="hp-live-row">
                    <a href={`/salary-transfer/${entry.id}/`} class="hp-live-row-main">
                      <span class="hp-live-row-name">{entry.data.name}</span>
                      <span class="hp-live-row-meta">
                        Min salary AED {minSalary.toLocaleString()} · ends {fmtShort(entry.data.validUntil)}
                      </span>
                    </a>
                    <span class="hp-live-row-amount">
                      <span class="num">AED {maxReward.toLocaleString()}</span>
                    </span>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <div class="hp-live-col">
            <div class="hp-col-head">
              <h3>Deals expiring soon</h3>
              <a href="/deals/" class="hp-col-more">All deals →</a>
            </div>
            {railDeals.length === 0 ? (
              <p class="hp-empty">No live deals right now.</p>
            ) : (
              <ul class="hp-live-list">
                {railDeals.map((d) => (
                  <li class="hp-live-row">
                    <a href={`/deals/${d.id}/`} class="hp-live-row-main">
                      <span class="hp-live-row-name">{d.data.title}</span>
                      <span class="hp-live-row-meta">{d.data.category}</span>
                    </a>
                    <span class="hp-live-row-amount">
                      <span class="hp-expiry">Ends {fmtShort(d.data.expiresOn)}</span>
                    </span>
                  </li>
                ))}
              </ul>
            )}
          </div>

        </div>
      </div>
    </section>

    <!-- ── 3. LATEST ANALYSIS (single-column feed) ───────────────────── -->
    <section class="hp-feed-section">
      <div class="hp-wrap">
        <div class="hp-section-head">
          <h2>Latest analysis</h2>
          <a href="/guides/" class="hp-section-meta">All guides →</a>
        </div>

        <ul class="hp-feed-list">
          {recentFeed.map((f) => (
            <li class="hp-feed-row">
              <a href={f.href} class="hp-feed-link">
                <span class="hp-feed-cat">{f.cat}</span>
                <span class="hp-feed-title">{f.title}</span>
                <span class="hp-feed-detail">{f.detail}</span>
                <span class="hp-feed-date">{fmtShort(f.date)}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- ── 4. NEWSLETTER + RSS-BY-BAND ───────────────────────────────── -->
    <section class="hp-newsletter-section">
      <div class="hp-wrap">
        <div class="hp-newsletter">
          <div class="hp-news-copy">
            <p class="hp-news-eyebrow">Subscribe</p>
            <h2>The Friday brief, in your inbox.</h2>
            <p class="hp-news-strap">
              One email each Friday with the week's salary-transfer changes, new
              card offers, and lifestyle deals. AED-first, no fluff. Or follow
              the per-band RSS feeds and get only what matches your salary.
            </p>
          </div>
          <div class="hp-news-actions">
            <a href="/newsletter/" class="hp-news-btn hp-news-btn-primary">
              Subscribe to the brief
            </a>
            <a href="/rss.xml" class="hp-news-btn hp-news-btn-ghost">
              RSS feeds (by salary band)
            </a>
          </div>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  /* ════════════════════════════════════════════════════════════════════
     Homepage — Quiet Ledger.
     Tokens come from src/styles/global.css (--ink, --ink-soft, --line,
     --paper, --bg, --brand, --red). No new colour tokens, no Tailwind
     utilities. Mobile-first; breakpoints at 768 (tablet) and 1024 (desktop).
     ════════════════════════════════════════════════════════════════════ */

  .hp-root {
    background: var(--paper);
    color: var(--ink);
    font-feature-settings: "tnum" 1, "lnum" 1;
  }

  .hp-wrap {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding-inline: 16px;
  }
  @media (min-width: 768px)  { .hp-wrap { padding-inline: 24px; } }
  @media (min-width: 1024px) { .hp-wrap { padding-inline: 32px; } }

  /* Section heads — shared across live, feed, newsletter. */
  .hp-section-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 12px;
    margin-bottom: 24px;
  }
  .hp-section-head h2 {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: clamp(22px, 3.4vw, 30px);
    letter-spacing: -0.6px; color: var(--ink);
  }
  .hp-section-meta {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--ink-soft);
    white-space: nowrap;
  }
  a.hp-section-meta:hover { color: var(--brand); }

  /* ── 1. Masthead-dateline section ───────────────────────────────────── */
  .hp-masthead-section {
    border-bottom: 1px solid var(--line);
    padding-block: 20px 36px;
  }
  @media (min-width: 1024px) {
    .hp-masthead-section { padding-block: 24px 56px; }
  }

  .hp-masthead {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
    border-bottom: 1px solid var(--ink);
    padding-block: 0 14px;
    margin-bottom: 28px;
  }
  .hp-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--ink);
  }
  .hp-dateline {
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.4px;
    color: var(--ink-soft);
  }
  .hp-live-tag {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--red);
  }
  .hp-live-tag:hover { text-decoration: underline; text-underline-offset: 3px; }

  .hp-hero h1 {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: clamp(32px, 5.6vw, 56px);
    line-height: 1.04; letter-spacing: -1.4px;
    color: var(--ink); text-wrap: balance;
    max-width: 18ch;
  }
  .hp-strap {
    margin-top: 14px;
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.55; color: var(--ink-soft);
    max-width: 60ch;
    text-wrap: pretty;
  }

  .hp-index {
    margin-top: 36px;
    border-top: 1px solid var(--ink);
    padding-top: 18px;
  }
  .hp-index-head {
    font-size: 10px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 14px;
  }
  .hp-index-list { display: grid; grid-template-columns: 1fr; }
  .hp-index-item {
    display: grid; grid-template-columns: 1fr; gap: 4px;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
  }
  @media (min-width: 768px) {
    .hp-index-item {
      grid-template-columns: 130px 1fr 110px;
      gap: 24px; align-items: baseline;
      padding: 18px 0;
    }
  }
  .hp-index-cat {
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .hp-index-title {
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: clamp(18px, 2.2vw, 22px);
    line-height: 1.25; letter-spacing: -0.3px;
    color: var(--ink); text-wrap: balance;
  }
  .hp-index-item:hover .hp-index-title {
    text-decoration: underline;
    text-decoration-color: var(--brand);
    text-underline-offset: 4px;
  }
  .hp-index-meta {
    font-size: 12px; color: var(--muted);
    letter-spacing: 0.2px;
  }
  @media (min-width: 768px) { .hp-index-meta { text-align: right; } }

  /* ── 2. Live module ──────────────────────────────────────────────────── */
  .hp-live-section {
    padding-block: 48px 56px;
    border-bottom: 1px solid var(--line);
    background: var(--bg);
  }
  @media (min-width: 1024px) {
    .hp-live-section { padding-block: 64px 72px; }
  }

  .hp-live-grid {
    display: grid; gap: 28px;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .hp-live-grid { grid-template-columns: 1fr 1fr; gap: 36px; }
  }

  .hp-col-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 12px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 10px;
    margin-bottom: 8px;
  }
  .hp-col-head h3 {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: 18px; letter-spacing: -0.3px; color: var(--ink);
  }
  .hp-col-more {
    font-size: 11px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .hp-col-more:hover { color: var(--brand); }

  .hp-empty {
    font-size: 13px; color: var(--muted);
    padding: 14px 0;
  }

  .hp-live-list { list-style: none; padding: 0; margin: 0; }
  .hp-live-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
  }
  .hp-live-row:last-child { border-bottom: none; }
  @media (min-width: 480px) {
    .hp-live-row {
      grid-template-columns: 1fr auto;
      gap: 16px;
      align-items: baseline;
    }
  }
  .hp-live-row-main { min-width: 0; display: flex; flex-direction: column; gap: 3px; }
  .hp-live-row-name {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: 16px; letter-spacing: -0.2px;
    color: var(--ink);
    line-height: 1.3;
  }
  .hp-live-row-main:hover .hp-live-row-name { text-decoration: underline; text-underline-offset: 3px; }
  .hp-live-row-meta {
    font-size: 12px; color: var(--ink-soft); line-height: 1.4;
  }
  .hp-live-row-amount { text-align: left; }
  @media (min-width: 480px) { .hp-live-row-amount { text-align: right; white-space: nowrap; } }
  .hp-live-row-amount .num {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: 22px; letter-spacing: -0.5px; color: var(--ink);
  }
  .hp-expiry {
    font-size: 11px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--red);
  }

  /* ── 3. Latest analysis feed ─────────────────────────────────────────── */
  .hp-feed-section {
    padding-block: 48px 56px;
    border-bottom: 1px solid var(--line);
  }
  @media (min-width: 1024px) {
    .hp-feed-section { padding-block: 64px 72px; }
  }

  .hp-feed-list { list-style: none; padding: 0; margin: 0; }
  .hp-feed-row { border-bottom: 1px solid var(--line); }
  .hp-feed-row:last-child { border-bottom: none; }
  .hp-feed-link {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4px;
    padding: 18px 0;
  }
  @media (min-width: 768px) {
    .hp-feed-link {
      grid-template-columns: 130px minmax(0, 1fr) 110px;
      gap: 24px; align-items: baseline;
      padding: 20px 0;
    }
  }
  .hp-feed-cat {
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .hp-feed-title {
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: clamp(17px, 2vw, 20px);
    line-height: 1.3; letter-spacing: -0.3px;
    color: var(--ink); text-wrap: balance;
  }
  .hp-feed-link:hover .hp-feed-title {
    text-decoration: underline;
    text-decoration-color: var(--brand);
    text-underline-offset: 4px;
  }
  .hp-feed-detail {
    font-size: 13px; color: var(--ink-soft); line-height: 1.5;
    grid-column: 1;
  }
  @media (min-width: 768px) { .hp-feed-detail { grid-column: 2; } }
  .hp-feed-date {
    font-size: 12px; color: var(--muted);
    letter-spacing: 0.2px;
    grid-column: 1;
  }
  @media (min-width: 768px) {
    .hp-feed-date { grid-column: 3; text-align: right; }
  }

  /* ── 4. Newsletter ───────────────────────────────────────────────────── */
  .hp-newsletter-section { padding-block: 48px 72px; }
  @media (min-width: 1024px) {
    .hp-newsletter-section { padding-block: 64px 96px; }
  }
  .hp-newsletter {
    display: grid; gap: 24px;
    grid-template-columns: 1fr;
    border: 1px solid var(--ink);
    padding: 24px;
    background: var(--paper);
  }
  @media (min-width: 768px) {
    .hp-newsletter {
      grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
      gap: 36px;
      padding: 36px 40px;
      align-items: center;
    }
  }
  .hp-news-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--red);
    margin-bottom: 10px;
  }
  .hp-news-copy h2 {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: clamp(22px, 3vw, 28px);
    line-height: 1.15; letter-spacing: -0.6px;
    color: var(--ink); text-wrap: balance;
  }
  .hp-news-strap {
    margin-top: 12px;
    font-size: 14px; line-height: 1.55;
    color: var(--ink-soft); max-width: 50ch;
  }
  .hp-news-actions {
    display: flex; flex-direction: column; gap: 10px;
  }
  .hp-news-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 12px 18px; min-height: 44px;
    font-size: 13px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    text-align: center;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .hp-news-btn-primary {
    background: var(--ink); color: white;
    border: 1px solid var(--ink);
  }
  .hp-news-btn-primary:hover { background: var(--brand); border-color: var(--brand); }
  .hp-news-btn-ghost {
    background: var(--paper); color: var(--ink);
    border: 1px solid var(--ink);
  }
  .hp-news-btn-ghost:hover { color: var(--brand); border-color: var(--brand); }
</style>
