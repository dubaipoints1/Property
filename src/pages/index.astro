---
// Homepage — design-handoff idiom (Phase H1, Claude Design handoff bundle).
// Structure mirrors the section-index template (B1) plus a richer hero and
// a card-spotlight band that reuses the per-issuer .dp-cr-mock from G2.
//
// Sections
//   1. Masthead hero (eyebrow / date / h1 / strap / meta strip)
//   2. Featured band (1 hero + 2 medium + 4 small) — newest guides + deals
//   3. Pull-quote (editorial standard)
//   4. Latest feed (8 mixed-type items, numbered)
//   5. Favourite cards spotlight (per-issuer card-art tiles)
//   6. Newsletter band (green CTA)

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getAllCards } from "~/lib/cardsData";

const todayMs = Date.now();

const fmtShort = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short" });

// ── Source collections ───────────────────────────────────────────────────
const allGuides = await getCollection("guides");
const allDeals = await getCollection("deals");
const cards = getAllCards();

const liveDeals = allDeals
  .filter((d) => d.data.expiresOn.getTime() >= todayMs)
  .sort((a, b) => a.data.expiresOn.getTime() - b.data.expiresOn.getTime());

const guidesSorted = [...allGuides].sort(
  (a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime(),
);

const cardSpotlights = cards
  .filter((c) => c.welcomeBonus)
  .sort((a, b) => (b.welcomeBonusValue ?? 0) - (a.welcomeBonusValue ?? 0));

// ── Featured band — top 7 mixed (1 hero + 2 med + 4 sm) ─────────────────
type Featured = {
  href: string; cat: string; title: string; deck?: string; date: Date;
};
const featuredPool: Featured[] = [
  ...guidesSorted.map((g) => ({
    href: `/guides/${g.id}/`,
    cat: "Guide",
    title: g.data.title,
    deck: g.data.description,
    date: g.data.updatedAt,
  })),
  ...liveDeals.map((d) => ({
    href: `/deals/${d.id}/`,
    cat: "Deal",
    title: d.data.title,
    deck: `${d.data.category} · ends ${fmtShort(d.data.expiresOn)}`,
    date: d.data.expiresOn,
  })),
  ...cardSpotlights.slice(0, 4).map((c) => ({
    href: `/cards/${c.slug}/`,
    cat: "Review",
    title: c.name,
    deck: `${c.bank} · annual fee AED ${c.annualFee.toLocaleString()}`,
    date: c.lastVerified,
  })),
];
const featured = featuredPool
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 7);

// ── Latest feed (8 mixed items, numbered) ────────────────────────────────
const latest = featuredPool
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 8);

// ── Favourite cards (top 6 by welcome-bonus value) ──────────────────────
const favouriteCards = cardSpotlights.slice(0, 6);

// ── Filter pill destinations ────────────────────────────────────────────
const filters = [
  { label: "All cards",  href: "/cards/" },
  { label: "Cashback",   href: "/cards/cashback/" },
  { label: "Miles",      href: "/cards/miles/" },
  { label: "Islamic",    href: "/cards/islamic/" },
  { label: "Compare",    href: "/cards/compare/" },
];
---

<BaseLayout
  title="DubaiPoints — UAE Miles, Deals & Banking Hacks"
  description="Independent UAE-resident-led guides to credit cards, salary-transfer bonuses, miles redemptions and lifestyle deals. Every figure in AED, every card checked."
  fullWidth
>
  <!-- ── 1. Masthead hero ─────────────────────────────────────────────── -->
  <header class="dp-pagehead is-hero">
    <h1>Points and miles for the&nbsp;UAE.</h1>
    <p>
      Independent analysis of UAE credit cards, salary-transfer bonuses,
      miles redemptions and lifestyle deals — every figure in AED, every
      card checked against UAE eligibility.
    </p>
    <div class="meta-strip">
      <span><strong>{cards.length}</strong> cards reviewed</span>
      <span class="sep" aria-hidden="true"></span>
      <span><strong>{liveDeals.length}</strong> live deals</span>
      <span class="sep" aria-hidden="true"></span>
      <span><strong>{allGuides.length}</strong> guides</span>
      <a href="/salary-transfer/" class="live-link">
        <span class="dot" aria-hidden="true"></span>
        Live tracker
      </a>
    </div>
  </header>

  <!-- Decorative section divider between hero and featured band -->
  <div class="dp-section-divider" aria-hidden="true">
    <span class="rule"></span>
    <span class="dot"></span>
    <span class="rule"></span>
  </div>

  <!-- ── 2. Featured band ─────────────────────────────────────────────── -->
  {featured.length > 0 && (
    <section class="dp-featured-band">
      <div class="dp-featured-eyebrow">
        <span>Featured this week</span>
        <span class="rule"></span>
        <span class="meta">Curated by editors · refreshed Mondays</span>
      </div>
      <div class="dp-featured-grid">
        {featured[0] && (
          <a href={featured[0].href} class="dp-story-card hero">
            <div class="cover">Cover · {featured[0].cat}</div>
            <div class="body">
              <div class="meta"><span class="cat">{featured[0].cat}</span><span>{fmtShort(featured[0].date)}</span></div>
              <h3>{featured[0].title}</h3>
              {featured[0].deck && <p>{featured[0].deck}</p>}
              <div class="by">By DubaiPoints Editorial</div>
            </div>
          </a>
        )}
        {featured.slice(1, 3).map((f) => (
          <a href={f.href} class="dp-story-card med">
            <div class="cover">Cover · {f.cat}</div>
            <div class="body">
              <div class="meta"><span class="cat">{f.cat}</span><span>{fmtShort(f.date)}</span></div>
              <h3>{f.title}</h3>
              {f.deck && <p>{f.deck}</p>}
            </div>
          </a>
        ))}
        {featured.slice(3, 7).map((f) => (
          <a href={f.href} class="dp-story-card sm">
            <div class="cover">Cover</div>
            <div class="body">
              <div class="meta"><span class="cat">{f.cat}</span><span>{fmtShort(f.date)}</span></div>
              <h3>{f.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── 3. Pull-quote ────────────────────────────────────────────────── -->
  <div class="dp-pullquote">
    <div class="mark">"</div>
    <blockquote>
      The only UAE points publication that pays its own annual fees, refuses advertorial, and prints the date next to every verdict.
    </blockquote>
    <div class="attr"><span class="rule"></span>Editorial standard · est. 2026</div>
  </div>

  <!-- ── 4. Latest feed ───────────────────────────────────────────────── -->
  <div class="dp-list-head">
    <div class="t">The latest</div>
    <div class="m">Newest stories across guides, reviews and deals · refreshed daily</div>
  </div>
  <div class="dp-feed">
    {latest.map((f, i) => (
      <a href={f.href} class="dp-feed-row">
        <div>
          <div class="num">{String(i + 1).padStart(2, "0")}</div>
          <div class="feed-eyebrow">{f.cat}</div>
        </div>
        <div>
          <h3>{f.title}</h3>
          {f.deck && <div class="summary">{f.deck}</div>}
        </div>
        <div class="thumb">Cover · {f.cat}</div>
        <div class="when">{fmtShort(f.date)}</div>
      </a>
    ))}
  </div>

  <div class="dp-page-nav">
    <a href="/news/" class="more-link">More stories →</a>
  </div>

  <!-- ── 5. Favourite cards spotlight ─────────────────────────────────── -->
  <section class="hp-cards-band">
    <div class="hp-cards-head">
      <div class="dp-featured-eyebrow">
        <span>Cards to consider this month</span>
        <span class="rule"></span>
        <span class="meta">Verified against issuer T&Cs</span>
      </div>
      <h2>Favourite cards.</h2>
      <p>Reviewed against UAE eligibility, not US norms. Every card checked against the issuer's published Schedule of Charges.</p>
      <div class="hp-cards-pills">
        {filters.map((p) => (
          <a href={p.href} class="dp-filter-pill">{p.label}</a>
        ))}
      </div>
    </div>

    <div class="hp-cards-grid">
      {favouriteCards.map((c) => (
        <a href={`/cards/${c.slug}/`} class="hp-card-cell">
          <div class="dp-cr-mock" data-bank={c.bank} aria-hidden="true">
            <div class="dp-cr-mock-chip"></div>
            <div class="dp-cr-mock-row">
              <div class="b">{c.bank}</div>
              <div class="dp-cr-mock-mark">{c.network.slice(0, 1)}</div>
            </div>
            <div class="n">{c.name}</div>
            <div class="b">{c.network}</div>
          </div>
          <div class="hp-card-meta">
            <span class="eyebrow">Review</span>
            <span class="title">{c.name}</span>
            <span class="specs">
              AED {c.annualFee.toLocaleString()}/yr ·
              AED {(c.eligibility?.minSalary ?? 0).toLocaleString()}/mo min
            </span>
          </div>
        </a>
      ))}
    </div>

    <div class="dp-page-nav">
      <a href="/cards/" class="more-link">All reviewed cards →</a>
    </div>
  </section>

  <!-- ── 6. Newsletter band ───────────────────────────────────────────── -->
  <section class="hp-news-band">
    <div class="inner">
      <span class="eyebrow">The DubaiPoints brief</span>
      <h2>Friday morning, in your inbox.</h2>
      <p>One email each Friday with the week's salary-transfer changes, new card offers, miles redemptions worth knowing about, and lifestyle deals. AED-first, no fluff.</p>
      <div class="cta">
        <a href="/newsletter/" class="btn primary">Subscribe</a>
        <a href="/rss.xml" class="btn ghost">RSS feeds</a>
      </div>
      <p class="micro">
        We never sell email addresses or browsing data. <a href="/editorial-policy/">Editorial policy</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  /* Homepage-specific glue. The design-handoff classes (.dp-pagehead,
     .dp-featured-band, .dp-feed, .dp-cr-mock, .dp-filter-pill) come from
     global.css. This file extends the hero and adds two homepage-only
     bands (cards spotlight + newsletter). */

  .dp-pagehead.is-hero {
    background: linear-gradient(to bottom, var(--shade-1) 0%, var(--paper) 100%);
    padding: 88px 32px 64px;
    text-align: center;
  }
  .dp-pagehead.is-hero h1 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(36px, 6.2vw, 72px);
    line-height: 1.02;
    letter-spacing: -1.6px;
    color: var(--ink);
    text-wrap: balance;
    margin: 0 auto 20px;
    max-width: 18ch;
  }
  .dp-pagehead.is-hero p {
    max-width: 56ch;
    margin: 0 auto;
    font-size: clamp(16px, 1.5vw, 18px);
    line-height: 1.6;
    color: var(--ink-soft);
    text-wrap: pretty;
  }
  .dp-pagehead.is-hero .meta-strip {
    margin: 32px auto 0;
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
    align-items: center;
    font-size: 13px;
    color: var(--ink-soft);
    padding: 10px 20px;
    border: 1px solid var(--line);
    background: var(--paper);
    border-radius: 999px;
  }
  .dp-pagehead.is-hero .meta-strip strong {
    color: var(--ink);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .dp-pagehead.is-hero .meta-strip .sep {
    width: 1px;
    height: 14px;
    background: var(--line);
  }
  .dp-pagehead.is-hero .meta-strip .live-link {
    display: inline-flex; align-items: center; gap: 6px;
    margin-left: 6px;
    padding-left: 14px;
    border-left: 1px solid var(--line);
    color: var(--green);
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
  }
  .dp-pagehead.is-hero .meta-strip .live-link .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--green);
    animation: hp-pulse 2.4s ease-in-out infinite;
  }
  @keyframes hp-pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }
  @media (prefers-reduced-motion: reduce) {
    .dp-pagehead.is-hero .meta-strip .live-link .dot { animation: none; }
  }
  @media (max-width: 768px) {
    .dp-pagehead.is-hero { padding: 56px 20px 40px; }
    .dp-pagehead.is-hero .meta-strip {
      flex-direction: column;
      gap: 8px;
      border-radius: 14px;
      padding: 14px 18px;
    }
    .dp-pagehead.is-hero .meta-strip .sep { display: none; }
    .dp-pagehead.is-hero .meta-strip .live-link {
      margin-left: 0;
      padding-left: 0;
      border-left: 0;
      padding-top: 6px;
      border-top: 1px solid var(--line);
      width: 100%;
      justify-content: center;
    }
  }

  /* Decorative section divider — Fraunces-flavoured ornament */
  .dp-section-divider {
    display: flex; align-items: center; justify-content: center;
    gap: 14px;
    max-width: 1180px;
    margin: 0 auto;
    padding: 32px 32px 0;
  }
  .dp-section-divider .rule {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--line) 40%, var(--line) 60%, transparent);
    max-width: 280px;
  }
  .dp-section-divider .dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .dp-section-divider { padding: 24px 20px 0; gap: 10px; }
    .dp-section-divider .rule { max-width: 100px; }
  }

  /* "More stories" link styling */
  .dp-page-nav .more-link {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.5px;
    color: var(--green);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: border-color 0.15s ease;
  }
  .dp-page-nav .more-link:hover {
    border-bottom-color: var(--green);
  }

  /* Cards spotlight band */
  .hp-cards-band {
    background: var(--shade-1);
    padding: 56px 32px 64px;
    margin-top: 40px;
  }
  .hp-cards-head {
    max-width: 1180px;
    margin: 0 auto 32px;
  }
  .hp-cards-head h2 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(28px, 4vw, 42px);
    letter-spacing: -1px;
    color: var(--ink);
    margin: 8px 0 12px;
  }
  .hp-cards-head p {
    max-width: 60ch;
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 24px;
  }
  .hp-cards-pills {
    display: flex; flex-wrap: wrap; gap: 8px;
  }
  .hp-cards-grid {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
  }
  .hp-card-cell {
    display: grid; gap: 14px;
    text-decoration: none;
    transition: transform 0.15s ease;
  }
  .hp-card-cell:hover { transform: translateY(-2px); }
  .hp-card-cell .dp-cr-mock { max-width: none; }
  .hp-card-meta { display: grid; gap: 4px; padding: 0 4px; }
  .hp-card-meta .eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--green);
  }
  .hp-card-meta .title {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: -0.3px;
    color: var(--ink);
  }
  .hp-card-meta .specs {
    font-size: 12px;
    color: var(--ink-soft);
    font-variant-numeric: tabular-nums;
  }

  /* Newsletter band — green CTA */
  .hp-news-band {
    background: linear-gradient(135deg, var(--green) 0%, #1f5240 100%);
    color: white;
    padding: 64px 32px 72px;
    margin-top: 40px;
    position: relative;
    overflow: hidden;
  }
  .hp-news-band::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 80% 30%, rgba(255,255,255,0.08), transparent 50%),
      radial-gradient(circle at 20% 80%, rgba(255,255,255,0.06), transparent 45%);
    pointer-events: none;
  }
  .hp-news-band .inner {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }
  .hp-news-band .eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: rgba(255,255,255,0.7);
    display: inline-block; margin-bottom: 16px;
  }
  .hp-news-band h2 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(28px, 4.5vw, 44px);
    letter-spacing: -1px;
    color: white;
    margin: 0 0 14px;
    text-wrap: balance;
  }
  .hp-news-band p {
    font-size: 16px;
    line-height: 1.55;
    color: rgba(255,255,255,0.85);
    max-width: 56ch;
    margin: 0 auto 28px;
  }
  .hp-news-band .cta {
    display: flex; gap: 12px; justify-content: center;
    flex-wrap: wrap;
  }
  .hp-news-band .btn {
    display: inline-flex; align-items: center;
    height: 44px;
    padding: 0 22px;
    border-radius: 999px;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px; font-weight: 700;
    letter-spacing: 0.5px;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .hp-news-band .btn.primary {
    background: white;
    color: var(--green);
  }
  .hp-news-band .btn.primary:hover {
    background: var(--paper);
  }
  .hp-news-band .btn.ghost {
    background: transparent;
    color: white;
    border: 1px solid rgba(255,255,255,0.4);
  }
  .hp-news-band .btn.ghost:hover {
    background: rgba(255,255,255,0.10);
  }
  .hp-news-band .micro {
    margin-top: 24px;
    font-size: 12px;
    color: rgba(255,255,255,0.65);
  }
  .hp-news-band .micro a {
    color: white;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  @media (max-width: 768px) {
    .hp-cards-band, .hp-news-band { padding: 40px 20px; }
  }
</style>
