---
import BaseLayout from "~/layouts/BaseLayout.astro";
import HomepageTrackerSummary from "~/components/HomepageTrackerSummary.astro";
import { getCollection } from "astro:content";

// ── Live data ────────────────────────────────────────────────────────────
const todayMs = Date.now();
const allDeals = await getCollection("deals");
const liveDeals = allDeals
  .filter((d) => d.data.expiresOn.getTime() >= todayMs)
  .sort((a, b) => a.data.expiresOn.getTime() - b.data.expiresOn.getTime())
  .slice(0, 5);

const allGuides = await getCollection("guides");
const guidesSorted = [...allGuides].sort(
  (a, b) => b.data.updatedAt.getTime() - a.data.updatedAt.getTime(),
);
const latestGuide = guidesSorted[0];
const evergreenGuides = guidesSorted.slice(0, 4);

const allCards = await getCollection("cards");
const cardSpotlights = allCards
  .filter((c) => c.data.welcomeBonus)
  .sort(
    (a, b) =>
      (b.data.welcomeBonusValue ?? 0) - (a.data.welcomeBonusValue ?? 0),
  )
  .slice(0, 3);

// Recent posts feed — interleave guides + deals
type FeedItem = {
  href: string;
  category: string;
  title: string;
  date: Date;
};
const feed: FeedItem[] = [
  ...allGuides.map((g) => ({
    href: `/guides/${g.id}/`,
    category: "Guide",
    title: g.data.title,
    date: g.data.updatedAt,
  })),
  ...allDeals.map((d) => ({
    href: `/deals/${d.id}/`,
    category: "Deal",
    title: d.data.title,
    date: d.data.expiresOn,
  })),
];
const recentPosts = feed
  .sort((a, b) => b.date.getTime() - a.date.getTime())
  .slice(0, 6);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
---

<BaseLayout
  title="DubaiPoints — UAE Miles, Deals & Banking Hacks"
  description="Independent UAE-resident-led guides to credit cards, salary-transfer bonuses, miles redemptions and lifestyle deals. Every figure in AED, every card checked."
  fullWidth={true}
>

<style>
/* ════════════════════════════════════════════════════════════════════════
   MOBILE-FIRST HOMEPAGE — SITE_ARCHITECTURE.md §4
   Default styles target ≤640px (one-handed portrait). Breakpoints scale up.
   ════════════════════════════════════════════════════════════════════════ */

/* ── Layout primitives ────────────────────────────────────────────────── */
.wrap {
  width: 100%;
  max-width: 1180px;
  margin: 0 auto;
  padding-inline: 16px;
}
@media (min-width: 768px) { .wrap { padding-inline: 24px; } }
@media (min-width: 1024px) { .wrap { padding-inline: 32px; } }

.section { padding-block: 40px; }
@media (min-width: 768px) { .section { padding-block: 56px; } }
@media (min-width: 1024px) { .section { padding-block: 72px; } }

.section-band {
  background: var(--paper);
  border-block: 1px solid var(--line);
}

.section-head {
  display: flex; align-items: baseline; justify-content: space-between;
  gap: 16px; margin-bottom: 20px;
  padding-bottom: 12px; border-bottom: 1px solid var(--line);
}
.section-head h2 {
  font-family: 'Fraunces', serif; font-weight: 500;
  font-size: clamp(22px, 4vw, 28px);
  letter-spacing: -0.5px; color: var(--ink);
  text-wrap: balance;
}
.section-head h2 em { font-style: italic; color: var(--brand); font-weight: 500; }
.section-head .more {
  font-size: 13px; font-weight: 600; color: var(--ink);
  white-space: nowrap;
}
.section-head .more:hover { color: var(--brand); }

/* ── 1. HERO + Today's Best Deals rail ─────────────────────────────── */
.hero {
  padding-block: 32px 24px;
  text-align: left;
}
@media (min-width: 768px) { .hero { padding-block: 56px 40px; text-align: center; } }

.hero .eyebrow {
  font-size: 11px; font-weight: 700; letter-spacing: 2.5px;
  text-transform: uppercase; color: var(--brand); margin-bottom: 14px;
}
.hero h1 {
  font-family: 'Fraunces', serif; font-weight: 400;
  font-size: clamp(32px, 8vw, 60px);
  line-height: 1.05; letter-spacing: -1.4px;
  color: var(--ink); text-wrap: balance;
}
.hero h1 em { font-style: italic; color: var(--brand); font-weight: 500; }
.hero .sub {
  margin-top: 16px;
  font-family: 'Fraunces', serif; font-weight: 400;
  font-size: clamp(16px, 2.4vw, 22px);
  line-height: 1.4; color: var(--ink-soft);
  letter-spacing: -0.2px; text-wrap: pretty;
  max-width: 65ch;
}
@media (min-width: 768px) { .hero .sub { margin-inline: auto; } }

/* Today's Best Deals — horizontal scroll-snap rail */
.deals-rail-wrap {
  margin-top: 28px;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
  padding-block: 20px;
}
.deals-rail-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14px; gap: 12px;
}
.deals-rail-head .label {
  font-size: 10px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--red);
  display: flex; align-items: center; gap: 8px;
}
.deals-rail-head .label::before {
  content: ''; width: 6px; height: 6px; border-radius: 50%;
  background: var(--red); animation: pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
.deals-rail-head .more { font-size: 12px; font-weight: 600; color: var(--ink); }

.deals-rail {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 78%;
  gap: 12px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  margin-inline: -16px;
  padding-inline: 16px;
  padding-bottom: 6px;
}
.deals-rail::-webkit-scrollbar { display: none; }
@media (min-width: 640px) { .deals-rail { grid-auto-columns: 46%; } }
@media (min-width: 1024px) {
  .deals-rail {
    grid-auto-flow: initial;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-inline: 0; padding-inline: 0;
    overflow: visible;
  }
}

.deal-card {
  scroll-snap-align: start;
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 16px;
  display: flex; flex-direction: column;
  min-height: 140px;
  transition: border-color 0.15s;
}
.deal-card:hover { border-color: var(--brand); }
.deal-card .meta {
  display: flex; gap: 8px; align-items: center; margin-bottom: 10px;
  font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase;
}
.deal-card .meta .cat { color: var(--brand); }
.deal-card .meta .dot { color: var(--line); }
.deal-card .meta .expiry { color: var(--red); }
.deal-card h3 {
  font-family: 'Fraunces', serif; font-weight: 500;
  font-size: 16px; line-height: 1.3; color: var(--ink);
  letter-spacing: -0.2px; flex: 1;
}
.deal-card .verified {
  margin-top: 12px;
  font-size: 11px; color: var(--muted);
}

/* ── 2. LATEST POST (single feature) ───────────────────────────────── */
.latest-feature {
  display: grid; grid-template-columns: 1fr; gap: 20px;
}
@media (min-width: 768px) {
  .latest-feature { grid-template-columns: 1.3fr 1fr; gap: 40px; align-items: center; }
}
.latest-feature-img {
  aspect-ratio: 16 / 10; border-radius: 8px;
  background: linear-gradient(135deg, #d9cfb8, #a89372);
  position: relative; overflow: hidden;
}
.latest-feature-img::after {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.25), transparent 55%);
}
.latest-feature-img .pin {
  position: absolute; top: 14px; left: 14px;
  background: rgba(255,255,255,0.92);
  padding: 5px 11px; border-radius: 30px;
  font-size: 10px; font-weight: 700;
  letter-spacing: 1.5px; text-transform: uppercase; color: var(--ink);
}
.latest-feature .kicker {
  font-size: 10px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--red); margin-bottom: 12px;
}
.latest-feature h2 {
  font-family: 'Fraunces', serif; font-weight: 500;
  font-size: clamp(24px, 4.5vw, 36px);
  line-height: 1.12; letter-spacing: -0.8px;
  color: var(--ink); margin-bottom: 14px; text-wrap: balance;
}
.latest-feature .lede {
  font-size: 15px; color: var(--ink-soft); line-height: 1.55;
  margin-bottom: 16px; max-width: 60ch;
}
.byline {
  display: flex; flex-wrap: wrap; gap: 8px; align-items: center;
  font-size: 12px; color: var(--muted);
}
.byline .name { color: var(--ink); font-weight: 600; }
.byline .verified-badge {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 3px 9px; border-radius: 30px;
  background: var(--gold-soft); color: var(--gold);
  font-size: 10px; font-weight: 700; letter-spacing: 0.5px;
  text-transform: uppercase;
}
.byline .sep { color: var(--line); }

/* ── 3. NEW TO THE UAE? band ──────────────────────────────────────── */
.expat-band {
  background: var(--ink);
  color: white;
  border-radius: 0;
}
.expat-band .wrap {
  display: grid; grid-template-columns: 1fr; gap: 20px;
  padding-block: 40px;
}
@media (min-width: 768px) {
  .expat-band .wrap {
    grid-template-columns: 1fr auto;
    align-items: center; gap: 40px;
    padding-block: 48px;
  }
}
.expat-band .eyebrow {
  font-size: 11px; font-weight: 700; letter-spacing: 2.5px;
  text-transform: uppercase; color: var(--brand); margin-bottom: 12px;
}
.expat-band h2 {
  font-family: 'Fraunces', serif; font-weight: 500;
  font-size: clamp(24px, 4vw, 34px);
  line-height: 1.15; letter-spacing: -0.6px;
  color: white; margin-bottom: 12px; text-wrap: balance;
}
.expat-band p {
  font-size: 15px; color: rgba(255,255,255,0.78);
  line-height: 1.55; max-width: 60ch;
}
.expat-band .cta {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 22px;
  background: var(--brand); color: white;
  border-radius: 6px;
  font-size: 14px; font-weight: 700;
  letter-spacing: 0.2px;
  white-space: nowrap;
  min-height: 44px;
  transition: background 0.15s;
}
.expat-band .cta:hover { background: var(--brand-deep); }

/* ── 4. SALARY TRANSFER tracker preview ──────────────────────────── */
.tracker-section .head {
  display: flex; flex-direction: column; gap: 6px;
  margin-bottom: 16px;
  padding-bottom: 12px; border-bottom: 1px solid var(--line);
}
@media (min-width: 768px) {
  .tracker-section .head {
    flex-direction: row; align-items: flex-end; justify-content: space-between;
    gap: 24px;
  }
}
.tracker-section .eyebrow {
  font-size: 10px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--red);
  display: flex; align-items: center; gap: 8px;
}
.tracker-section .eyebrow::before {
  content: ''; width: 6px; height: 6px; border-radius: 50%;
  background: var(--red); animation: pulse 2s infinite;
}
.tracker-section h2 {
  font-family: 'Fraunces', serif; font-weight: 500;
  font-size: clamp(22px, 4vw, 28px);
  letter-spacing: -0.5px; color: var(--ink);
}
.tracker-section .cta {
  font-size: 13px; font-weight: 600; color: var(--ink);
  border: 1px solid var(--ink);
  padding: 10px 16px; border-radius: 6px;
  min-height: 44px;
  display: inline-flex; align-items: center;
  transition: all 0.15s;
}
.tracker-section .cta:hover { background: var(--ink); color: white; }

/* ── 5. CARD SPOTLIGHTS ──────────────────────────────────────────── */
.cards-grid {
  display: grid; grid-template-columns: 1fr; gap: 16px;
}
@media (min-width: 640px) { .cards-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .cards-grid { grid-template-columns: repeat(3, 1fr); } }

.card-spot {
  border: 1px solid var(--line); border-radius: 8px;
  padding: 20px;
  background: var(--bg);
  display: flex; flex-direction: column;
  transition: border-color 0.15s;
}
.card-spot:hover { border-color: var(--brand); }
.card-spot .super {
  font-size: 10px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--brand); margin-bottom: 10px;
}
.card-spot .visual {
  aspect-ratio: 1.6 / 1; border-radius: 6px;
  background: linear-gradient(135deg, #1a1f2e, #0d1119);
  margin-bottom: 16px; padding: 14px;
  display: flex; align-items: flex-end;
  position: relative; overflow: hidden;
}
.card-spot .visual::after {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(circle at 20% 20%, rgba(255,255,255,0.15), transparent 60%);
}
.card-spot .visual .bank-name {
  font-family: 'Fraunces', serif; font-weight: 600; font-size: 16px;
  color: rgba(255,255,255,0.95); letter-spacing: -0.2px;
  position: relative; z-index: 1;
}
.card-spot h3 {
  font-family: 'Fraunces', serif; font-weight: 500;
  font-size: 18px; letter-spacing: -0.3px;
  color: var(--ink); line-height: 1.25; margin-bottom: 12px;
}
.card-spot .bonus {
  background: var(--paper); border: 1px solid var(--line);
  border-radius: 5px; padding: 10px 12px; margin-bottom: 14px;
}
.card-spot .bonus .num {
  font-family: 'Fraunces', serif; font-weight: 600;
  font-size: 22px; color: var(--ink);
  letter-spacing: -0.5px; line-height: 1;
}
.card-spot .bonus .lbl {
  font-size: 11px; color: var(--muted); margin-top: 4px;
}
.card-spot .req {
  font-size: 12px; color: var(--ink-soft); flex: 1; margin-bottom: 14px;
  line-height: 1.5;
}
.card-spot .apply {
  text-align: center; padding: 12px;
  background: var(--ink); color: white;
  border-radius: 5px;
  font-size: 13px; font-weight: 600;
  min-height: 44px;
  display: flex; align-items: center; justify-content: center;
}
.card-spot .apply:hover { background: var(--brand); }

/* ── 6. RECENT POSTS feed ───────────────────────────────────────── */
.feed {
  display: grid; grid-template-columns: 1fr; gap: 0;
}
.feed-item {
  display: grid;
  grid-template-columns: 1fr;
  gap: 4px;
  padding-block: 18px;
  border-bottom: 1px solid var(--line);
}
@media (min-width: 768px) {
  .feed-item {
    grid-template-columns: 110px 1fr auto;
    gap: 24px; align-items: center;
    padding-block: 22px;
  }
}
.feed-item:hover h3 { color: var(--brand); }
.feed-item .cat {
  font-size: 10px; font-weight: 700; letter-spacing: 2px;
  text-transform: uppercase; color: var(--red);
}
.feed-item h3 {
  font-family: 'Fraunces', serif; font-weight: 500;
  font-size: 17px; line-height: 1.3; color: var(--ink);
  letter-spacing: -0.2px; text-wrap: balance;
}
.feed-item .date {
  font-size: 12px; color: var(--muted);
}

/* ── 7. EVERGREEN guides ─────────────────────────────────────────── */
.evergreen-grid {
  display: grid; grid-template-columns: 1fr; gap: 14px;
}
@media (min-width: 640px) { .evergreen-grid { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 1024px) { .evergreen-grid { grid-template-columns: repeat(4, 1fr); } }

.evergreen-card {
  background: var(--paper); border: 1px solid var(--line);
  border-radius: 6px; padding: 18px;
  display: flex; flex-direction: column; gap: 8px;
  min-height: 130px;
  transition: border-color 0.15s;
}
.evergreen-card:hover { border-color: var(--brand); }
.evergreen-card .num {
  font-family: 'Fraunces', serif; font-weight: 500; font-size: 26px;
  color: var(--brand); letter-spacing: -0.6px; line-height: 1;
}
.evergreen-card h4 {
  font-family: 'Fraunces', serif; font-weight: 500;
  font-size: 16px; letter-spacing: -0.2px; color: var(--ink);
  line-height: 1.3; flex: 1;
}
.evergreen-card .date {
  font-size: 11px; color: var(--muted);
}

/* ── 8. NEWSLETTER ─────────────────────────────────────────────── */
.newsletter {
  background: var(--paper);
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 28px 20px;
  display: grid; grid-template-columns: 1fr; gap: 20px;
}
@media (min-width: 768px) {
  .newsletter {
    grid-template-columns: 1fr 1fr;
    gap: 40px; align-items: center;
    padding: 40px;
  }
}
.newsletter h2 {
  font-family: 'Fraunces', serif; font-weight: 500;
  font-size: clamp(22px, 4vw, 28px);
  letter-spacing: -0.5px; color: var(--ink);
  margin-bottom: 8px; text-wrap: balance;
}
.newsletter h2 em { font-style: italic; color: var(--brand); font-weight: 500; }
.newsletter p { font-size: 14px; color: var(--ink-soft); line-height: 1.55; }
.nl-form { display: flex; flex-direction: column; gap: 10px; }
.nl-form .row { display: flex; gap: 8px; flex-direction: column; }
@media (min-width: 480px) { .nl-form .row { flex-direction: row; } }
.nl-form input {
  flex: 1; padding: 14px 16px;
  border: 1px solid var(--line); border-radius: 5px;
  font-size: 16px; /* prevent iOS zoom */
  font-family: inherit; background: var(--bg);
  outline: none; min-height: 44px;
  transition: border-color 0.15s;
}
.nl-form input:focus { border-color: var(--brand); }
.nl-form button {
  padding: 14px 20px;
  background: var(--ink); color: white;
  border: none; border-radius: 5px;
  font-size: 14px; font-weight: 600;
  font-family: inherit; cursor: pointer;
  min-height: 44px;
  transition: background 0.15s;
}
.nl-form button:hover { background: var(--brand); }
.nl-form .meta { font-size: 11px; color: var(--muted); }
.nl-form .wa-cta {
  display: inline-flex; align-items: center; gap: 8px;
  margin-top: 4px; padding: 10px 12px;
  border: 1px solid var(--line);
  border-radius: 5px;
  font-size: 13px; font-weight: 600;
  color: var(--ink);
  background: transparent;
  transition: border-color 0.15s, background 0.15s;
  align-self: flex-start;
}
.nl-form .wa-cta:hover { border-color: #25d366; background: rgba(37, 211, 102, 0.06); }
.nl-form .wa-cta svg { width: 16px; height: 16px; color: #25d366; flex-shrink: 0; }
</style>

<!-- ── 1. HERO + TODAY'S BEST DEALS ─────────────────────────────────── -->
<section class="section hero">
  <div class="wrap">
    <div class="eyebrow">UAE rewards · banking · travel — decoded</div>
    <h1>Make every <em>dirham</em> work harder.</h1>
    <p class="sub">Independent UAE-resident-led analysis of credit cards, salary-transfer bonuses, miles redemptions, and lifestyle deals — every figure in AED, every card checked against UAE eligibility rules.</p>

    <div class="deals-rail-wrap">
      <div class="deals-rail-head">
        <span class="label">Today's best deals</span>
        <a class="more" href="/deals/">All deals →</a>
      </div>

      <div class="deals-rail" role="list">
        {liveDeals.length === 0 && (
          <div class="deal-card" role="listitem">
            <div class="meta"><span class="cat">Coming soon</span></div>
            <h3>New deals are verified daily — check back tomorrow morning.</h3>
            <div class="verified">Last verified: {fmtDate(new Date())}</div>
          </div>
        )}
        {liveDeals.map((d) => (
          <a href={`/deals/${d.id}/`} class="deal-card" role="listitem">
            <div class="meta">
              <span class="cat">{d.data.category.replace("-", " ")}</span>
              <span class="dot">·</span>
              <span class="expiry">Ends {fmtDate(d.data.expiresOn)}</span>
            </div>
            <h3>{d.data.title}</h3>
            <div class="verified">Last verified: {fmtDate(new Date())}</div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ── 2. LATEST POST ─────────────────────────────────────────────── -->
{latestGuide && (
  <section class="section section-band">
    <div class="wrap">
      <div class="section-head">
        <h2>Latest analysis</h2>
        <a class="more" href="/guides/">All guides →</a>
      </div>
      <a href={`/guides/${latestGuide.id}/`} class="latest-feature">
        <div class="latest-feature-img">
          <span class="pin">Editor's Pick</span>
        </div>
        <div>
          <div class="kicker">Guide · UAE</div>
          <h2>{latestGuide.data.title}</h2>
          <p class="lede">{latestGuide.data.description}</p>
          <div class="byline">
            <span class="name">DubaiPoints Editorial</span>
            <span class="sep">·</span>
            <span>{fmtDate(latestGuide.data.publishedAt)}</span>
            <span class="sep">·</span>
            <span class="verified-badge">Verified {fmtDate(latestGuide.data.updatedAt)}</span>
          </div>
        </div>
      </a>
    </div>
  </section>
)}

<!-- ── 3. NEW TO THE UAE? ─────────────────────────────────────────── -->
<section class="expat-band">
  <div class="wrap">
    <div>
      <div class="eyebrow">New to the UAE?</div>
      <h2>Start with the Expat Starter Guide.</h2>
      <p>Choosing your first card, opening a UAE bank account, salary transfer mechanics, and the points-and-miles basics — written for newcomers, no fluff.</p>
    </div>
    <a href="/guides/expat-starter/" class="cta">Open the guide →</a>
  </div>
</section>

<!-- ── 4. SALARY TRANSFER summary (top 3 by reward) ───────────────── -->
<section class="section tracker-section">
  <div class="wrap">
    <div class="head">
      <div>
        <span class="eyebrow">Live offers · top 3 by reward</span>
        <h2>UAE salary transfer offers</h2>
      </div>
    </div>
    <HomepageTrackerSummary />
  </div>
</section>

<!-- ── 5. CARD SPOTLIGHTS ─────────────────────────────────────────── -->
{cardSpotlights.length > 0 && (
  <section class="section section-band">
    <div class="wrap">
      <div class="section-head">
        <h2>Top UAE card offers this month</h2>
        <a class="more" href="/cards/">Compare all →</a>
      </div>
      <div class="cards-grid">
        {cardSpotlights.map((c, i) => (
          <a href={`/cards/${c.id}/`} class="card-spot">
            <div class="super">
              {i === 0 ? "Best welcome bonus" : c.data.categories[0] ? `Best for ${c.data.categories[0]}` : "Featured"}
            </div>
            <div class="visual">
              <span class="bank-name">{c.data.name}</span>
            </div>
            <h3>{c.data.name}</h3>
            <div class="bonus">
              <div class="num">{c.data.welcomeBonus}</div>
              <div class="lbl">Welcome offer</div>
            </div>
            <div class="req">
              Min salary AED {c.data.eligibility.minSalary.toLocaleString()}
              {c.data.eligibility.salaryTransferRequired && " · Salary transfer required"}
            </div>
            <span class="apply">View card →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ── 6. RECENT POSTS ────────────────────────────────────────────── -->
<section class="section">
  <div class="wrap">
    <div class="section-head">
      <h2>This week on DubaiPoints</h2>
      <a class="more" href="/guides/">All posts →</a>
    </div>
    <div class="feed">
      {recentPosts.map((p) => (
        <a href={p.href} class="feed-item">
          <span class="cat">{p.category}</span>
          <h3>{p.title}</h3>
          <span class="date">{fmtDate(p.date)}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ── 7. EVERGREEN guides ────────────────────────────────────────── -->
{evergreenGuides.length > 0 && (
  <section class="section section-band">
    <div class="wrap">
      <div class="section-head">
        <h2>Most-read guides</h2>
        <a class="more" href="/guides/">All guides →</a>
      </div>
      <div class="evergreen-grid">
        {evergreenGuides.map((g, i) => (
          <a href={`/guides/${g.id}/`} class="evergreen-card">
            <div class="num">{String(i + 1).padStart(2, "0")}</div>
            <h4>{g.data.title}</h4>
            <span class="date">Updated {fmtDate(g.data.updatedAt)}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<!-- ── 8. NEWSLETTER (email or WhatsApp) ──────────────────────────── -->
