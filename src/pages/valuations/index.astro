---
// Valuations — Phase C tools template (Claude Design handoff).
// Reference: dubaipoints/project/templates/tools.jsx::Valuations.
// DP values mirror the published programme-page baselines; rows with
// no published baseline are "Pending" until the DP-value methodology
// lands (Q3 2026 per EDITORIAL.md).

import BaseLayout from "~/layouts/BaseLayout.astro";

interface Programme {
  name: string;
  currencyName: string;
  mark: string;
  floor: number | null;
  ceiling: number | null;
  dpValue: number | null;
  delta90: string;
  status: "Active" | "Pending" | "Under review";
}

// DP values carry only the baselines actually published in the
// programme overviews (and used by card reviews) — see
// .council/sops/value-to-me-convention.md. The earlier illustrative
// figures here (Skywards 3.5, Etihad 2.8, …) contradicted the 2-fil
// baseline the reviews cite; a reader cross-checking a review against
// this page got a different number (Fact-Checker redline, 11 June
// 2026). Floor/ceiling ranges and 90-day deltas return when the
// methodology lands (Q3 2026) — they are not published until they
// can be traced.
const programmes: Programme[] = [
  { name: "Emirates",         currencyName: "Skywards",         mark: "SKY", floor: null, ceiling: null, dpValue: 2.0,  delta90: "—", status: "Active" },
  { name: "Etihad",           currencyName: "Guest",            mark: "ETI", floor: null, ceiling: null, dpValue: 2.0,  delta90: "—", status: "Active" },
  { name: "Qatar",            currencyName: "Avios",            mark: "QR",  floor: null, ceiling: null, dpValue: 3.0,  delta90: "—", status: "Active" },
  { name: "British Airways",  currencyName: "Avios",            mark: "BA",  floor: null, ceiling: null, dpValue: null, delta90: "—", status: "Pending" },
  { name: "Marriott",         currencyName: "Bonvoy",           mark: "MAR", floor: null, ceiling: null, dpValue: 2.5,  delta90: "—", status: "Active" },
  { name: "IHG",              currencyName: "One Rewards",      mark: "IHG", floor: null, ceiling: null, dpValue: null, delta90: "—", status: "Pending" },
  { name: "Hilton",           currencyName: "Honors",           mark: "HIL", floor: null, ceiling: null, dpValue: 1.5,  delta90: "—", status: "Active" },
  { name: "flydubai",         currencyName: "OPEN",             mark: "FZ",  floor: null, ceiling: null, dpValue: null, delta90: "—", status: "Pending" },
  { name: "Wizz Air",         currencyName: "Discount Club",    mark: "W6",  floor: null, ceiling: null, dpValue: null, delta90: "—", status: "Pending" },
  { name: "Air Arabia",       currencyName: "Airewards",        mark: "G9",  floor: null, ceiling: null, dpValue: null, delta90: "—", status: "Pending" },
];

// Date the published baselines were last confirmed against the
// programme overview pages — NOT the build date. A build-date stamp
// here manufactured freshness for numbers that hadn't moved.
const baselinesConfirmed = new Date("2026-06-10");
const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });

const distributionPct = (p: Programme): number => {
  if (p.dpValue == null || p.floor == null || p.ceiling == null) return 0;
  if (p.ceiling === p.floor) return 50;
  return ((p.dpValue - p.floor) / (p.ceiling - p.floor)) * 100;
};
---

<BaseLayout
  title="UAE points & miles valuations | DubaiPoints"
  description="What each UAE-relevant loyalty currency is worth in fils per point. DP-value is the rate we use in card reviews. Floor (worst-case) and ceiling (premium-cabin sweet spot) bracket the realistic range."
  fullWidth
>
  <div class="dp-pagehead">
    <div class="crumb">DubaiPoints / Valuations</div>
    <h1>Points &amp; miles valuations</h1>
    <p>What each UAE-relevant loyalty currency is actually worth, in fils per point. <strong>Floor</strong> = worst-case redemption (economy cash-vs-points on the programme's own metal). <strong>Ceiling</strong> = premium-cabin sweet spot on partner award space, on routes UAE residents fly. <strong>DP value</strong> is what we use in our own card reviews.</p>

    <div class="dp-tools-stats">
      <span><span class="lbl">Programmes tracked:</span> <strong>{programmes.length}</strong></span>
      <span><span class="lbl">Baselines confirmed:</span> <strong>{fmt(baselinesConfirmed)}</strong></span>
      <span><span class="lbl">Methodology:</span> <strong style="color: var(--link);"><a href="/editorial-policy/">Read →</a></strong></span>
    </div>
  </div>

  <div class="dp-toolbar" aria-label="Table scope" style="justify-content: space-between;">
    <span style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 13px; color: var(--ink-soft);">
      Showing <strong style="color: var(--ink); font-weight: 600;">{programmes.length}</strong> UAE-relevant programmes
    </span>
    <span style="font-family: 'DM Sans', system-ui, sans-serif; font-size: 13px; color: var(--ink-soft);">
      Sorted by <strong style="color: var(--ink); font-weight: 600;">DP value</strong>
    </span>
  </div>

  <div class="dp-tools-table-wrap">
    <table class="dp-tools-table">
      <thead>
        <tr>
          <th style="width: 30%;">Programme</th>
          <th>Floor (fils)</th>
          <th>Ceiling (fils)</th>
          <th class="sort-active">DP value (fils) ▼</th>
          <th style="width: 200px;">Distribution</th>
          <th>Δ 90d</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {programmes.map((p) => (
          <tr>
            <td>
              <div class="bank-cell">
                <div class="bank-mark">{p.mark}</div>
                <div>
                  <div class="bank-name">{p.name}</div>
                  <div class="bank-tier">{p.currencyName}</div>
                </div>
              </div>
            </td>
            <td class="num">{p.floor ?? "—"}</td>
            <td class="num">{p.ceiling ?? "—"}</td>
            <td class="num"><strong style="font-size: 15px;">{p.dpValue ?? "—"}</strong></td>
            <td>
              {p.dpValue != null && p.floor != null && p.ceiling != null ? (
                <div class="dp-val-bar">
                  <span style={`width: ${Math.max(15, distributionPct(p))}%;`}></span>
                </div>
              ) : (
                <span style="font-size: 11px; color: var(--muted);">{p.dpValue != null ? "range pending methodology" : "under review"}</span>
              )}
            </td>
            <td class={p.delta90.startsWith("+") ? "delta-up" : p.delta90.startsWith("-") ? "delta-down" : ""}>{p.delta90}</td>
            <td>
              <span class={p.status === "Active" ? "status-active" : "status-paused"} style={p.status === "Pending" ? "color: var(--muted);" : ""}>● {p.status}</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <section class="dp-tools-methodology">
    <div class="col">
      <div class="lbl">Floor</div>
      <p>Worst-case redemption — economy cash-vs-points on the programme's own metal, taxes / fuel surcharges in.</p>
    </div>
    <div class="col">
      <div class="lbl">Ceiling</div>
      <p>Sweet-spot — premium cabin on partner award space, on routes UAE residents actually fly (DXB / AUH / SHJ outbound).</p>
    </div>
    <div class="col">
      <div class="lbl">DP value</div>
      <p>The baseline published in each programme's overview page and used for every earn-rate calculation in card reviews — a deliberately conservative cost-basis figure. Floor/ceiling ranges land with the methodology page, Q3 2026 per editorial calendar.</p>
    </div>
  </section>

  <div class="dp-tools-actions">
    <span><a href="/editorial-policy/">Methodology (draft)</a> · Programmes drawn from /airlines/ collection</span>
    <span><a href="/airlines/">Programme guides →</a></span>
  </div>
</BaseLayout>
