---
// Valuations — Phase C tools template (Claude Design handoff).
// Reference: dubaipoints/project/templates/tools.jsx::Valuations.
// Placeholder data until DP-value methodology lands (Q3 2026 per
// EDITORIAL.md). Each row is flagged "draft" so readers know the
// numbers are illustrative until the methodology page goes live.

import BaseLayout from "~/layouts/BaseLayout.astro";

interface Programme {
  name: string;
  currencyName: string;
  mark: string;
  floor: number | null;
  ceiling: number | null;
  dpValue: number | null;
  delta90: string;
  status: "Active" | "Pending" | "Under review";
}

// Draft valuations — illustrative until methodology lands.
const programmes: Programme[] = [
  { name: "Emirates",         currencyName: "Skywards",         mark: "SKY", floor: 3.2, ceiling: 3.8, dpValue: 3.5, delta90: "+0.2", status: "Active" },
  { name: "Etihad",           currencyName: "Guest",            mark: "ETI", floor: 2.6, ceiling: 3.2, dpValue: 2.8, delta90: "-0.3", status: "Active" },
  { name: "Qatar",            currencyName: "Avios",            mark: "QR",  floor: 2.9, ceiling: 3.4, dpValue: 3.0, delta90: "—",    status: "Active" },
  { name: "British Airways",  currencyName: "Avios",            mark: "BA",  floor: 3.0, ceiling: 3.6, dpValue: 3.1, delta90: "+0.1", status: "Active" },
  { name: "Marriott",         currencyName: "Bonvoy",           mark: "MAR", floor: 2.4, ceiling: 2.9, dpValue: 2.5, delta90: "—",    status: "Active" },
  { name: "IHG",              currencyName: "One Rewards",      mark: "IHG", floor: 1.7, ceiling: 2.2, dpValue: 1.9, delta90: "—",    status: "Active" },
  { name: "Hilton",           currencyName: "Honors",           mark: "HIL", floor: 1.2, ceiling: 1.6, dpValue: 1.4, delta90: "-0.1", status: "Active" },
  { name: "flydubai",         currencyName: "OPEN",             mark: "FZ",  floor: 1.8, ceiling: 2.4, dpValue: 2.0, delta90: "—",    status: "Active" },
  { name: "Wizz Air",         currencyName: "Discount Club",    mark: "W6",  floor: null, ceiling: null, dpValue: null, delta90: "—", status: "Pending" },
  { name: "Air Arabia",       currencyName: "Airewards",        mark: "G9",  floor: 1.5, ceiling: 2.1, dpValue: 1.7, delta90: "—",    status: "Active" },
];

const today = new Date();
const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });

const distributionPct = (p: Programme): number => {
  if (p.dpValue == null || p.floor == null || p.ceiling == null) return 0;
  if (p.ceiling === p.floor) return 50;
  return ((p.dpValue - p.floor) / (p.ceiling - p.floor)) * 100;
};
---

<BaseLayout
  title="Points & miles valuations — UAE-relevant programmes"
  description="What each UAE-relevant loyalty currency is worth in fils per point. DP-value is the rate we use in card reviews. Floor (worst-case) and ceiling (premium-cabin sweet spot) bracket the realistic range."
  fullWidth
>
  <div class="dp-pagehead">
    <div class="crumb">DubaiPoints / Tools / Valuations</div>
    <h1>Points &amp; miles valuations</h1>
    <p>What each UAE-relevant loyalty currency is actually worth, in fils per point. <strong>Floor</strong> = worst-case redemption (economy cash-vs-points on the programme's own metal). <strong>Ceiling</strong> = premium-cabin sweet spot on partner award space, on routes UAE residents fly. <strong>DP value</strong> is what we use in our own card reviews.</p>

    <div class="dp-tools-stats">
      <span><span class="lbl">Programmes tracked:</span> <strong>{programmes.length}</strong></span>
      <span><span class="lbl">Last revalued:</span> <strong>{fmt(today)}</strong></span>
      <span><span class="lbl">Methodology:</span> <strong style="color: var(--link);"><a href="/editorial-policy/">Read →</a></strong></span>
    </div>
  </div>

  <div class="dp-toolbar">
    <div class="dp-toolbar-input">Search programmes</div>
    <div class="dp-toolbar-select">Type: All</div>
    <div class="dp-toolbar-select">Region: UAE-relevant</div>
    <div class="dp-toolbar-reset">Sort: by DP value ▾</div>
  </div>

  <div class="dp-tools-table-wrap">
    <table class="dp-tools-table">
      <thead>
        <tr>
          <th style="width: 30%;">Programme</th>
          <th>Floor (fils)</th>
          <th>Ceiling (fils)</th>
          <th class="sort-active">DP value (fils) ▼</th>
          <th style="width: 200px;">Distribution</th>
          <th>Δ 90d</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {programmes.map((p) => (
          <tr>
            <td>
              <div class="bank-cell">
                <div class="bank-mark">{p.mark}</div>
                <div>
                  <div class="bank-name">{p.name}</div>
                  <div class="bank-tier">{p.currencyName}</div>
                </div>
              </div>
            </td>
            <td class="num">{p.floor ?? "—"}</td>
            <td class="num">{p.ceiling ?? "—"}</td>
            <td class="num"><strong style="font-size: 15px;">{p.dpValue ?? "—"}</strong></td>
            <td>
              {p.dpValue != null ? (
                <div class="dp-val-bar">
                  <span style={`width: ${Math.max(15, distributionPct(p))}%;`}></span>
                </div>
              ) : (
                <span style="font-size: 11px; color: var(--muted);">under review</span>
              )}
            </td>
            <td class={p.delta90.startsWith("+") ? "delta-up" : p.delta90.startsWith("-") ? "delta-down" : ""}>{p.delta90}</td>
            <td>
              <span class={p.status === "Active" ? "status-active" : "status-paused"} style={p.status === "Pending" ? "color: var(--muted);" : ""}>● {p.status}</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <section class="dp-tools-methodology">
    <div class="col">
      <div class="lbl">Floor</div>
      <p>Worst-case redemption — economy cash-vs-points on the programme's own metal, taxes / fuel surcharges in.</p>
    </div>
    <div class="col">
      <div class="lbl">Ceiling</div>
      <p>Sweet-spot — premium cabin on partner award space, on routes UAE residents actually fly (DXB / AUH / SHJ outbound).</p>
    </div>
    <div class="col">
      <div class="lbl">DP value</div>
      <p>Our weighted blend used for every earn-rate calculation in card reviews. Recalibrated quarterly. Methodology page lands Q3 2026 per editorial calendar.</p>
    </div>
  </section>

  <div class="dp-tools-actions">
    <span><a href="/editorial-policy/">Methodology (draft)</a> · Programmes drawn from /airlines/ collection</span>
    <span><a href="/airlines/">Programme guides →</a></span>
  </div>
</BaseLayout>
