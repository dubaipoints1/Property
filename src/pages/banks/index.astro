---
// Banks index — section-index template (Phase B1 cascade).
// Reference: PR #34 + dubaipoints/project/templates/chrome.jsx::SectionIndex.

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const banks = (await getCollection("banks")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);

const featured = banks.slice(0, 7);
const remaining = banks.slice(7);

const filters = [
  { label: "All", active: true },
  { label: "Cards by issuer", href: "/cards/" },
  { label: "Salary transfer", href: "/salary-transfer/" },
  { label: "Compare", href: "/cards/compare/" },
];
---

<BaseLayout
  title="UAE banks — directory"
  description="Every UAE bank we cover, with a hub page each: salary-transfer offer, card lineup, and reward currencies."
  fullWidth
>
  <div class="dp-pagehead">
    <div class="crumb">DubaiPoints / Banks</div>
    <h1>Banks</h1>
    <p>A hub for each bank we cover — salary-transfer offer, card lineup, reward currency, and reputation notes in one place.</p>
  </div>

  <div class="dp-filters">
    {filters.map((f) => (
      f.active
        ? <span class="dp-filter-pill is-active">{f.label}</span>
        : <a href={f.href} class="dp-filter-pill">{f.label}</a>
    ))}
    <span class="dp-sort">Sort: <strong>A–Z</strong> ▾</span>
  </div>

  {featured.length > 0 && (
    <section class="dp-featured-band">
      <div class="dp-featured-eyebrow">
        <span>UAE bank coverage</span>
        <span class="rule"></span>
        <span class="meta">{banks.length} bank{banks.length === 1 ? "" : "s"} covered</span>
      </div>
      <div class="dp-featured-grid">
        {featured[0] && (
          <a href={`/banks/${featured[0].id}/`} class="dp-story-card hero">
            <div class="cover">{featured[0].data.name}</div>
            <div class="body">
              <div class="meta"><span class="cat">UAE Bank</span><span>{featured[0].data.cards.length} card{featured[0].data.cards.length === 1 ? "" : "s"}</span></div>
              <h3>{featured[0].data.name}</h3>
              {featured[0].data.customerService.website && (
                <p>{new URL(featured[0].data.customerService.website).hostname}</p>
              )}
              <div class="by">Bank hub</div>
            </div>
          </a>
        )}
        {[featured[1], featured[2]].filter(Boolean).map((b) => (
          <a href={`/banks/${b.id}/`} class="dp-story-card med">
            <div class="cover">{b.data.name}</div>
            <div class="body">
              <div class="meta"><span class="cat">UAE Bank</span></div>
              <h3>{b.data.name}</h3>
              {b.data.customerService.website && (
                <p>{new URL(b.data.customerService.website).hostname}</p>
              )}
            </div>
          </a>
        ))}
        {featured.slice(3, 7).map((b) => (
          <a href={`/banks/${b.id}/`} class="dp-story-card sm">
            <div class="cover">{b.data.name}</div>
            <div class="body">
              <div class="meta"><span class="cat">UAE Bank</span></div>
              <h3>{b.data.name}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <div class="dp-pullquote">
    <div class="mark">"</div>
    <blockquote>
      Every bank covered with the same scrutiny — Schedule of Charges, salary-transfer terms, and AECB friction in one place.
    </blockquote>
    <div class="attr"><span class="rule"></span>Editorial standard · est. 2026</div>
  </div>

  {remaining.length > 0 && (
    <>
      <div class="dp-list-head">
        <div class="t">All banks</div>
        <div class="m">A–Z · {remaining.length} more</div>
      </div>
      <div class="dp-feed">
        {remaining.map((b, i) => {
          const n = i + featured.length + 1;
          return (
            <a href={`/banks/${b.id}/`} class="dp-feed-row">
              <div>
                <div class="num">{String(n).padStart(2, "0")}</div>
                <div class="feed-eyebrow">UAE Bank</div>
              </div>
              <div>
                <h3>{b.data.name}</h3>
                {b.data.customerService.website && (
                  <div class="summary">{new URL(b.data.customerService.website).hostname}</div>
                )}
              </div>
              <div class="thumb">{b.data.name.split(" ").map((w) => w[0]).slice(0, 3).join("")}</div>
              <div class="when">Hub →</div>
            </a>
          );
        })}
      </div>
    </>
  )}

  <div class="dp-page-nav">
    <span style="font-size:12px;color:var(--muted);">Showing all {banks.length} bank{banks.length === 1 ? "" : "s"}</span>
  </div>
</BaseLayout>
