---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const banks = (await getCollection("banks")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout
  title="UAE banks — directory"
  description="Every UAE bank we cover, with a hub page each: salary-transfer offers, card lineup, and reward currencies."
  fullWidth
>
  <article class="dp-article is-wide">
    <header class="dp-article-head">
      <p class="dp-article-eyebrow">Banks</p>
      <h1 class="dp-article-title">UAE banks.</h1>
      <p class="dp-article-lede">A hub for each bank we cover — salary-transfer offer, card lineup, reward currency, and reputation notes in one place.</p>
    </header>

    <div class="dp-dir-grid">
      {banks.map((b) => (
        <a href={`/banks/${b.id}/`} class="dp-dir-tile">
          <span class="eyebrow">UAE Bank</span>
          <span class="title">{b.data.name}</span>
          {b.data.customerService.website && (
            <span class="meta">{new URL(b.data.customerService.website).hostname}</span>
          )}
        </a>
      ))}
    </div>
  </article>
</BaseLayout>
