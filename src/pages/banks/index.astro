---
// Banks directory — Phase F.16 rebuild (Head-of-UX audit, May 2026).
// Migrated from the legacy dp-pagehead + dp-featured-band template
// (which assumed 7+ featured + a remaining "feed" — incoherent for a
// 5-bank set) onto the same intel-* idiom as /guides/, /news/,
// /airlines/, /deals/, /cards/. Each bank now reads as a tile in a
// flat scannable grid, with the salary-transfer tracker promoted in
// the sidebar where the reader expects "next action".

import BaseLayout from "~/layouts/BaseLayout.astro";
import StockImage from "~/components/StockImage.astro";
import { getCollection } from "astro:content";
import { getActiveCards } from "~/lib/cardsData";

const banks = (await getCollection("banks")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);

// Card counts per bank — pulled from L2 (cards.json) since the bank
// frontmatter `cards: []` is stale on most banks.
const cards = getActiveCards();
const cardCountByBank = new Map<string, number>();
for (const c of cards) {
  cardCountByBank.set(c.bank, (cardCountByBank.get(c.bank) ?? 0) + 1);
}

// Featured bank = the one with the most reviewed cards (today: ENBD
// by a wide margin). Falls back to A–Z first if counts tie.
const sortedByCardCount = [...banks].sort(
  (a, b) =>
    (cardCountByBank.get(b.id) ?? 0) - (cardCountByBank.get(a.id) ?? 0),
);
const featured = sortedByCardCount[0];
const others = banks.filter((b) => b.id !== featured?.id);

const tabs = [
  { label: "All banks", active: true, href: "/banks/" },
  { label: "Salary-transfer tracker", href: "/salary-transfer/" },
];
---

<BaseLayout
  title="UAE banks — directory"
  description="Every UAE bank we cover, with a hub page each: salary-transfer offer, card lineup, and reward currencies."
  fullWidth
>
  <header class="intel-pagehead">
    <div class="intel-pagehead-inner">
      <div class="crumb">DubaiPoints / Banks</div>
      <h1>UAE banks.</h1>
      <p>A hub page for each bank we cover — salary-transfer offer, card lineup, reward currency, and reputation notes in one place. {banks.length} banks tracked.</p>

      <div class="intel-tools">
        <div class="intel-tabs" role="tablist">
          {tabs.map((t) => (
            t.active
              ? <span class="intel-tab is-active" role="tab" aria-selected="true">{t.label}</span>
              : <a href={t.href} class="intel-tab" role="tab">{t.label}</a>
          ))}
        </div>
        <form class="intel-search" action="/" method="get" role="search">
          <label class="intel-search-label" for="banks-search-input">Search</label>
          <label for="banks-search-input" class="intel-search-icon" aria-hidden="true">
            <svg viewBox="0 0 20 20" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="9" r="6"/>
              <line x1="13.5" y1="13.5" x2="17.5" y2="17.5" stroke-linecap="round"/>
            </svg>
          </label>
          <input
            id="banks-search-input"
            type="search"
            name="q"
            placeholder="Search banks…"
            autocomplete="off"
          />
        </form>
      </div>
    </div>
  </header>

  <div class="intel-grid">
    <main class="intel-main">
      {featured && (
        <a href={`/banks/${featured.id}/`} class="intel-featured">
          <StockImage
            slug={`bank-${featured.id}`}
            coverTitle={featured.data.name}
            coverCategory="Programme"
            coverSize="hero"
            class="intel-featured-image"
            loading="eager"
            sizes="(max-width: 900px) 100vw, 66vw"
          />
          <div class="intel-featured-body">
            <span class="intel-featured-eyebrow">Most-covered issuer · UAE bank</span>
            <h2>{featured.data.name}</h2>
            <p>Cards, rewards currency and salary-transfer offer for {featured.data.name} — every figure cross-checked against the issuer's published Schedule of Charges.</p>
            <span class="intel-featured-meta">
              {cardCountByBank.get(featured.id) ?? 0} card{(cardCountByBank.get(featured.id) ?? 0) === 1 ? "" : "s"} reviewed · Open the bank hub →
            </span>
          </div>
        </a>
      )}

      {others.length > 0 && (
        <ul class="intel-card-grid">
          {others.map((b) => {
            const count = cardCountByBank.get(b.id) ?? 0;
            return (
              <li class="intel-card-item">
                <a href={`/banks/${b.id}/`} class="intel-card">
                  <StockImage
                    slug={`bank-${b.id}`}
                    coverTitle={b.data.name}
                    coverCategory="Programme"
                    coverSize="med"
                    class="intel-card-image"
                    sizes="(max-width: 900px) 100vw, 33vw"
                  />
                  <div class="intel-card-body">
                    <span class="intel-card-cat">UAE bank</span>
                    <h3>{b.data.name}</h3>
                    <p>{count > 0 ? `${count} card${count === 1 ? "" : "s"} reviewed` : "Salary-transfer offer + bank hub"}</p>
                    <span class="intel-card-meta">Open hub →</span>
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </main>

    <aside class="intel-aside">
      <nav class="intel-trending" aria-label="Bank tools">
        <h4>Bank tools</h4>
        <ol>
          <li>
            <span class="num">01</span>
            <a href="/salary-transfer/">Salary-transfer tracker</a>
          </li>
          <li>
            <span class="num">02</span>
            <a href="/salary-transfer/calculator/">Salary-transfer calculator</a>
          </li>
          <li>
            <span class="num">03</span>
            <a href="/cards/compare/">Compare cards side-by-side</a>
          </li>
          <li>
            <span class="num">04</span>
            <a href="/guides/expat-starter-banking-basics/">Expat banking basics</a>
          </li>
          <li>
            <span class="num">05</span>
            <a href="/guides/uae-credit-card-eligibility-2026/">UAE eligibility &amp; AECB</a>
          </li>
        </ol>
      </nav>

      <div class="intel-insider">
        <span class="eyebrow">Insider Intel</span>
        <h4>Friday morning, in your inbox.</h4>
        <p>One email each Friday — salary-transfer changes, new card offers, miles redemptions worth knowing about.</p>
        <a href="/newsletter/" class="cta">Subscribe →</a>
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  /* Shared with /guides/, /news/, /airlines/, /deals/. Inlined per
     surface for evolution independence; lift to a shared
     ArticleIndexLayout once the five stabilise. */
  .intel-pagehead {
    background: var(--paper);
    padding: 48px 32px 32px;
    border-bottom: 1px solid var(--line);
  }
  .intel-pagehead-inner { max-width: 1180px; margin: 0 auto; }
  .intel-pagehead .crumb {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--green);
    margin-bottom: 16px;
  }
  .intel-pagehead h1 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(38px, 5.6vw, 58px);
    letter-spacing: -1.6px;
    line-height: 1.04;
    color: var(--green);
    margin: 0 0 14px;
  }
  .intel-pagehead p {
    max-width: 62ch;
    font-size: 15px; line-height: 1.6;
    color: var(--ink-soft);
    margin: 0 0 28px;
  }
  .intel-tools {
    display: flex; flex-wrap: wrap;
    gap: 16px 24px;
    align-items: center;
    justify-content: space-between;
  }
  .intel-tabs { display: flex; flex-wrap: wrap; gap: 6px; }
  .intel-tab {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px; font-weight: 600; letter-spacing: 0.2px;
    color: var(--ink-soft);
    padding: 8px 14px;
    border-radius: 999px;
    background: transparent;
    border: 1px solid transparent;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
    cursor: pointer;
  }
  .intel-tab:hover { background: var(--shade-1); color: var(--ink); }
  .intel-tab.is-active { background: var(--ink); color: var(--paper); cursor: default; }

  .intel-search {
    display: flex; align-items: center;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0 14px;
    height: 36px;
    min-width: 220px;
    transition: border-color 0.15s ease;
  }
  .intel-search:focus-within { border-color: var(--ink-soft); }
  .intel-search-label {
    position: absolute; width: 1px; height: 1px;
    overflow: hidden; clip: rect(0,0,0,0);
  }
  .intel-search input[type="search"] {
    border: 0; background: transparent; outline: none;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    color: var(--ink);
    width: 100%;
  }
  .intel-search input[type="search"]::placeholder { color: var(--muted); }
  .intel-search-icon {
    display: none;
    align-items: center; justify-content: center;
    color: var(--ink-soft);
    cursor: pointer;
    flex-shrink: 0;
  }

  .intel-grid {
    max-width: 1180px;
    margin: 32px auto 56px;
    padding: 0 32px;
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: 40px;
    align-items: start;
  }
  .intel-main { display: grid; gap: 28px; }

  .intel-featured {
    display: grid; grid-template-rows: auto 1fr;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none; color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }
  .intel-featured:hover {
    transform: translateY(-2px);
    border-color: var(--ink-soft);
    box-shadow: 0 20px 40px -20px rgba(15, 31, 46, 0.22);
  }
  .intel-featured :global(.intel-featured-image) {
    width: 100%; aspect-ratio: 16 / 9;
    object-fit: cover; display: block;
    border-bottom: 1px solid var(--line);
  }
  .intel-featured :global(svg.dp-cover) {
    width: 100%; display: block;
    border-bottom: 1px solid var(--line);
  }
  .intel-featured-body { padding: 24px 28px 28px; display: grid; gap: 10px; }
  .intel-featured-eyebrow {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--green);
  }
  .intel-featured-body h2 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: clamp(24px, 3.4vw, 34px);
    letter-spacing: -0.9px;
    line-height: 1.12;
    color: var(--ink);
    margin: 0;
    text-wrap: balance;
  }
  .intel-featured:hover h2 { color: var(--green); }
  .intel-featured-body p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
    max-width: 64ch;
  }
  .intel-featured-meta {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.3px;
    margin-top: 4px;
  }

  .intel-card-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }
  .intel-card-item { display: block; }
  .intel-card {
    display: grid; grid-template-rows: auto 1fr;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none; color: inherit;
    height: 100%;
    transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .intel-card:hover {
    transform: translateY(-2px);
    border-color: var(--ink-soft);
    box-shadow: 0 14px 28px -16px rgba(15, 31, 46, 0.18);
  }
  .intel-card :global(.intel-card-image) {
    width: 100%; aspect-ratio: 3 / 2;
    object-fit: cover; display: block;
    border-bottom: 1px solid var(--line);
  }
  .intel-card :global(svg.dp-cover) {
    width: 100%; display: block;
    border-bottom: 1px solid var(--line);
  }
  .intel-card-body { padding: 18px 20px 20px; display: grid; gap: 8px; }
  .intel-card-cat {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--green);
  }
  .intel-card h3 {
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: -0.3px;
    line-height: 1.25;
    color: var(--ink);
    margin: 0;
    text-wrap: balance;
  }
  .intel-card:hover h3 { color: var(--green); }
  .intel-card-body p {
    font-size: 13px; line-height: 1.5;
    color: var(--ink-soft); margin: 0;
  }
  .intel-card-meta {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 11px; color: var(--muted);
    letter-spacing: 0.2px; margin-top: 2px;
  }

  .intel-aside { display: flex; flex-direction: column; gap: 20px; }
  @media (min-width: 1024px) {
    .intel-aside { position: sticky; top: 32px; align-self: flex-start; }
  }
  .intel-trending {
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 22px;
  }
  .intel-trending h4 {
    font-family: 'DM Sans', sans-serif;
    font-size: 11px; letter-spacing: 2.5px;
    text-transform: uppercase; color: var(--green);
    margin: 0 0 14px; font-weight: 700;
  }
  .intel-trending ol { list-style: none; padding: 0; margin: 0; }
  .intel-trending li {
    padding: 10px 0;
    border-bottom: 1px solid var(--line-soft);
    font-size: 13px; color: var(--ink-soft);
    display: flex; gap: 12px;
    line-height: 1.35;
  }
  .intel-trending li:last-child { border-bottom: 0; }
  .intel-trending .num {
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    font-size: 11px; min-width: 20px;
    flex-shrink: 0; font-weight: 700;
    letter-spacing: 1px;
  }
  .intel-trending a {
    color: var(--ink);
    font-family: 'Fraunces', serif;
    font-weight: 500; letter-spacing: -0.2px;
    text-decoration: none;
  }
  .intel-trending a:hover { color: var(--green); }

  .intel-insider {
    background: var(--green);
    color: white;
    border-radius: 16px;
    padding: 22px;
    display: grid; gap: 8px;
  }
  .intel-insider .eyebrow {
    font-family: 'DM Sans', sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: rgba(255, 255, 255, 0.75);
  }
  .intel-insider h4 {
    font-family: 'Fraunces', serif;
    font-weight: 500; font-size: 19px;
    line-height: 1.2; letter-spacing: -0.4px;
    color: white; margin: 0;
    text-wrap: balance;
  }
  .intel-insider p {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px; line-height: 1.5;
    color: rgba(255, 255, 255, 0.88);
    margin: 4px 0 6px;
  }
  .intel-insider .cta {
    display: inline-flex; align-items: center;
    height: 36px; padding: 0 16px;
    background: white; color: var(--green);
    border-radius: 999px;
    font-family: 'DM Sans', sans-serif;
    font-size: 12px; font-weight: 700; letter-spacing: 0.4px;
    text-decoration: none; align-self: start;
    transition: opacity 0.15s ease;
  }
  .intel-insider .cta:hover { opacity: 0.88; }

  @media (max-width: 1023px) {
    .intel-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .intel-pagehead { padding: 32px 20px 24px; }
    .intel-grid { padding: 0 20px; margin-top: 24px; gap: 28px; }
    .intel-card-grid { grid-template-columns: 1fr; }
    /* F-UX-4: tabs + icon-only search share one row at <640px.
       Search expands to a full-width pill when focused. */
    .intel-tools {
      flex-direction: row;
      flex-wrap: nowrap;
      align-items: center;
      gap: 8px;
    }
    .intel-tabs { flex: 1 1 auto; min-width: 0; gap: 4px; }
    .intel-tab { padding: 6px 10px; font-size: 12px; }
    .intel-search:not(:only-child) {
      min-width: 36px;
      width: 36px;
      flex: 0 0 36px;
      height: 36px;
      padding: 0;
      justify-content: center;
      transition: width 0.18s ease, flex-basis 0.18s ease, padding 0.18s ease;
    }
    .intel-search:not(:only-child) .intel-search-icon {
      display: inline-flex; width: 36px; height: 36px;
    }
    .intel-search:not(:only-child) input[type="search"] {
      width: 0; padding: 0;
      transition: width 0.18s ease, padding 0.18s ease;
    }
    .intel-search:not(:only-child):focus-within {
      width: 100%; flex: 1 1 100%; padding: 0 14px;
    }
    .intel-search:not(:only-child):focus-within .intel-search-icon { display: none; }
    .intel-search:not(:only-child):focus-within input[type="search"] { width: 100%; }
    .intel-search:only-child { width: 100%; min-width: 0; flex: 1 1 100%; }
  }
</style>
