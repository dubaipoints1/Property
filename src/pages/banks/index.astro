---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const banks = (await getCollection("banks")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout
  title="UAE banks — directory"
  description="All the UAE banks we cover, with a link to each bank's dedicated hub: salary transfer offers, cards, and reward currencies."
>
  <header class="border-b border-slate-200 pb-6">
    <h1 class="text-3xl font-semibold text-slate-900">UAE banks</h1>
    <p class="mt-2 text-slate-700">Hubs for each bank we cover.</p>
  </header>

  <ul class="mt-6 grid gap-3 sm:grid-cols-2">
    {
      banks.map((b) => (
        <li>
          <a
            href={`/banks/${b.id}/`}
            class="block rounded-md border border-slate-200 bg-white p-4 no-underline hover:border-brand-500"
          >
            <h2 class="font-semibold text-slate-900">{b.data.name}</h2>
            {b.data.customerService.website && (
              <p class="mt-1 truncate text-xs text-slate-500">
                {b.data.customerService.website}
              </p>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
