---
// Design spike — Quiet Ledger direction (recommended).
// Standalone route at /design-spike/. All styles are scoped to this page.
// Pagefind is asked to skip via data-pagefind-ignore on the wrapper.
//
// Sections:
//   1. Hero — masthead-dateline + 5-story typographic index
//   2. Card grid — 40 placeholder cards, generated inline
//   3. Editorial block — eyebrow + headline + lede + section + Our take
//
// No changes to src/styles/global.css.

import BaseLayout from "~/layouts/BaseLayout.astro";

const today = new Date().toLocaleDateString("en-GB", {
  weekday: "long", year: "numeric", month: "long", day: "numeric",
});

// 5-story typographic index for the masthead
const indexStories = [
  {
    cat: "Salary transfer",
    title: "FAB lifts AED 50k+ payout to AED 4,000 — limited to 30 June",
    meta: "Filed 7 May",
  },
  {
    cat: "Card review",
    title: "Emirates Skywards Infinite — earns Skywards Miles, but not enough of them",
    meta: "Verified 3 May",
  },
  {
    cat: "Deal",
    title: "Cinnabon UAE 2-for-1 boxes — runs through May, no app required",
    meta: "Ends 31 May",
  },
  {
    cat: "Programme",
    title: "Etihad Guest devalues partner redemptions on Lufthansa Group",
    meta: "Filed 5 May",
  },
  {
    cat: "Guide",
    title: "Opening a UAE bank account: what AECB looks at, and what it doesn't",
    meta: "Updated 30 Apr",
  },
];

// 40 placeholder cards — Array.from per spec.
// Mix of bank names, fees, salary thresholds, and value figures so the
// grid stress-tests typography, not the homepage's curated 3-card view.
const banks = ["FAB", "Emirates NBD", "ADCB", "Mashreq", "ENBD", "RAKBANK", "Citi", "HSBC", "ADIB", "DIB", "CBD", "SCB"];
const tiers = ["Infinite", "Signature", "Platinum", "World Elite", "Cashback", "Gold", "Premium"];
const cards = Array.from({ length: 40 }).map((_, i) => {
  const bank = banks[i % banks.length];
  const tier = tiers[(i * 3) % tiers.length];
  const annualFee = [0, 199, 350, 500, 750, 1500][i % 6];
  const minSalary = [5000, 8000, 12000, 15000, 20000, 30000, 50000][i % 7];
  const value = 800 + ((i * 173) % 4200); // pseudo-random AED/year value
  const verified = ["3 May", "29 Apr", "21 Apr", "5 Apr", "12 Apr"][i % 5];
  const stale = i % 7 === 6;
  return {
    bank,
    name: `${bank} ${tier}`,
    annualFee,
    minSalary,
    value,
    verified,
    stale,
  };
});
---

<BaseLayout
  title="Design spike — Quiet Ledger"
  description="UX redesign spike for dubaipoints.ae — recommended direction."
  fullWidth={true}
>

<style>
  /* ════════════════════════════════════════════════════════════════════
     QUIET LEDGER — scoped tokens for this spike only.
     These intentionally shadow some `--*` properties from global.css so
     this page reads in the new palette without touching the global file.
     ════════════════════════════════════════════════════════════════════ */
  .ql-root {
    --ql-paper:    #ffffff;
    --ql-bg:       #ffffff;
    --ql-ink:      #0d1117;
    --ql-ink-soft: #5a6068;
    --ql-muted:    #8a8f9a;
    --ql-line:     #e3e3e1;
    --ql-line-soft:#f1f1ef;
    --ql-link:     #2a6bd1;
    --ql-signal:   #c8412d;
    --ql-stale:    #8a6a14;

    background: var(--ql-paper);
    color: var(--ql-ink);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-feature-settings: "tnum" 1, "lnum" 1; /* tabular figures */
  }

  .ql-wrap {
    width: 100%;
    max-width: 1180px;
    margin: 0 auto;
    padding-inline: 16px;
  }
  @media (min-width: 768px)  { .ql-wrap { padding-inline: 24px; } }
  @media (min-width: 1024px) { .ql-wrap { padding-inline: 32px; } }

  /* ── Section 1 — Masthead-dateline + typographic index ─────────────── */
  .ql-masthead {
    border-bottom: 1px solid var(--ql-ink);
    padding-block: 20px 14px;
  }
  .ql-mast-row {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px; flex-wrap: wrap;
  }
  .ql-mast-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--ql-ink);
  }
  .ql-mast-date {
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.4px;
    color: var(--ql-ink-soft);
  }
  .ql-mast-spike {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--ql-signal);
  }

  .ql-hero {
    padding-block: 36px 28px;
    border-bottom: 1px solid var(--ql-line);
  }
  @media (min-width: 1024px) {
    .ql-hero { padding-block: 56px 40px; }
  }
  .ql-hero h1 {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: clamp(34px, 6vw, 60px);
    line-height: 1.04; letter-spacing: -1.4px;
    color: var(--ql-ink);
    text-wrap: balance;
    max-width: 18ch;
  }
  .ql-hero .strap {
    margin-top: 14px;
    font-size: clamp(15px, 1.6vw, 17px);
    line-height: 1.55; color: var(--ql-ink-soft);
    max-width: 60ch;
  }

  /* The 5-story typographic index — replaces hero imagery */
  .ql-index {
    margin-top: 32px;
    border-top: 1px solid var(--ql-ink);
    padding-top: 18px;
  }
  .ql-index-head {
    font-size: 10px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--ql-ink);
    margin-bottom: 14px;
  }
  .ql-index-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .ql-index-item {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4px;
    padding: 16px 0;
    border-bottom: 1px solid var(--ql-line);
  }
  @media (min-width: 768px) {
    .ql-index-item {
      grid-template-columns: 130px 1fr 110px;
      gap: 24px; align-items: baseline;
      padding: 18px 0;
    }
  }
  .ql-index-cat {
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--ql-ink-soft);
  }
  .ql-index-title {
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: clamp(18px, 2.4vw, 22px);
    line-height: 1.25; letter-spacing: -0.3px;
    color: var(--ql-ink); text-wrap: balance;
  }
  .ql-index-item:hover .ql-index-title {
    text-decoration: underline;
    text-decoration-color: var(--ql-link);
    text-underline-offset: 4px;
  }
  .ql-index-meta {
    font-size: 12px; color: var(--ql-muted);
    letter-spacing: 0.2px;
  }
  @media (min-width: 768px) {
    .ql-index-meta { text-align: right; }
  }

  /* ── Section 2 — Card grid ─────────────────────────────────────────── */
  .ql-grid-section {
    padding-block: 48px 64px;
    border-bottom: 1px solid var(--ql-line);
  }
  .ql-grid-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px; margin-bottom: 24px;
    border-bottom: 1px solid var(--ql-ink);
    padding-bottom: 12px;
  }
  .ql-grid-head h2 {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: clamp(22px, 3.2vw, 30px);
    letter-spacing: -0.6px; color: var(--ql-ink);
  }
  .ql-grid-head .meta {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--ql-ink-soft);
  }

  .ql-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid var(--ql-line);
  }
  @media (min-width: 640px)  { .ql-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .ql-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1280px) { .ql-grid { grid-template-columns: repeat(4, 1fr); } }

  .ql-tile {
    display: flex; flex-direction: column; gap: 10px;
    padding: 18px 18px 22px;
    border-right: 1px solid var(--ql-line);
    border-bottom: 1px solid var(--ql-line);
    background: var(--ql-paper);
    min-height: 200px;
    transition: background 0.12s;
    position: relative;
  }
  .ql-tile:hover { background: var(--ql-line-soft); }

  /* Right edge: kill the trailing border at the right edge of each row */
  @media (min-width: 1280px) {
    .ql-tile:nth-child(4n) { border-right: none; }
  }
  @media (min-width: 1024px) and (max-width: 1279.98px) {
    .ql-tile:nth-child(3n) { border-right: none; }
  }
  @media (min-width: 640px) and (max-width: 1023.98px) {
    .ql-tile:nth-child(2n) { border-right: none; }
  }
  @media (max-width: 639.98px) {
    .ql-tile { border-right: none; }
  }

  .ql-tile .bank {
    font-size: 10px; font-weight: 700;
    letter-spacing: 2px; text-transform: uppercase;
    color: var(--ql-ink-soft);
  }
  .ql-tile .name {
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: 18px; line-height: 1.25;
    letter-spacing: -0.3px; color: var(--ql-ink);
    text-wrap: balance;
  }
  .ql-tile:hover .name {
    text-decoration: underline;
    text-decoration-color: var(--ql-link);
    text-underline-offset: 3px;
  }

  /* The "value" figure — pull-number, replaces the gold welcome-bonus chip */
  .ql-tile .value {
    margin-top: 4px;
    display: flex; align-items: baseline; gap: 6px;
  }
  .ql-tile .value .num {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: 26px; line-height: 1;
    letter-spacing: -0.6px; color: var(--ql-ink);
  }
  .ql-tile .value .lbl {
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--ql-muted);
  }

  .ql-tile .specs {
    margin-top: auto;
    display: flex; flex-wrap: wrap; gap: 0 16px;
    padding-top: 12px;
    border-top: 1px solid var(--ql-line);
    font-size: 12px; color: var(--ql-ink-soft);
  }
  .ql-tile .specs dt {
    font-size: 10px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--ql-muted);
    margin-bottom: 2px;
  }
  .ql-tile .specs dd {
    margin: 0 0 4px;
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: 14px; color: var(--ql-ink);
    letter-spacing: -0.1px;
  }
  .ql-tile .specs > div { min-width: 90px; }

  .ql-tile .verified {
    position: absolute; top: 14px; right: 14px;
    font-size: 10px; font-weight: 700;
    letter-spacing: 1px; text-transform: uppercase;
    color: var(--ql-ink-soft);
  }
  .ql-tile .verified.is-stale { color: var(--ql-stale); }
  .ql-tile .verified::before {
    content: ''; display: inline-block;
    width: 6px; height: 6px; border-radius: 50%;
    background: currentColor; margin-right: 6px;
    vertical-align: 1px;
  }

  /* ── Section 3 — Editorial block ───────────────────────────────────── */
  .ql-article {
    max-width: 720px;
    margin: 0 auto;
    padding-block: 56px 80px;
  }
  .ql-art-eyebrow {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--ql-ink); /* black eyebrows — no gold, no italic accent */
    margin-bottom: 14px;
  }
  .ql-art-eyebrow .live {
    color: var(--ql-signal); margin-right: 8px;
  }
  .ql-art-title {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: clamp(30px, 5vw, 46px);
    line-height: 1.08; letter-spacing: -1.1px;
    color: var(--ql-ink); text-wrap: balance;
  }
  .ql-art-lede {
    margin-top: 16px;
    font-size: clamp(17px, 1.7vw, 19px);
    line-height: 1.55;
    color: var(--ql-ink-soft);
    max-width: 60ch;
    text-wrap: pretty;
  }
  .ql-art-meta {
    margin-top: 22px;
    padding-top: 14px;
    border-top: 1px solid var(--ql-line);
    display: flex; flex-wrap: wrap; gap: 12px;
    font-size: 12px; color: var(--ql-muted);
    letter-spacing: 0.2px;
  }
  .ql-art-meta strong { color: var(--ql-ink); font-weight: 600; }
  .ql-art-meta .sep { color: var(--ql-line); }

  .ql-art-section { margin-top: 36px; }
  .ql-art-section h2 {
    font-family: 'Fraunces', serif; font-weight: 600;
    font-size: clamp(22px, 3vw, 28px);
    letter-spacing: -0.5px; color: var(--ql-ink);
    margin-bottom: 14px;
  }
  .ql-art-section p {
    font-size: 17px; line-height: 1.7;
    color: var(--ql-ink-soft);
    max-width: 60ch;
    margin-bottom: 14px;
    text-wrap: pretty;
  }
  .ql-art-section a {
    color: var(--ql-ink); font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--ql-link);
    text-underline-offset: 3px;
  }
  .ql-art-section a:hover { color: var(--ql-link); }

  /* "Our take" — hairline-bordered block on white, red label.
     Replaces the gold-on-cream `.dp-take` callout. */
  .ql-take {
    margin-top: 28px;
    padding: 20px 22px 22px;
    border: 1px solid var(--ql-ink);
    background: var(--ql-paper);
  }
  .ql-take .label {
    font-size: 11px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--ql-signal);
    margin-bottom: 10px;
  }
  .ql-take p {
    font-family: 'Fraunces', serif; font-weight: 500;
    font-size: 19px; line-height: 1.5;
    color: var(--ql-ink); text-wrap: pretty;
    margin: 0; max-width: 56ch;
  }

  /* Spike-only banner so the owner sees this is not the live homepage */
  .ql-spike-banner {
    background: var(--ql-ink); color: white;
    padding: 10px 16px;
    font-size: 11px; font-weight: 700;
    letter-spacing: 1.5px; text-transform: uppercase;
    text-align: center;
  }
  .ql-spike-banner span { color: #b8b8b8; font-weight: 500; margin-left: 8px; }
</style>

<div class="ql-root" data-pagefind-ignore="true">

  <div class="ql-spike-banner">
    Design spike — Quiet Ledger
    <span>Recommended direction · not the live site</span>
  </div>

  <!-- ── 1. HERO + masthead-dateline + typographic index ─────────────── -->
  <section class="ql-hero">
    <div class="ql-wrap">

      <div class="ql-masthead">
        <div class="ql-mast-row">
          <span class="ql-mast-eyebrow">DubaiPoints</span>
          <span class="ql-mast-date">{today} · Dubai</span>
          <span class="ql-mast-spike">Live · salary transfer tracker</span>
        </div>
      </div>

      <h1>UAE rewards, banking, and travel — without the marketing.</h1>
      <p class="strap">
        Independent UAE-resident-led analysis of credit cards, salary-transfer
        bonuses, miles redemptions, and lifestyle deals — every figure in AED,
        every card checked against UAE eligibility rules.
      </p>

      <div class="ql-index">
        <div class="ql-index-head">In today's brief</div>
        <div class="ql-index-list">
          {indexStories.map((s) => (
            <a href="#" class="ql-index-item">
              <span class="ql-index-cat">{s.cat}</span>
              <span class="ql-index-title">{s.title}</span>
              <span class="ql-index-meta">{s.meta}</span>
            </a>
          ))}
        </div>
      </div>

    </div>
  </section>

  <!-- ── 2. CARD GRID — 40 placeholder tiles ─────────────────────────── -->
  <section class="ql-grid-section">
    <div class="ql-wrap">
      <div class="ql-grid-head">
        <h2>Every card we track</h2>
        <span class="meta">{cards.length} cards · sorted by AED value / year</span>
      </div>
      <div class="ql-grid">
        {cards.map((c) => (
          <a href="#" class="ql-tile">
            <span class={`verified${c.stale ? " is-stale" : ""}`}>
              {c.stale ? "Needs reverify" : `Verified ${c.verified}`}
            </span>
            <span class="bank">{c.bank}</span>
            <span class="name">{c.name}</span>

            <div class="value">
              <span class="num">AED {c.value.toLocaleString()}</span>
              <span class="lbl">/ year</span>
            </div>

            <dl class="specs">
              <div>
                <dt>Annual fee</dt>
                <dd>{c.annualFee === 0 ? "AED 0" : `AED ${c.annualFee.toLocaleString()}`}</dd>
              </div>
              <div>
                <dt>Min salary</dt>
                <dd>AED {c.minSalary.toLocaleString()}</dd>
              </div>
            </dl>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ── 3. EDITORIAL BLOCK ──────────────────────────────────────────── -->
  <article class="ql-article">

    <p class="ql-art-eyebrow">
      <span class="live">Live</span>
      Salary transfer · FAB
    </p>

    <h1 class="ql-art-title">
      FAB lifts AED 50k+ payout to AED 4,000 — but the eligibility window is short.
    </h1>

    <p class="ql-art-lede">
      First Abu Dhabi Bank's headline salary-transfer offer increased on 2 May
      from AED 3,000 to AED 4,000 for the AED 50,000+ band. The catch: the
      transfer must clear before 30 June, and only first-time FAB salary
      customers qualify.
    </p>

    <div class="ql-art-meta">
      <span>By <strong>DubaiPoints Editorial</strong></span>
      <span class="sep">·</span>
      <span>Filed 7 May 2026</span>
      <span class="sep">·</span>
      <span>Verified <strong>7 May 2026</strong></span>
    </div>

    <section class="ql-art-section">
      <h2>What changed</h2>
      <p>
        FAB's published salary-transfer schedule (last revised April 2026) paid
        AED 3,000 to customers transferring an AED 50k+ salary. The 2 May
        update raises that to AED 4,000 — a 33% lift, the largest single-band
        change in the bank's tracker history. Lower bands are unchanged: AED
        2,000 at 30k–50k, AED 1,000 at 15k–30k, AED 500 at 8k–15k.
      </p>
      <p>
        The eligibility rules are unchanged. Customers must be new to FAB
        salary transfer (existing FAB customers transferring for the first
        time qualify; existing salary customers do not). The salary must clear
        the FAB account on or before 30 June 2026, with the bonus credited
        within 60 days of the second salary deposit. <a href="#">FAB's
        scheduled rates page</a> remains the canonical source.
      </p>
    </section>

    <aside class="ql-take">
      <p class="label">Our take</p>
      <p>
        Worth taking if your salary lands in the top band and you do not
        already bank with FAB. AED 4,000 is the highest single salary-transfer
        payout in the UAE market this month. For everyone else, the lower
        bands are unchanged and ADCB or Mashreq still win on AED-per-AED.
      </p>
    </aside>

  </article>

</div>

</BaseLayout>
