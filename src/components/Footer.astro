---
// Footer — Claude Design (polished pass, July 2026)
// Improvements: better responsive grid, clickable email, newsletter CTA,
// social placeholder, stronger disclaimer, smoother hover states.

import { getCollection } from "astro:content";
import BankLogo from "~/components/BankLogo.astro";

const banks = (await getCollection("banks")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
const programs = await getCollection("programs");

const year = new Date().getFullYear();
---

<footer class="dp-footer">
  <div class="dp-footer-inner">
    <div class="dp-footer-top">
      <!-- Brand column: wordmark + tagline + newsletter CTA -->
      <div class="dp-footer-brand">
        <a href="/" class="dp-footer-wordmark" aria-label="DubaiPoints home">
          DubaiPoints<span class="dot">.</span>
        </a>
        <p class="dp-footer-tag">UAE rewards. Source-verified, AED-first.</p>
        <a href="/newsletter/" class="dp-footer-cta">
          Get the weekly digest
          <span class="dp-footer-cta-arrow" aria-hidden="true">→</span>
        </a>

        <!-- Social placeholder — add real URLs when ready -->
        <div class="dp-footer-social">
          <a href="#" aria-label="Twitter / X" class="dp-social-link">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a href="#" aria-label="LinkedIn" class="dp-social-link">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Salary transfer -->
      <div class="dp-footer-col">
        <div class="dp-footer-heading">Salary transfer</div>
        <ul>
          <li><a href="/salary-transfer/">Live tracker</a></li>
          <li><a href="/salary-transfer/calculator/">Calculator</a></li>
          <li><a href="/salary-transfer/aed-5000-to-8000/">AED 5,000 – 8,000</a></li>
          <li><a href="/salary-transfer/aed-8000-to-15000/">AED 8,000 – 15,000</a></li>
          <li><a href="/salary-transfer/aed-15000-to-30000/">AED 15,000 – 30,000</a></li>
          <li><a href="/salary-transfer/aed-30000-to-50000/">AED 30,000 – 50,000</a></li>
          <li><a href="/salary-transfer/aed-50000-plus/">AED 50,000+</a></li>
        </ul>
      </div>

      <!-- Banks -->
      <div class="dp-footer-col">
        <div class="dp-footer-heading">Banks</div>
        <ul>
          {banks.map((b) => (
            <li>
              <a href={`/banks/${b.id}/`} class="dp-footer-bank-row">
                <BankLogo slug={b.id} name={b.data.name} size="sm" />
                <span>{b.data.name}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Programmes -->
      <div class="dp-footer-col">
        <div class="dp-footer-heading">Programmes</div>
        <ul>
          {programs.map((p) => (
            <li><a href={`/airlines/${p.id}/`}>{p.data.name}</a></li>
          ))}
        </ul>
      </div>

      <!-- Site -->
      <div class="dp-footer-col">
        <div class="dp-footer-heading">Site</div>
        <ul>
          <li><a href="/cards/">All cards</a></li>
          <li><a href="/cards/compare/">Compare cards</a></li>
          <li><a href="/valuations/">AED valuations</a></li>
          <li><a href="/guides/">Guides</a></li>
          <li><a href="/guides/expat-starter/">Expat Starter</a></li>
          <li><a href="/best-of/">Best-of roundups</a></li>
          <li><a href="/topics/">All topics</a></li>
          <li><a href="/search/">Search</a></li>
          <li><a href="/rss.xml">RSS</a></li>
        </ul>
      </div>

      <!-- Trust -->
      <div class="dp-footer-col">
        <div class="dp-footer-heading">Trust</div>
        <ul>
          <li><a href="/about/">Why we built it</a></li>
          <li><a href="/editorial-policy/">Editorial policy</a></li>
          <li><a href="/how-we-make-money/">How we make money</a></li>
          <li><a href="/partnership/">Partnerships</a></li>
          <li><a href="/corrections/">Corrections log</a></li>
          <li><a href="/team/">The team</a></li>
          <li><a href="/glossary/">Glossary</a></li>
          <li><a href="/press/">Press</a></li>
          <li><a href="/tip/">Submit a tip</a></li>
          <li><a href="mailto:info@dubaipoints.ae">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="dp-footer-bottom">
      <span>© {year} DubaiPoints. UAE-resident-led, independent.</span>
      <a href="mailto:info@dubaipoints.ae" class="dp-footer-bottom-mail">info@dubaipoints.ae</a>
    </div>

    <p class="dp-footer-disclaimer">
      DubaiPoints is independent and not affiliated with any bank or
      financial institution. Content is for informational purposes only —
      always verify terms directly with the provider.
    </p>
  </div>
</footer>

<style>
  .dp-footer {
    background: var(--navy-deep);
    color: rgba(255, 255, 255, 0.78);
    margin-top: 96px;
    padding: 56px 32px 32px;
  }
  @media (max-width: 768px) {
    .dp-footer { margin-top: 64px; padding: 40px 20px 24px; }
  }

  .dp-footer-inner {
    max-width: var(--container-listing);
    margin: 0 auto;
  }

  .dp-footer-top {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 40px;
  }

  /* Brand column */
  .dp-footer-brand {
    grid-column: span 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .dp-footer-wordmark {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-weight: 800;
    font-size: 22px;
    letter-spacing: -0.6px;
    color: #fff;
    text-decoration: none;
    display: inline-block;
    transition: opacity 0.15s ease;
  }
  .dp-footer-wordmark:hover { opacity: 0.85; }
  .dp-footer-wordmark .dot { color: var(--green); }

  .dp-footer-tag {
    font-family: 'Fraunces', serif;
    font-size: 15px;
    line-height: 1.4;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
    max-width: 26ch;
    text-wrap: balance;
  }

  /* Newsletter CTA */
  .dp-footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    padding: 10px 16px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-decoration: none;
    transition: background 0.15s ease, border-color 0.15s ease;
    width: fit-content;
  }
  .dp-footer-cta:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.25);
  }
  .dp-footer-cta-arrow {
    transition: transform 0.15s ease;
  }
  .dp-footer-cta:hover .dp-footer-cta-arrow {
    transform: translateX(3px);
  }

  /* Social links */
  .dp-footer-social {
    display: flex;
    gap: 10px;
    margin-top: 8px;
  }
  .dp-social-link {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .dp-social-link:hover {
    background: rgba(255, 255, 255, 0.18);
    color: #fff;
  }

  /* Column headings */
  .dp-footer-col .dp-footer-heading {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #9bb1a4;
    margin: 0 0 14px;
  }

  /* Link lists */
  .dp-footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .dp-footer-col a {
    color: rgba(255, 255, 255, 0.78);
    font-size: 12px;
    text-decoration: none;
    transition: color 0.15s ease, padding-left 0.15s ease;
    display: inline-block;
    padding: 1px 0;
    position: relative;
  }
  .dp-footer-col a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.4);
    transition: width 0.2s ease;
  }
  .dp-footer-col a:hover {
    color: #fff;
  }
  .dp-footer-col a:hover::after {
    width: 100%;
  }

  /* Bank rows with logos */
  .dp-footer-bank-row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .dp-footer-bank-row :global(img) {
    filter: invert(1) brightness(0.85);
    opacity: 0.8;
    transition: opacity 0.15s ease;
  }
  .dp-footer-bank-row:hover :global(img) { opacity: 1; }

  /* Bottom bar */
  .dp-footer-bottom {
    margin-top: 16px;
    padding-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.5);
  }
  .dp-footer-bottom-mail {
    font-variant-numeric: tabular-nums;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .dp-footer-bottom-mail:hover {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Disclaimer */
  .dp-footer-disclaimer {
    margin-top: 16px;
    font-size: 10px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.5);    /* was 0.35 — now readable */
    max-width: 80ch;
  }

  /* ─── Responsive ─────────────────────────────────────────────── */

  /* Tablet: 3 columns, brand spans full width */
  @media (max-width: 1024px) {
    .dp-footer-top {
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }
    .dp-footer-brand {
      grid-column: span 3;
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px 32px;
      margin-bottom: 8px;
    }
    .dp-footer-tag { max-width: 40ch; }
    .dp-footer-cta { margin-top: 0; }
    .dp-footer-social { margin-top: 0; }
  }

  /* Mobile: 2 columns, brand on top */
  @media (max-width: 768px) {
    .dp-footer-top {
      grid-template-columns: repeat(2, 1fr);
      gap: 28px;
      margin-bottom: 28px;
    }
    .dp-footer-brand {
      grid-column: span 2;
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
    .dp-footer-tag { max-width: none; }
    .dp-footer-cta { margin-top: 4px; }
    .dp-footer-social { margin-top: 4px; }
    .dp-footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      padding-top: 16px;
    }
  }

  /* Very narrow: single column */
  @media (max-width: 480px) {
    .dp-footer-top {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .dp-footer-brand { grid-column: span 1; }
    .dp-footer-col .dp-footer-heading { margin-bottom: 10px; }
    .dp-footer-col ul { gap: 6px; }
  }
</style>
