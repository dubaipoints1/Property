---
import { getCollection } from "astro:content";
import BankLogo from "~/components/BankLogo.astro";

const banks = (await getCollection("banks")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
const programs = await getCollection("programs");

const year = new Date().getFullYear();
---

<style>
footer {
  background: var(--ink);
  color: rgba(255,255,255,0.6);
  margin-top: 96px;
  padding: 56px 32px 32px;
}
.footer-inner { max-width: 1180px; margin: 0 auto; }
.footer-top {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr;
  gap: 40px;
  margin-bottom: 40px;
}
.footer-brand .logo-wordmark img { height: 36px; }
.footer-brand p {
  font-size: 13px; color: rgba(255,255,255,0.45);
  line-height: 1.6; margin-top: 16px; max-width: 300px;
}
.footer-col h4 {
  font-size: 10px; font-weight: 700; letter-spacing: 2.5px;
  text-transform: uppercase; color: rgba(255,255,255,0.4);
  margin-bottom: 14px;
}
.footer-col a {
  display: block; font-size: 13px;
  color: rgba(255,255,255,0.6); padding: 5px 0;
  transition: color 0.15s;
}
.footer-col a:hover { color: white; }
.footer-col a.footer-bank-row {
  display: inline-flex; align-items: center; gap: 8px;
}
.footer-col a.footer-bank-row :global(img) {
  filter: invert(1) brightness(0.85);
  opacity: 0.8;
  transition: opacity 0.15s;
}
.footer-col a.footer-bank-row:hover :global(img) { opacity: 1; }
.footer-bottom {
  padding-top: 24px;
  border-top: 1px solid rgba(255,255,255,0.08);
  display: flex; justify-content: space-between; align-items: center;
  gap: 24px;
}
.footer-bottom p { font-size: 11px; color: rgba(255,255,255,0.3); }
.footer-bottom .disclaimer {
  font-size: 10px; color: rgba(255,255,255,0.25);
  max-width: 520px; line-height: 1.5;
}
@media (max-width: 1024px) {
  .footer-top { grid-template-columns: 1fr 1fr 1fr; }
}
@media (max-width: 768px) {
  .footer-top { grid-template-columns: 1fr 1fr; }
  .footer-bottom { flex-direction: column; align-items: flex-start; }
}
</style>

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="logo-wordmark"><img src="/logo-white.svg" alt="DubaiPoints" /></div>
        <p>The UAE's go-to source for points, miles, credit-card deals and banking hacks. Independent. Written by UAE residents, for UAE residents.</p>
      </div>
      <div class="footer-col">
        <h4>Salary transfer</h4>
        <a href="/salary-transfer/">Live tracker</a>
        <a href="/salary-transfer/calculator/">Calculator</a>
        <a href="/salary-transfer/aed-5000-to-8000/">AED 5k–8k</a>
        <a href="/salary-transfer/aed-8000-to-15000/">AED 8k–15k</a>
        <a href="/salary-transfer/aed-15000-to-30000/">AED 15k–30k</a>
        <a href="/salary-transfer/aed-30000-to-50000/">AED 30k–50k</a>
        <a href="/salary-transfer/aed-50000-plus/">AED 50k+</a>
      </div>
      <div class="footer-col">
        <h4>Banks</h4>
        {banks.map((b) => (
          <a href={`/banks/${b.id}/`} class="footer-bank-row">
            <BankLogo slug={b.id} name={b.data.name} size="sm" />
            <span>{b.data.name}</span>
          </a>
        ))}
      </div>
      <div class="footer-col">
        <h4>Programmes</h4>
        {programs.map((p) => <a href={`/airlines/${p.id}/`}>{p.data.name}</a>)}
      </div>
      <div class="footer-col">
        <h4>Site</h4>
        <a href="/cards/">All cards</a>
        <a href="/cards/compare/">Compare cards</a>
        <a href="/valuations/">AED valuations</a>
        <a href="/guides/">Guides</a>
        <a href="/guides/expat-starter/">Expat Starter</a>
        <a href="/rss.xml">RSS</a>
      </div>
      <div class="footer-col">
        <h4>Trust</h4>
        <a href="/editorial-policy/">Editorial policy</a>
        <a href="/how-we-make-money/">How we make money</a>
        <a href="/team/">The team</a>
        <a href="mailto:corrections@dubaipoints.ae">Corrections</a>
        <a href="mailto:tips@dubaipoints.ae">Send a tip</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} DubaiPoints.ae</p>
      <p class="disclaimer">DubaiPoints is independent and not affiliated with any bank or financial institution. Content is for informational purposes only — always verify terms directly with the provider.</p>
    </div>
  </div>
</footer>
