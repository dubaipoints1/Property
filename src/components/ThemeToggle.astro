---
// ThemeToggle — sun/moon button with localStorage persistence
// Uses inline script for zero-JS-flash on load
---

<button
  id="dp-theme-toggle"
  class="dp-theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  title="Toggle dark mode"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<style>
  .dp-theme-toggle {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: var(--paper);
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
    padding: 0;
  }
  .dp-theme-toggle:hover {
    background: var(--shade-1);
    border-color: var(--green);
  }
  .dp-theme-toggle:active { transform: scale(0.96); }
  
  .icon-sun, .icon-moon {
    position: absolute;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  
  /* Default (light): show moon, hide sun */
  .icon-sun { opacity: 0; transform: rotate(90deg) scale(0.5); }
  .icon-moon { opacity: 1; transform: rotate(0) scale(1); }
  
  /* Dark mode: show sun, hide moon */
  :global([data-theme="dark"]) .icon-sun { opacity: 1; transform: rotate(0) scale(1); }
  :global([data-theme="dark"]) .icon-moon { opacity: 0; transform: rotate(-90deg) scale(0.5); }
</style>

<script is:inline>
  (function() {
    const toggle = document.getElementById('dp-theme-toggle');
    if (!toggle) return;
    
    toggle.addEventListener('click', function() {
      const html = document.documentElement;
      const isDark = html.getAttribute('data-theme') === 'dark';
      const next = isDark ? 'light' : 'dark';
      
      html.setAttribute('data-theme', next);
      localStorage.setItem('dp-theme', next);
    });
  })();
</script>
