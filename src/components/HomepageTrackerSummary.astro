---
import { getLiveOffers } from "~/lib/offerAdapter";
import { formatAED, daysUntil } from "~/lib/salaryTransfer";
import BankLogo from "~/components/BankLogo.astro";

const offers = await getLiveOffers();

const ranked = offers
  .map((o) => ({
    offer: o,
    headlineReward: Math.max(...o.salaryBands.map((b) => b.rewardAmount)),
  }))
  .sort((a, b) => b.headlineReward - a.headlineReward)
  .slice(0, 3);
---

<div class="dp-tracker dp-tracker--summary">
  {ranked.length === 0 ? (
    <p class="dp-tracker-empty">
      No live offers tracked right now. Check back tomorrow.
    </p>
  ) : (
    <ul class="dp-tracker-list">
      {ranked.map(({ offer, headlineReward }) => (
        <li class="dp-tracker-row">
          <div class="dp-tracker-row-main">
            <a href={`/salary-transfer/${offer.bankSlug}/`} class="dp-tracker-bank">
              <BankLogo slug={offer.bankSlug} name={offer.bankName} size="sm" />
              <span>{offer.bankName}</span>
            </a>
            <p class="dp-tracker-name">{offer.name}</p>
            <p class="dp-tracker-meta">
              <span>{offer.salaryBands[0]?.rewardType.replace("_", " ")}</span>
              <span>· {offer.tenureMonths} months</span>
              {offer.sharia && <span>· Sharia</span>}
              {!offer.creditCardRequired && <span>· No card</span>}
            </p>
          </div>
          <div class="dp-tracker-row-amount">
            <p class="dp-tracker-reward">
              <span class="num">{formatAED(headlineReward)}</span>
            </p>
            <p class="dp-tracker-expiry">
              Ends in {daysUntil(offer.validUntil)} days
            </p>
          </div>
        </li>
      ))}
    </ul>
  )}

  <div class="dp-tracker-summary-cta">
    <a href="/salary-transfer/" class="primary">Open the live tracker →</a>
    <a href="/salary-transfer/calculator/" class="secondary">
      Score for your salary band
    </a>
  </div>
</div>

<style>
  .dp-tracker--summary { display: flex; flex-direction: column; gap: 16px; }
  .dp-tracker-summary-cta {
    display: flex; flex-wrap: wrap; gap: 16px;
    align-items: center;
    padding-top: 4px;
  }
  .dp-tracker-summary-cta a {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.2px;
    transition: color 0.15s;
  }
  .dp-tracker-summary-cta a.primary {
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
  }
  .dp-tracker-summary-cta a.primary:hover { color: var(--gold); border-bottom-color: var(--gold); }
  .dp-tracker-summary-cta a.secondary {
    color: var(--muted);
  }
  .dp-tracker-summary-cta a.secondary:hover { color: var(--ink); }
</style>
