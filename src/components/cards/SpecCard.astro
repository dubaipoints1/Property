---
// SpecCard — the canonical card surface used across hubs, finder,
// compare, and individual card pages.
//
// Variants:
//   - "compact": dense, for grids and finder results.
//   - "full":    full surface with welcome bonus + earn-rate table +
//                eligibility chips. Used on finder ranked results
//                and compare full-detail mode.
//   - "row":     horizontal layout for list views (compare default).
//
// All three variants pull from the same Card object so the data
// surface is consistent. Pixel discipline: spacing on an 8-px grid,
// type from the existing scale (12, 14, 16, 18, 22, 28).
//
// Reads:
//   - card.bank             → bank slug for BankLogo
//   - card.name, network, annualFee, fxFee
//   - card.welcomeBonus     → optional callout
//   - card.earnRates        → only on "full" variant
//   - card.eligibility      → eligibility chips
//   - card.lastVerified     → VerifiedStamp + 90-day stale warning chip

import { getEntry } from "astro:content";
import type { CardData } from "~/lib/cardsData";
import {
  welcomeBonusDisplay as toDisplay,
  annualFeeLabel,
} from "~/lib/cardsData";
import {
  formatEarnValue,
  topEarnEntry,
  CATEGORY_LABELS_FOR_TOP,
} from "~/lib/cardsDataFormat";
import BankLogo from "../BankLogo.astro";
import FeeBlock from "./FeeBlock.astro";
import EarnRateTable from "./EarnRateTable.astro";
import EligibilityChips from "./EligibilityChips.astro";
import WelcomeBonusCallout from "./WelcomeBonusCallout.astro";
import VerifiedStamp from "./VerifiedStamp.astro";

interface Props {
  card: CardData & { slug: string };
  variant?: "compact" | "full" | "row";
  showVerified?: boolean;
}

const { card, variant = "compact", showVerified = true } = Astro.props;

// Resolve bank-collection display name (graceful fallback to the slug).
const bankEntry = await getEntry("banks", card.bank);
const bankName = bankEntry?.data.name ?? card.bank;

// Headline earn-rate string — routes through the shared `topEarnEntry`
// + `CATEGORY_LABELS_FOR_TOP` so the rendered label is the same as
// AtAGlance's "Top earn rate" tile and the EarnRateTable's "top" row
// (audit finding, 1 June 2026 — the prior local topEarnRate + minimal
// CATEGORY_LABELS table leaked raw L2 keys like "partnerBrands" and
// "everythingElse" to readers because the local map omitted them).
const top = topEarnEntry(card.earnRates as Record<string, unknown>);
const earnLine = top
  ? `${formatEarnValue(top.value, card.earnUnit, card.categories)} ${CATEGORY_LABELS_FOR_TOP[top.key] ?? top.key}`
  : null;

// Year-1 vs year-2 annual-fee qualifier — shared with the listing tile,
// comparison tables, and SEO meta so the same card never reads as a
// different annual fee on different surfaces.
const feeLabel = annualFeeLabel(card);

// 90-day stale check — reused for the warning chip on the card head.
const NINETY_DAYS_MS = 90 * 24 * 60 * 60 * 1000;
const verifiedAt =
  card.lastVerified instanceof Date
    ? card.lastVerified
    : new Date(card.lastVerified);
const isStale = Date.now() - verifiedAt.getTime() > NINETY_DAYS_MS;

const wbDisplay = card.welcomeBonus ? toDisplay(card.welcomeBonus) : "";
const showWelcome =
  card.welcomeBonus !== undefined &&
  card.welcomeBonus !== null &&
  wbDisplay.length > 0 &&
  (variant === "full");

// Stage 5.5 UX Fix #5: editorial tagline on the full-variant SpecCard.
// Pulls the first sentence of the MDX editorTake when available;
// otherwise composes a deterministic one-liner from the top earn rate
// + annual fee. This is the line that converts the surface from a data
// tile to a publication artefact.
let tagline: string | null = null;
if (variant === "full") {
  try {
    const editorial = await getEntry("cards", card.slug);
    const editorTake = editorial?.data?.editorTake;
    if (typeof editorTake === "string" && editorTake.trim().length > 0) {
      // Chairman ruling Q1 (2026-05-20): require terminating punctuation
      // to be followed by whitespace or end-of-string so decimal numerals
      // ("earn 2.5x on…") in the first sentence don't clip mid-word.
      const firstSentence = editorTake
        .trim()
        .replace(/\s+/g, " ")
        .match(/^[^.!?]+[.!?](?:\s|$)/);
      tagline = firstSentence ? firstSentence[0].trim() : null;
    }
  } catch {
    // Editorial MDX may not exist for every L2 card — fall through to the
    // computed tagline below.
  }
  if (!tagline && top) {
    const lbl = CATEGORY_LABELS_FOR_TOP[top.key] ?? top.key;
    const feeStr =
      card.annualFee.amount === 0
        ? "no annual fee"
        : `${feeLabel.amount} a year`;
    tagline = `${formatEarnValue(top.value, card.earnUnit, card.categories)} on ${lbl} — ${feeStr}.`;
  }
}
---

<article class={`dp-spec-card is-${variant}`} data-bank={card.bank}>
  <header class="head">
    <div class="brand">
      <BankLogo slug={card.bank} name={bankName} size="sm" />
      <span class="bank">{bankName}</span>
    </div>
    {/* Phase 2a.0 (2026-05-20): gold "No longer accepting applications"
        chip sits between the bank eyebrow and the network pill. Second
        legitimate gold use site-wide (alongside VerifiedStamp.is-stale).
        Render only when discontinuedForNewApplicants is present. */}
    {card.discontinuedForNewApplicants && (
      <span
        class="discontinued"
        title={card.discontinuedForNewApplicants.note ?? "Closed to new applications"}
      >
        No longer accepting applications
      </span>
    )}
    <span class="network">{card.network}</span>
  </header>

  {/* Stage 5.5 UX Fix #4: on `is-full`, the loudest reader signal (the
      AED annual fee in 28px Fraunces) comes immediately under the head.
      The card name follows. Reader meets the price before the bank
      acronym dominates their attention. Compact + row variants keep
      the title-first reading order they were designed for. */}
  {variant === "full" && (
    <div class="hero-fee">
      <FeeBlock
        annualFee={card.annualFee}
        fxFee={card.fxFee}
        waiver={card.annualFeeWaiver}
        joiningFee={card.joiningFee}
      />
    </div>
  )}

  <div class="title">
    <h3>
      <a href={`/cards/${card.slug}/`}>{card.name}</a>
    </h3>
    {isStale && showVerified && (
      <span class="dp-card-chip is-warn" title="Last verified more than 90 days ago">
        Pending re-audit
      </span>
    )}
  </div>

  {variant === "full" && tagline && (
    <p class="tagline">{tagline}</p>
  )}

  {showWelcome && card.welcomeBonus && (
    <WelcomeBonusCallout
      welcomeBonus={card.welcomeBonus}
      welcomeBonusDisplay={wbDisplay}
    />
  )}

  {variant === "full" && (
    <div class="cell cell-earn">
      <div class="lbl">Earn rates</div>
      <EarnRateTable
        earnRates={card.earnRates}
        earnUnit={card.earnUnit}
      />
    </div>
  )}

  {(variant === "compact" || variant === "row") && (
    <dl class="mini-stats">
      <div>
        <dt>Annual fee</dt>
        <dd>
          {feeLabel.amount}
          {feeLabel.qual && <small class="qual"> ({feeLabel.qual})</small>}
        </dd>
      </div>
      {earnLine && (
        <div>
          <dt>Top earn rate</dt>
          <dd>{earnLine}</dd>
        </div>
      )}
      <div>
        <dt>Min salary</dt>
        <dd class={card._provenance?.eligibility === "needs-review" ? "is-unverified" : undefined}>
          {card._provenance?.eligibility === "needs-review"
            ? "Pending"
            : `AED ${card.eligibility.minSalary.toLocaleString()}/mo`}
        </dd>
      </div>
    </dl>
  )}

  {variant === "full" && (
    <div class="eligibility">
      <div class="lbl">Eligibility</div>
      <EligibilityChips
        eligibility={card.eligibility}
        eligibilityProvenance={card._provenance?.eligibility}
      />
    </div>
  )}

  <footer class="foot">
    {showVerified && <VerifiedStamp lastVerified={card.lastVerified} />}
    <a class="cta" href={`/cards/${card.slug}/`}>
      Read review <span aria-hidden="true">→</span>
    </a>
  </footer>
</article>

<style>
  .dp-spec-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 16px;
    display: grid;
    gap: 12px;
    font-family: "DM Sans", system-ui, sans-serif;
    color: var(--ink);
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .dp-spec-card:hover {
    border-color: var(--ink-soft);
    box-shadow: 0 8px 16px -12px rgba(15, 31, 46, 0.18);
  }
  .dp-spec-card.is-full {
    padding: 24px;
    gap: 16px;
  }
  .dp-spec-card.is-row {
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
    gap: 16px 24px;
    align-items: start;
  }

  .head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .head .brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .head .bank {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--green);
  }
  .head .network {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--ink-soft);
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 4px 8px;
    background: var(--paper);
  }
  /* Phase 2a.0: gold chip for discontinued cards. Sits between the
     bank eyebrow and the network pill in the .head row. Uses --gold
     + --gold-soft — second legitimate gold use site-wide alongside
     VerifiedStamp.is-stale. */
  .head .discontinued {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid var(--gold);
    border-radius: 4px;
    padding: 4px 8px;
    background: var(--gold-soft);
    line-height: 1.2;
  }

  .title {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
  }
  .title h3 {
    margin: 0;
    font-family: "Fraunces", serif;
    font-weight: 500;
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: -0.3px;
    color: var(--ink);
    text-wrap: balance;
  }
  .is-full .title h3 {
    font-size: 22px;
    letter-spacing: -0.4px;
  }
  .title h3 a {
    color: inherit;
  }
  .title h3 a:hover {
    color: var(--green);
  }

  /* Hero fee block — sits between the head eyebrow row and the title
     on `is-full`. Pulled out of the old two-column .grid; the earn
     table now lives as its own section below the welcome callout. */
  .hero-fee {
    padding: 8px 0 16px 0;
    border-bottom: 1px solid var(--line-soft);
  }

  /* Stage 5.5 UX Fix #5: one-line editorial tagline in Fraunces italic.
     Sits between the card name and the welcome callout, giving every
     full-variant card a single line of publication voice. */
  .tagline {
    margin: 0;
    font-family: "Fraunces", serif;
    font-style: italic;
    font-size: 16px;
    font-weight: 400;
    line-height: 1.4;
    color: var(--ink-soft);
    text-wrap: balance;
    max-width: 52ch;
  }

  .cell .lbl {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .mini-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px 16px;
    margin: 0;
    padding: 12px 0;
    border-top: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
  }
  .mini-stats > div {
    display: grid;
    gap: 2px;
    min-width: 0;
  }
  .mini-stats dt {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--muted);
  }
  .mini-stats dd {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }
  .mini-stats dd .qual {
    font-weight: 500;
    font-size: 11px;
    /* WCAG-AA contrast fix on the year-1/year-2 disambiguator
       (UX audit, 3 June 2026). --muted ~2.85:1; --ink-soft ~6.4:1. */
    color: var(--ink-soft);
    letter-spacing: 0.2px;
  }
  /* Provenance-aware: needs-review eligibility renders "Pending" in
     muted italics so the unverified band can't be read as confirmed. */
  .mini-stats dd.is-unverified {
    color: var(--muted);
    font-style: italic;
    font-weight: 500;
  }

  .eligibility .lbl {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
  }

  .foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .foot .cta {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.3px;
    color: var(--ink);
    border-bottom: 1px solid currentColor;
    padding-bottom: 2px;
    transition: color 0.15s ease;
  }
  .foot .cta:hover {
    color: var(--green);
  }

  @media (max-width: 720px) {
    .dp-spec-card.is-row {
      grid-template-columns: 1fr;
    }
    .dp-spec-card.is-full {
      padding: 16px;
    }
    .grid {
      grid-template-columns: 1fr;
    }
    .mini-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
