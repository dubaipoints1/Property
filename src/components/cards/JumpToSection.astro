---
// JumpToSection — sticky in-page nav. Anchors to H2 ids in the article
// body. Pure HTML (<details>/<summary>) so no JS hydration; the native
// disclosure on tap is enough for the mobile-first reader who scrolls
// fast and needs to bail to a specific section.
//
// Phase 2a.2.5 (2026-05-21). Modelled on Upgraded Points' / OMAAT's
// "Jump to section" pattern. On scroll past the hero, the chip sticks
// to the top of the viewport. Tap to expand the section list; tap an
// item to scroll-jump.
//
// Editor authors the section list in MDX — Astro's MDX rehype slugifier
// turns each `## H2` into an id (lower-case, hyphens). The `id` prop
// here must match.

interface Section {
  /** The slugified id of the corresponding `## H2` in the MDX body. */
  id: string;
  /** Label shown in the nav — keep short (≤ 24 chars). */
  label: string;
}

interface Props {
  sections: Section[];
}

const { sections } = Astro.props;
---

{sections && sections.length > 0 && (
  <nav class="dp-jump-to-section" aria-label="Jump to section">
    <details>
      <summary>
        <span class="label">Jump to section</span>
        <span class="caret" aria-hidden="true">▾</span>
      </summary>
      <ul>
        {sections.map((s) => (
          <li>
            <a href={`#${s.id}`}>{s.label}</a>
          </li>
        ))}
      </ul>
    </details>
  </nav>
)}

<style>
  .dp-jump-to-section {
    position: sticky;
    top: 0;
    z-index: 5;
    margin: 0 0 24px;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    padding: 10px 0;
  }
  .dp-jump-to-section details {
    max-width: 65ch;
  }
  .dp-jump-to-section summary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    list-style: none;
    padding: 8px 14px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--paper);
    font-family: "DM Sans", system-ui, sans-serif;
    font-weight: 600;
    font-size: 13px;
    color: var(--green);
    letter-spacing: 0.2px;
    line-height: 1;
    transition: border-color 120ms ease, background 120ms ease;
  }
  .dp-jump-to-section summary::-webkit-details-marker { display: none; }
  .dp-jump-to-section summary:hover {
    border-color: var(--green);
    background: rgba(45, 106, 82, 0.04);
  }
  .dp-jump-to-section summary .caret {
    font-size: 10px;
    transition: transform 150ms ease;
  }
  .dp-jump-to-section details[open] summary .caret {
    transform: rotate(180deg);
  }
  .dp-jump-to-section ul {
    list-style: none;
    margin: 12px 0 4px;
    padding: 12px 4px;
    display: grid;
    gap: 6px;
    border-top: 1px solid var(--line-soft);
  }
  .dp-jump-to-section li { margin: 0; }
  .dp-jump-to-section a {
    display: block;
    padding: 8px 12px;
    border-radius: 4px;
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 14px;
    color: var(--ink);
    text-decoration: none;
    line-height: 1.3;
  }
  .dp-jump-to-section a:hover {
    background: rgba(45, 106, 82, 0.06);
    color: var(--green);
  }
  @media (max-width: 719.98px) {
    .dp-jump-to-section { padding: 8px 0; margin: 0 0 18px; }
    .dp-jump-to-section summary { font-size: 12px; padding: 7px 12px; }
  }
  /* When the user clicks a section link, account for the sticky chip's
     height so the H2 doesn't sit underneath it. */
  :global(.dp-prose h2[id]) { scroll-margin-top: 64px; }
</style>
