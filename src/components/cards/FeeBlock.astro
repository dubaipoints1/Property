---
// FeeBlock — two-line fee surface (annual fee + optional FX + waiver).
//
// Renders the headline AED annual figure in display type, a small
// "FX +X.XX%" line below, and a conditional waiver line where the
// structured form is present.
//
// Token-only. Annual fee uses --ink (per /cards/ index.astro); FX
// uses --ink-soft. Waiver line uses --green to signal "good news"
// in keeping with the two-accent system.

import type {
  CardData,
  StructuredAnnualFeeWaiver,
} from "~/lib/cardsData";
import {
  annualFeeWaiverDisplay,
  isStructuredAnnualFeeWaiver,
  getCardData,
} from "~/lib/cardsData";

interface Props {
  /** Phase 2a.2: when set, the component resolves all inline props
   * from `getCardData(card)`. Keeps the MDX call site at one line:
   * `<FeeBlock card="emirates-nbd-skywards-infinite" />`. */
  card?: string;
  annualFee?: CardData["annualFee"];
  fxFee?: number;
  /** L2 `_provenance.fxFee` — when "needs-review" the fxFee line is
   * rendered as "—" instead of "0.00%" so an unverified zero can't be
   * mistaken for a confirmed zero (1 June 2026 audit follow-up to the
   * 2026-05-29 §10 ADCB FX kill-list amendment). When the component
   * is card-resolved this is read from the L2 directly. */
  fxFeeProvenance?: string;
  waiver?: CardData["annualFeeWaiver"];
  /** Phase 2a.0 (2026-05-20): year-1 joining fee. Rendered as a small
   * line beneath the annual figure only when present AND ≠ annualFee.
   * When equal, the joining-fee line is suppressed (year-1 and year-2+
   * are the same number, so the annual figure already conveys it). */
  joiningFee?: CardData["joiningFee"];
}

const {
  card,
  annualFee: annualFeeProp,
  fxFee: fxFeeProp,
  fxFeeProvenance: fxFeeProvenanceProp,
  waiver: waiverProp,
  joiningFee: joiningFeeProp,
} = Astro.props;

const resolved = card ? getCardData(card) : undefined;
if (card && !resolved) {
  throw new Error(`FeeBlock: unknown card slug "${card}"`);
}

const annualFee = resolved?.annualFee ?? annualFeeProp;
if (!annualFee) {
  throw new Error("FeeBlock: requires `card` or inline `annualFee` prop");
}
const fxFee = resolved?.fxFee ?? fxFeeProp;
const fxFeeProvenance =
  resolved?._provenance?.fxFee ?? fxFeeProvenanceProp;
const waiver = resolved?.annualFeeWaiver ?? waiverProp;
const joiningFee = resolved?.joiningFee ?? joiningFeeProp;

// Phase 2a.2.3 (2026-05-20) — VAT tag. Defaults to "inclusive" per the
// schema default so cards without an explicit policy render the
// inclusive treatment.
const vatPolicy = resolved?.vatPolicy ?? "inclusive";
const showVatTag = annualFee.amount > 0;
const vatTagText =
  vatPolicy === "exclusive" ? "+ 5% VAT" : "incl. VAT";

const aedFormatter = new Intl.NumberFormat("en-AE", {
  style: "currency",
  currency: "AED",
  maximumFractionDigits: 0,
});

// AED amounts may carry decimals (joining fees like 3,148.95 / 1,573.95).
// Use a separate formatter so we keep the precision when present.
const aedDecimalFormatter = new Intl.NumberFormat("en-AE", {
  style: "currency",
  currency: "AED",
  maximumFractionDigits: 2,
});

function formatAED(amount: number): string {
  return Number.isInteger(amount)
    ? aedFormatter.format(amount)
    : aedDecimalFormatter.format(amount);
}

const feeLabel =
  annualFee.amount === 0
    ? "Free"
    : formatAED(annualFee.amount);

const waiverString = annualFeeWaiverDisplay(
  waiver as StructuredAnnualFeeWaiver | string | null | undefined,
);
const showWaiver =
  waiverString.length > 0 &&
  (isStructuredAnnualFeeWaiver(waiver) || typeof waiver === "string");

// Phase 2a.0: only show the joining-fee line when the year-1 figure
// differs from the year-2+ annual fee. When they're equal (LuLu 247
// Platinum is the inverse: year-1 525, year-2 262.50, so they differ;
// dnata World is 1048.95 / 1048.95, so equal and suppressed).
const showJoiningFee =
  joiningFee !== undefined &&
  joiningFee !== null &&
  joiningFee.amount !== annualFee.amount;
---

<div class="dp-fee-block">
  <div class="amt">{feeLabel}</div>
  {showVatTag && <div class="vat">{vatTagText}</div>}
  <div class="lbl">Annual fee</div>
  {showJoiningFee && joiningFee && (
    <div class="joining">
      Joining fee {formatAED(joiningFee.amount)} (year 1{vatPolicy === "inclusive" ? ", incl. VAT" : ""})
    </div>
  )}
  {/* Provenance-aware FX line: when the L2 fxFee provenance is
      'needs-review' we render an explicit '—' rather than a bare
      number, so the reader can't mistake an unverified zero for a
      confirmed zero. The 2026-05-29 §10 kill-list amendment surfaced
      exactly this failure mode on the ADCB FX-fee parse. */}
  {fxFee !== undefined && fxFee !== null && fxFeeProvenance !== "needs-review" && (
    <div class="fx">FX +{fxFee.toFixed(2)}%</div>
  )}
  {fxFeeProvenance === "needs-review" && (
    <div class="fx is-unverified">FX — confirmation pending</div>
  )}
  {showWaiver && <div class="waiver">{waiverString}</div>}
</div>

<style>
  .dp-fee-block {
    display: grid;
    gap: 4px;
    margin: 24px 0 40px;
    font-family: "DM Sans", system-ui, sans-serif;
  }
  @media (max-width: 719.98px) {
    .dp-fee-block { margin: 20px 0 32px; }
  }
  .dp-fee-block .amt {
    font-family: "Fraunces", serif;
    font-weight: 500;
    font-size: 28px;
    letter-spacing: -0.6px;
    color: var(--ink);
    line-height: 1.1;
  }
  .dp-fee-block .vat {
    font-size: 10px;
    font-weight: 500;
    color: var(--muted);
    margin-top: 2px;
    line-height: 1.2;
  }
  .dp-fee-block .lbl {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: var(--muted);
  }
  .dp-fee-block .joining {
    font-size: 12px;
    color: var(--ink-soft);
    line-height: 1.4;
    margin-top: 4px;
  }
  .dp-fee-block .fx {
    font-size: 12px;
    color: var(--ink-soft);
    margin-top: 4px;
  }
  .dp-fee-block .fx.is-unverified {
    color: var(--muted);
    font-style: italic;
  }
  .dp-fee-block .waiver {
    font-size: 12px;
    line-height: 1.4;
    color: var(--green);
    margin-top: 4px;
  }
</style>
