---
// AtAGlance — fact-tile strip surfacing annual fee, min salary, top
// earn rate, and welcome bonus above the EditorVerdict on every
// card-review page. Reader gets the headline numbers in 3 seconds
// before any prose. Pure SSR; no JS hydration.
//
// Reads from the L2 layer via getCardData(slug); shares topEarnEntry
// + CATEGORY_LABELS_FOR_TOP with EarnRateTable.is-top + CardComparison
// so the "Top earn rate" tile matches the navy-bold row in
// EarnRateTable on the same page.
//
// Spec source: .council/briefs/2026-05-20-phase-2a-2-2-prose-density-pass.md
// Phase 2a.2.5 (2026-05-22) — welcome-bonus tile added per dossier
// Tier A #1 (top-of-article fact-tile strip — UP + TPG pattern).

import { getCardData } from "~/lib/cardsData";
import {
  topEarnEntry,
  CATEGORY_LABELS_FOR_TOP,
  formatAED,
} from "~/lib/cardsDataFormat";

interface Props {
  card: string;
}

const { card: slug } = Astro.props;
const card = getCardData(slug);
if (!card) throw new Error(`AtAGlance: unknown card slug "${slug}"`);

const annualFeeAmount = card.annualFee.amount;
const minSalary = card.eligibility.minSalary;
const invitationOnly = card.eligibility.invitationOnly === true;
const top = topEarnEntry(card.earnRates as Record<string, unknown>);

// welcomeBonus is a union: structured object | bifurcated (with/without
// salary transfer) | legacy string | null. The tile renders only when
// we have a structured amount + unit; for bifurcated cards we prefer
// the with-salary-transfer branch (the headline number most readers
// will qualify for in a UAE expat context).
const wb = card.welcomeBonus;
let welcomeBonusAmount = 0;
let welcomeBonusUnit = "";
if (wb && typeof wb === "object") {
  if ("amount" in wb && "unit" in wb) {
    welcomeBonusAmount = wb.amount;
    welcomeBonusUnit = wb.unit;
  } else {
    const branch = wb.with_salary_transfer ?? wb.without_salary_transfer;
    if (branch) {
      welcomeBonusAmount = branch.amount;
      welcomeBonusUnit = branch.unit;
    }
  }
}

const annualFeeLabel =
  annualFeeAmount === 0 ? "Free" : formatAED(annualFeeAmount);

// Phase 2a.2.3 (2026-05-20) — VAT qualifier on the annual fee tile.
const vatPolicy = card.vatPolicy ?? "inclusive";
const showVatQual = annualFeeAmount > 0;
const vatQualText =
  vatPolicy === "exclusive" ? "+ 5% VAT" : "incl. VAT";

const minSalaryEyebrow = "Min salary";
let minSalaryLabel: string;
if (invitationOnly) {
  minSalaryLabel = "Invitation only";
} else if (minSalary === 0) {
  minSalaryLabel = "No minimum";
} else {
  minSalaryLabel = `${formatAED(minSalary)}/mo`;
}

const UNIT_LABELS: Record<string, string> = {
  skywards_miles: "Skywards Miles",
  etihad_guest_miles: "Etihad Guest Miles",
  qatar_avios: "Avios",
  saudia_alfursan: "Alfursan Miles",
  share_points: "SHARE Points",
  lulu_points: "LuLu Points",
  upoints: "U Points",
  fab_rewards: "FAB Rewards",
  enbd_plus_points: "ENBD Plus Points",
  enbd_smiles: "ENBD Smiles",
  adcb_touchpoints: "ADCB TouchPoints",
  mashreq_salaam: "Mashreq Salaam",
  aed_cashback: "AED cashback",
  aed_voucher: "AED voucher",
  aed_credit: "AED credit",
  darna_points: "Darna Points",
  dnata_points: "dnata Points",
  marriott_bonvoy_points: "Bonvoy Points",
  noon_credits: "noon Credits",
  red_points: "Red Points",
};

function formatCompactBonus(n: number): string {
  if (n >= 1_000_000) {
    const m = n / 1_000_000;
    return `${m % 1 === 0 ? m.toFixed(0) : m.toFixed(1)}M`;
  }
  if (n >= 1_000) return `${Math.round(n / 1_000)}k`;
  return n.toLocaleString();
}

const showWelcomeBonus = welcomeBonusAmount > 0;
const welcomeBonusValue = showWelcomeBonus
  ? formatCompactBonus(welcomeBonusAmount)
  : "";
const welcomeBonusQual =
  UNIT_LABELS[welcomeBonusUnit] ??
  welcomeBonusUnit.replace(/_/g, " ");

const tileCount =
  2 + (top ? 1 : 0) + (showWelcomeBonus ? 1 : 0);
---

<dl class:list={["dp-at-a-glance", `is-${tileCount}-tiles`]} aria-label="Card at a glance">
  <div class="tile">
    <dt class="eyebrow">Annual fee</dt>
    <dd class="value">
      {annualFeeLabel}
      {showVatQual && <span class="qual">{vatQualText}</span>}
    </dd>
  </div>
  <div class="tile">
    <dt class="eyebrow">{minSalaryEyebrow}</dt>
    <dd class="value">{minSalaryLabel}</dd>
  </div>
  {top && (
    <div class="tile">
      <dt class="eyebrow">Top earn rate</dt>
      <dd class="value">
        <span class="num">{top.value}×</span>
        <span class="qual">{CATEGORY_LABELS_FOR_TOP[top.key] ?? top.key}</span>
      </dd>
    </div>
  )}
  {showWelcomeBonus && (
    <div class="tile">
      <dt class="eyebrow">Welcome bonus</dt>
      <dd class="value">
        <span class="num">{welcomeBonusValue}</span>
        <span class="qual">{welcomeBonusQual}</span>
      </dd>
    </div>
  )}
</dl>

<style>
  .dp-at-a-glance {
    display: grid;
    gap: 0;
    margin: 24px 0 36px;
    padding: 0;
    border: 1px solid var(--line);
    background: var(--paper);
    font-family: "DM Sans", system-ui, sans-serif;
  }
  .dp-at-a-glance.is-2-tiles {
    grid-template-columns: repeat(2, 1fr);
  }
  .dp-at-a-glance.is-3-tiles {
    grid-template-columns: repeat(3, 1fr);
  }
  .dp-at-a-glance.is-4-tiles {
    grid-template-columns: repeat(4, 1fr);
  }
  .dp-at-a-glance .tile {
    padding: 14px 16px 16px;
    display: grid;
    gap: 6px;
    border-right: 1px solid var(--line);
    min-width: 0;
  }
  .dp-at-a-glance .tile:last-child {
    border-right: none;
  }
  .dp-at-a-glance .eyebrow {
    font-family: "DM Sans", system-ui, sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.2;
    margin: 0;
  }
  .dp-at-a-glance .value {
    margin: 0;
    font-family: "Fraunces", serif;
    font-weight: 500;
    font-size: 24px;
    letter-spacing: -0.4px;
    color: var(--ink);
    line-height: 1.1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: clip;
  }
  .dp-at-a-glance .value .num {
    display: block;
    font-family: "Fraunces", serif;
    font-size: 24px;
    letter-spacing: -0.4px;
    color: var(--ink);
  }
  .dp-at-a-glance .value .qual {
    display: block;
    margin-top: 2px;
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-soft);
    letter-spacing: 0;
    text-transform: none;
    white-space: normal;
    line-height: 1.3;
  }
  @media (max-width: 719.98px) {
    .dp-at-a-glance {
      margin: 20px 0 28px;
    }
    .dp-at-a-glance.is-4-tiles {
      grid-template-columns: repeat(2, 1fr);
    }
    .dp-at-a-glance.is-4-tiles .tile:nth-child(2),
    .dp-at-a-glance.is-4-tiles .tile:nth-child(4) {
      border-right: none;
    }
    .dp-at-a-glance.is-4-tiles .tile:nth-child(3) {
      border-right: 1px solid var(--line);
    }
    .dp-at-a-glance.is-4-tiles .tile:nth-child(1),
    .dp-at-a-glance.is-4-tiles .tile:nth-child(2) {
      border-bottom: 1px solid var(--line);
    }
    .dp-at-a-glance .tile {
      padding: 10px 10px 12px;
      gap: 4px;
    }
    .dp-at-a-glance .eyebrow {
      font-size: 9px;
      letter-spacing: 1.5px;
    }
    .dp-at-a-glance .value,
    .dp-at-a-glance .value .num {
      font-size: 20px;
      letter-spacing: -0.3px;
    }
    .dp-at-a-glance .value .qual {
      font-size: 11px;
      margin-top: 1px;
    }
  }
</style>
