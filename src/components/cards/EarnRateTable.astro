---
// EarnRateTable — compact two-column grid of earn-rate categories.
//
// Categories rendered with sentence-case labels. Numbers right-aligned.
// If only `everythingElse` is set, collapses to a single line
// ("X per AED 1 spent").
//
// Reads the EarnRates shape directly; the _caps sub-object is filtered
// out so only numeric per-category fields render.

import type { CardData } from "~/lib/cardsData";
import { getCardData } from "~/lib/cardsData";
import { formatEarnValue, earnIsPercentage } from "~/lib/cardsDataFormat";

interface Props {
  /** Phase 2a.2: when set, the component resolves earnRates + earnUnit
   * from `getCardData(card)`. Keeps the MDX call site at one line. */
  card?: string;
  earnRates?: CardData["earnRates"];
  earnUnit?: string;
}

const {
  card,
  earnRates: earnRatesProp,
  earnUnit: earnUnitProp,
} = Astro.props;

const resolved = card ? getCardData(card) : undefined;
if (card && !resolved) {
  throw new Error(`EarnRateTable: unknown card slug "${card}"`);
}

const earnRates = resolved?.earnRates ?? earnRatesProp;
if (!earnRates) {
  throw new Error("EarnRateTable: requires `card` or inline `earnRates` prop");
}
const earnUnit = resolved?.earnUnit ?? earnUnitProp;

const CATEGORY_LABELS: Record<string, string> = {
  // Phase 2a.2 (2026-05-20): `partnerBrands` rendered as the first row so the
  // bank's headline partner-rate (e.g. Skywards Infinite's 2× on Emirates /
  // flydubai / duty free / food-delivery / ride-hailing apps) doesn't silently
  // drop from the table. The specific partner list lives in the MDX prose
  // above; the row label is intentionally generic so it works across cards.
  partnerBrands: "Partner brands",
  dining: "Dining",
  groceries: "Groceries",
  shopping: "Shopping",
  travel: "Travel",
  fuel: "Fuel",
  entertainment: "Entertainment",
  online: "Online",
  international: "International spend",
  utilities: "Utilities",
  insurance: "Insurance",
  everythingElse: "Everything else",
};

// Pull every numeric category, preserving definition order from
// CATEGORY_LABELS for deterministic rendering.
const allEntries: Array<{ key: string; label: string; value: number }> = [];
for (const key of Object.keys(CATEGORY_LABELS)) {
  const v = (earnRates as Record<string, unknown>)[key];
  if (typeof v === "number") {
    allEntries.push({ key, label: CATEGORY_LABELS[key], value: v });
  }
}

// "Everything else" pulled out for the collapsed single-line case.
const onlyEverythingElse =
  allEntries.length === 1 && allEntries[0]?.key === "everythingElse";

// Stage 5.5 UX Fix #3: precompute the top earn-rate row server-side so
// the reader's eye lands on "Dining 5×" in one glance instead of
// reading every row. `everythingElse` cannot be the top (it's the base
// rate by definition); ties are broken by category-definition order.
const candidateEntries = allEntries.filter((e) => e.key !== "everythingElse");
const topKey = candidateEntries.length > 0
  ? candidateEntries.reduce((a, b) => (b.value > a.value ? b : a)).key
  : null;

const unitLabel = earnUnit ?? "per AED 1 spent";

// §6 unit-integrity (2026-05-29): cashback / %-denominated cards render
// "5%", points cards "2×". When the value already carries "%" prefix
// in earnUnit (e.g. "% cashback (paid as FAB Rewards)"), strip the
// leading "%" so the collapsed line doesn't read "5% % cashback". When
// the value is a percentage but earnUnit is the "per AED 1 spent"
// default (or any non-%-prefixed form), drop the per-AED trailer
// entirely and render "cashback" — the value's "%" already conveys
// the percent-back framing (1 June 2026 audit follow-up).
const isPct = earnIsPercentage(earnUnit, resolved?.categories);
const displayUnit = isPct
  ? unitLabel.startsWith("%")
    ? unitLabel.replace(/^%\s*/, "")
    : "cashback"
  : unitLabel;
const cats = resolved?.categories;
---

{onlyEverythingElse && allEntries[0] ? (
  <div class="dp-earn-collapsed">
    <span class="rate">{formatEarnValue(allEntries[0].value, earnUnit, cats)}</span>
    <span class="unit">{displayUnit}</span>
  </div>
) : (
  <dl class="dp-earn-table">
    {allEntries.map(({ key, label, value }) => (
      <div
        class={`row${key === "everythingElse" ? " is-default" : ""}${key === topKey ? " is-top" : ""}`}
      >
        <dt>{label}</dt>
        <dd>{formatEarnValue(value, earnUnit, cats)}</dd>
      </div>
    ))}
  </dl>
)}

<style>
  .dp-earn-collapsed {
    display: flex;
    align-items: baseline;
    gap: 8px;
    font-family: "DM Sans", system-ui, sans-serif;
  }
  .dp-earn-collapsed .rate {
    font-family: "Fraunces", serif;
    font-weight: 500;
    font-size: 22px;
    color: var(--ink);
    letter-spacing: -0.4px;
  }
  .dp-earn-collapsed .unit {
    font-size: 12px;
    color: var(--ink-soft);
  }

  .dp-earn-table {
    margin: 24px 0 40px;
    padding: 0;
    display: grid;
    gap: 0;
    border-top: 1px solid var(--line-soft);
    font-family: "DM Sans", system-ui, sans-serif;
  }
  .dp-earn-table .row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    align-items: baseline;
    padding: 8px 0;
    border-bottom: 1px solid var(--line-soft);
  }
  .dp-earn-table dt {
    font-size: 14px;
    color: var(--ink);
    font-weight: 500;
  }
  .dp-earn-table dd {
    margin: 0;
    text-align: right;
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }
  .dp-earn-table .row.is-default dt,
  .dp-earn-table .row.is-default dd {
    color: var(--ink-soft);
  }
  /* Top earn-rate row — drawn in navy + 700-weight so the reader's eye
     lands on the highest rate in one glance. Stage 5.5 UX Fix #3. */
  .dp-earn-table .row.is-top dt,
  .dp-earn-table .row.is-top dd {
    color: var(--green);
    font-weight: 700;
  }
  @media (max-width: 719.98px) {
    .dp-earn-table { margin: 20px 0 32px; }
  }
</style>
