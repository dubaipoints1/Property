---
// EligibilityChips — promoted block: salary band as the primary value
// (dt/dd, Fraunces 18px), constraints + employment-type as a quiet
// chip row underneath.
//
// Stage 5.5 UX review (2026-05-20, Fix #2): the previous flat row of
// equal-weight chips made the salary band look like a sibling fact to
// "Salary transfer required" and "UAE residents". Salary is the gate;
// the rest is qualifier. The `is-warn` modifier on "Salary transfer
// required" is also dropped — it's a constraint, not an error, and
// dressing it as a warning told readers something was wrong with the
// card. Constraints are now quiet qualifiers.

import type { CardData } from "~/lib/cardsData";

interface Props {
  eligibility: CardData["eligibility"];
  /** L2 `_provenance.eligibility` — when "needs-review" the minSalary
   * line renders an explicit "Pending" placeholder instead of a bare
   * AED figure, so an unverified salary band can't be mistaken for a
   * confirmed one. Matches the FX provenance pattern from PR #210. */
  eligibilityProvenance?: string;
}

const { eligibility, eligibilityProvenance } = Astro.props;
const isUnverified = eligibilityProvenance === "needs-review";

const aedFormatter = new Intl.NumberFormat("en-AE", {
  style: "currency",
  currency: "AED",
  maximumFractionDigits: 0,
});

const EMPLOYMENT_LABELS: Record<string, string> = {
  salaried: "Salaried",
  "self-employed": "Self-employed",
  "business-owner": "Business owner",
  any: "Any employment",
};

// Phase 2a.0 (2026-05-20): when the card is invitation-only, the salary
// band is meaningless (the gate is AUM or a separate tier qualification).
// Hide the primary dt/dd block and render a single "Invitation only"
// qualifier instead. Retires the `minSalary: 250000` sentinel ENBD
// Priority Banking / FAB World Elite used in Phase 1.
const isInviteOnly = eligibility.invitationOnly === true;

const qualifiers: string[] = [];
if (isInviteOnly) qualifiers.push("Invitation only");
if (eligibility.salaryTransferRequired) qualifiers.push("Salary transfer required");
if (eligibility.residencyRequired) qualifiers.push("UAE residents");
// Chairman ruling Q3 (2026-05-20): omit the chip when employmentTypes
// includes "any" — "Any employment" reads as a constraint when it's
// the absence of one. Only emit chips for actual restrictions.
for (const t of eligibility.employmentTypes ?? []) {
  if (t === "any") continue;
  qualifiers.push(EMPLOYMENT_LABELS[t] ?? t);
}
---

<div class="dp-eligibility">
  {!isInviteOnly && (
    <dl class="dp-eligibility-primary">
      <dt>Minimum salary</dt>
      <dd class={isUnverified ? "is-unverified" : undefined}>
        {isUnverified ? (
          <>—<span class="per"> confirmation pending</span></>
        ) : (
          <>{aedFormatter.format(eligibility.minSalary)}<span class="per">/mo</span></>
        )}
      </dd>
    </dl>
  )}
  {qualifiers.length > 0 && (
    <ul class="dp-eligibility-qualifiers" role="list">
      {qualifiers.map((q) => (
        <li>
          <span class={`dp-card-chip${q === "Invitation only" ? " is-invite" : ""}`}>{q}</span>
        </li>
      ))}
    </ul>
  )}
</div>

<style>
  .dp-eligibility {
    display: grid;
    gap: 10px;
  }
  .dp-eligibility-primary {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 12px;
    margin: 0;
    padding: 0;
    border-bottom: 1px solid var(--line-soft);
    padding-bottom: 8px;
  }
  .dp-eligibility-primary dt {
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--ink-soft);
    line-height: 1.2;
  }
  .dp-eligibility-primary dd {
    margin: 0;
    font-family: "Fraunces", serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.2px;
  }
  .dp-eligibility-primary dd.is-unverified {
    color: var(--muted);
    font-style: italic;
  }
  .dp-eligibility-primary .per {
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: var(--ink-soft);
    margin-left: 2px;
  }
  .dp-eligibility-qualifiers {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .dp-eligibility-qualifiers > li {
    display: inline-flex;
  }
  /* Phase 2a.0: navy-styled chip for invitation-only cards. Sits inside
     the same .dp-card-chip pattern; the modifier inverts so the chip
     reads as a stronger constraint than the soft qualifier chips
     beside it. */
  .dp-eligibility-qualifiers .dp-card-chip.is-invite {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }
</style>
