---
// WelcomeBonusCallout — navy-rule callout for a card's welcome offer.
// Used on hubs, finder, compare, and individual card pages.
//
// Per Stage 5.5 UX review (2026-05-20), gold is sunsetted per the
// Quiet Ledger amendment and the 2026-05-09 Charter amendment ratifying
// navy as the only primary accent. The welcome bonus is still the
// headline trust signal — rendered as navy-rule on paper, with the
// body promoted to Fraunces display type. Mirrors the .dp-take editorial-
// verdict idiom so the welcome offer reads as the publication's
// headline figure rather than a promotional callout.
//
// Reads structured welcomeBonus where available so the spend-threshold
// line is precise. Falls back to the editor's display string for
// legacy free-text entries.

import type { CardData } from "~/lib/cardsData";
import {
  isStructuredWelcomeBonus,
  isBifurcatedWelcomeBonus,
  getCardData,
  welcomeBonusDisplay as toDisplay,
} from "~/lib/cardsData";

interface Props {
  /** Phase 2a.2: when set, the component resolves welcomeBonus from
   * `getCardData(card)`. Keeps the MDX call site at one line. */
  card?: string;
  welcomeBonus?: NonNullable<CardData["welcomeBonus"]>;
  welcomeBonusDisplay?: string;
}

const {
  card,
  welcomeBonus: welcomeBonusProp,
  welcomeBonusDisplay: displayProp,
} = Astro.props;

const resolved = card ? getCardData(card) : undefined;
if (card && !resolved) {
  throw new Error(`WelcomeBonusCallout: unknown card slug "${card}"`);
}

const welcomeBonus = (resolved?.welcomeBonus ?? welcomeBonusProp) as
  | NonNullable<CardData["welcomeBonus"]>
  | undefined;
if (!welcomeBonus) {
  throw new Error(
    "WelcomeBonusCallout: requires `card` or inline `welcomeBonus` prop, and the resolved card must carry a welcomeBonus",
  );
}
const welcomeBonusDisplay = displayProp ?? toDisplay(welcomeBonus);

const aedFormatter = new Intl.NumberFormat("en-AE", {
  style: "currency",
  currency: "AED",
  maximumFractionDigits: 0,
});

// Pull the structured branch we want to render the threshold line from.
// For bifurcated bonuses, prefer the with-salary-transfer branch (the
// editorial default; the salary-transfer-required filter on the finder
// is the path that selects bifurcated cards).
let structured: import("~/lib/cardsData").StructuredWelcomeBonus | null = null;
if (isStructuredWelcomeBonus(welcomeBonus)) {
  structured = welcomeBonus;
} else if (isBifurcatedWelcomeBonus(welcomeBonus)) {
  structured =
    welcomeBonus.with_salary_transfer ??
    welcomeBonus.without_salary_transfer ??
    null;
}

// Phase 2a.0 (2026-05-20): prefer the structured `headline` (≤90 chars,
// editor-written one-liner) over the verbose derived display string
// from notes. Falls through to the existing display pipeline when
// `headline` is absent (cards that don't yet carry one).
const bodyText =
  structured && structured.headline
    ? structured.headline
    : welcomeBonusDisplay;

const thresholdLine =
  structured && structured.spend_threshold_aed
    ? structured.qualify_window_days
      ? `on ${aedFormatter.format(structured.spend_threshold_aed)} cumulative spend within ${structured.qualify_window_days} days`
      : `on ${aedFormatter.format(structured.spend_threshold_aed)} cumulative spend`
    : null;
---

<aside class="dp-welcome-callout" aria-label="Welcome offer">
  <div class="eyebrow">Welcome offer</div>
  <div class={`body${structured && structured.headline ? " is-headline" : ""}`}>{bodyText}</div>
  {thresholdLine && <div class="threshold">{thresholdLine}</div>}
</aside>

<style>
  .dp-welcome-callout {
    background: var(--paper);
    border: 1px solid var(--line);
    border-left: 3px solid var(--green);
    border-radius: 0 4px 4px 0;
    padding: 14px 18px;
    display: grid;
    gap: 6px;
  }
  .dp-welcome-callout .eyebrow {
    font-family: "DM Sans", system-ui, sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--ink);
    line-height: 1.2;
  }
  .dp-welcome-callout .body {
    font-family: "Fraunces", serif;
    font-weight: 500;
    font-size: 18px;
    letter-spacing: -0.2px;
    color: var(--ink);
    line-height: 1.35;
    text-wrap: balance;
  }
  /* Phase 2a.0: when a structured `headline` is present we render the
     editor's one-liner (≤90 chars) in Fraunces 18px italic, balanced
     to 52ch. The italic + cap distinguishes the headline pipeline from
     the legacy derived-display fallback. */
  .dp-welcome-callout .body.is-headline {
    font-style: italic;
    max-width: 52ch;
  }
  .dp-welcome-callout .threshold {
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 12px;
    color: var(--ink-soft);
    line-height: 1.4;
  }
</style>
