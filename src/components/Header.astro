---
const links = [
  { href: "/banks", label: "Banks" },
  { href: "/cards", label: "Cards" },
  { href: "/programs", label: "Programs" },
  { href: "/guides", label: "Guides" },
  { href: "/deals", label: "Deals" },
];
---

<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex w-full max-w-5xl items-center justify-between px-4 py-4">
    <a href="/" class="text-lg font-semibold text-slate-900 no-underline">
      dubaipoints<span class="text-brand-500">.ae</span>
    </a>
    <nav class="flex items-center gap-6 text-sm text-slate-700">
      {links.map((l) => <a href={l.href} class="hover:text-brand-600">{l.label}</a>)}
    </nav>
  </div>
</header>
