---
// Header — Claude Design (handoff bundle, polished pass).
// Idiom from dubaipoints/project/Homepage.html (desktop chrome) +
// dubaipoints/project/templates/menus.jsx (mobile full-screen overlay).
//
// Layout
// ──────
// Desktop ≥1024px : 56-72px row (wordmark · nav · actions) + 28px
//                   tracker strip with rotating headline ticker.
// Tablet  ≥768px  : same but tighter.
// Mobile  <768px  : 56px row (hamburger · wordmark · search) + tracker
//                   strip; hamburger opens a full-screen overlay menu
//                   with expandable sections (Cards / Points + Miles /
//                   Travel) plus tools + publication blocks.
//
// No JS — all toggles use the hidden-checkbox + <label> pattern.
// Honours prefers-reduced-motion (ticker freezes on first item).

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

// Desktop primary nav — wireframe chrome.jsx Header order.
const navLinks = [
  { href: "/cards/",    label: "Cards"    },
  { href: "/banks/",    label: "Banks"    },
  { href: "/airlines/", label: "Airlines" },
  { href: "/guides/",   label: "Guides"   },
  { href: "/deals/",    label: "Deals"    },
  { href: "/news/",     label: "News"     },
];

// Mobile menu — flat top-level rows (mirror wireframe MobileMenu).
const mobileTop = [
  { href: "/newsletter/", label: "Subscribe", subscribe: true },
  { href: "/news/",       label: "Latest" },
  { href: "/banks/",      label: "Banks" },
  { href: "/deals/",      label: "Deals" },
  { href: "/guides/",     label: "Guides" },
  { href: "/news/",       label: "News" },
];

// Expandable section payload — links map to closest existing route;
// "coming soon" routes from the wireframe ship under the same chrome
// once Phase 4–9 builds them.
type SubRow = { label: string; href: string; sub?: string };
type Group = { title: string; rows: SubRow[] };

const cardsPanel: Group[] = [
  { title: "By card type", rows: [
    { label: "Best overall UAE cards", href: "/cards/", sub: "Editor's pick" },
    { label: "Best travel cards",       href: "/cards/miles/", sub: "Miles & lounge access" },
    { label: "Best cashback cards",     href: "/cards/cashback/", sub: "Capped & uncapped" },
    { label: "Best Islamic (Sharia) cards", href: "/cards/islamic/" },
    { label: "Best entry-level cards",  href: "/cards/", sub: "Min salary AED 8k+" },
    { label: "Best premium cards",      href: "/cards/", sub: "Min salary AED 30k+" },
    { label: "All cards",               href: "/cards/" },
  ]},
  { title: "By bank issuer", rows: [
    { label: "FAB cards",         href: "/banks/fab/" },
    { label: "Emirates NBD cards",href: "/banks/enbd/" },
    { label: "Mashreq cards",     href: "/banks/mashreq/" },
    { label: "ADCB cards",        href: "/banks/adcb/" },
    { label: "HSBC cards",        href: "/banks/hsbc/" },
    { label: "DIB cards",         href: "/banks/dib/", sub: "Islamic" },
    { label: "ADIB cards",        href: "/banks/adib/", sub: "Islamic" },
    { label: "All issuers",       href: "/banks/" },
  ]},
  { title: "Co-branded cards", rows: [
    { label: "Emirates Skywards cards", href: "/airlines/skywards/" },
    { label: "Etihad Guest cards",       href: "/airlines/etihad-guest/" },
    { label: "flydubai OPEN cards",      href: "/airlines/flydubai-open/" },
    { label: "Marriott Bonvoy cards",    href: "/cards/" },
    { label: "All co-branded cards",     href: "/cards/" },
  ]},
  { title: "Learn about UAE cards", rows: [
    { label: "Beginner's guide",          href: "/guides/" },
    { label: "AECB credit score",         href: "/guides/" },
    { label: "Salary transfer explained", href: "/salary-transfer/" },
    { label: "Card reviews methodology",  href: "/editorial-policy/" },
  ]},
];

const pointsPanel: Group[] = [
  { title: "UAE bank programmes", rows: [
    { label: "ENBD Rewards",        href: "/banks/enbd/" },
    { label: "FAB Rewards",         href: "/banks/fab/" },
    { label: "Mashreq Salaam",      href: "/banks/mashreq/" },
    { label: "ADCB TouchPoints",    href: "/banks/adcb/" },
    { label: "All bank programmes", href: "/banks/" },
  ]},
  { title: "Airline programmes", rows: [
    { label: "Emirates Skywards",     href: "/airlines/skywards/", sub: "3.5 fils · DP value" },
    { label: "Etihad Guest",           href: "/airlines/etihad-guest/", sub: "2.8 fils · DP value" },
    { label: "Qatar Avios",            href: "/airlines/", sub: "3.0 fils · DP value" },
    { label: "flydubai OPEN",          href: "/airlines/flydubai-open/", sub: "2.0 fils · DP value" },
    { label: "Air Arabia Airewards",   href: "/airlines/", sub: "1.7 fils · DP value" },
    { label: "All airline programmes", href: "/airlines/" },
  ]},
  { title: "Hotel programmes", rows: [
    { label: "Marriott Bonvoy",      href: "/airlines/" },
    { label: "Hilton Honors",        href: "/airlines/" },
    { label: "World of Hyatt",       href: "/airlines/" },
    { label: "IHG One Rewards",      href: "/airlines/" },
    { label: "All hotel programmes", href: "/airlines/" },
  ]},
  { title: "Learn", rows: [
    { label: "Beginner's guide to UAE points", href: "/guides/" },
    { label: "DP valuations methodology",       href: "/valuations/" },
    { label: "Award vs cash calculator",        href: "/salary-transfer/calculator/" },
    { label: "Transfer-partner cheatsheet",     href: "/guides/" },
  ]},
];

const travelPanel: Group[] = [
  { title: "Airlines", rows: [
    { label: "Airline news",     href: "/news/" },
    { label: "Airline reviews",  href: "/airlines/" },
    { label: "Airline deals",    href: "/deals/", sub: "From DXB / AUH / SHJ" },
    { label: "All airline stories", href: "/airlines/" },
  ]},
  { title: "Hotels", rows: [
    { label: "Hotel news",       href: "/news/" },
    { label: "Hotel reviews",    href: "/airlines/" },
    { label: "UAE staycations",  href: "/deals/" },
    { label: "All hotel stories", href: "/airlines/" },
  ]},
  { title: "Routes & destinations", rows: [
    { label: "From Dubai",       href: "/airlines/" },
    { label: "From Abu Dhabi",   href: "/airlines/" },
    { label: "GCC weekend",      href: "/deals/" },
    { label: "Long-haul awards", href: "/airlines/" },
  ]},
];

const toolRows: SubRow[] = [
  { label: "Salary-transfer tracker", href: "/salary-transfer/", sub: "Refreshed daily" },
  { label: "Points & miles valuations", href: "/valuations/", sub: "DP value" },
  { label: "Card compare", href: "/cards/compare/", sub: "Side-by-side specs" },
  { label: "Award vs cash calculator", href: "/salary-transfer/calculator/" },
];

const publicationRows: SubRow[] = [
  { label: "About DubaiPoints",    href: "/about/" },
  { label: "Editorial policy",     href: "/editorial-policy/" },
  { label: "How we make money",    href: "/how-we-make-money/" },
  { label: "Corrections",          href: "/editorial-policy/" },
  { label: "Submit a tip",         href: "mailto:info@dubaipoints.ae", sub: "info@dubaipoints.ae" },
];

// Tracker headline rotation — same items as the homepage masthead.
const trackerItems = [
  "FAB raised tier-2 to AED 1,200 · 2 days ago",
  "ENBD added 25k tier · 5 days ago",
  "14 banks tracked · refreshed daily",
];
---

<!-- Hidden checkbox controls drawer state (no JS) -->
<input type="checkbox" id="dp-nav-toggle" class="dp-nav-toggle" aria-hidden="true" />

<div class="dp-header" data-pagefind-ignore>

  <!-- ── Top row: hamburger / wordmark / actions ──────────────────── -->
  <div class="dp-header-inner">

    <!-- Hamburger (mobile only) -->
    <label for="dp-nav-toggle" class="dp-icon-btn dp-mobile-only" role="button"
           tabindex="0" aria-label="Open menu" aria-controls="dp-nav-overlay">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </label>

    <!-- Wordmark -->
    <a href="/" class="dp-wordmark" aria-label="DubaiPoints home">
      DubaiPoints<span class="dot">.</span>
    </a>

    <!-- Desktop nav -->
    <nav class="dp-header-nav" aria-label="Primary">
      {navLinks.map((l) => (
        <a href={l.href} class={isActive(l.href) ? "is-active" : ""}>{l.label}</a>
      ))}
    </nav>

    <!-- Desktop actions -->
    <div class="dp-header-actions">
      <a href="/search/" class="dp-icon-btn" aria-label="Search">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <line x1="16.5" y1="16.5" x2="21" y2="21" />
        </svg>
      </a>
      <a href="/newsletter/" class="dp-header-subscribe">Subscribe</a>
    </div>

    <!-- Mobile-only search button -->
    <a href="/search/" class="dp-icon-btn dp-mobile-only" aria-label="Search">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <line x1="16.5" y1="16.5" x2="21" y2="21" />
      </svg>
    </a>
  </div>

  <!-- ── Tracker strip ────────────────────────────────────────────── -->
  <div class="dp-tracker-strip">
    <div class="dp-tracker-strip-inner">
      <a href="/salary-transfer/" class="dp-tracker-live">
        Live · Salary-transfer tracker
      </a>
      <span class="dp-tracker-meta" aria-live="polite">
        <span class="dp-tracker-ticker">
          {trackerItems.map((t) => (<span class="dp-tracker-item">{t}</span>))}
        </span>
      </span>
    </div>
  </div>
</div>

<!-- ── Mobile full-screen overlay ──────────────────────────────────── -->
<label for="dp-nav-toggle" class="dp-nav-backdrop" aria-hidden="true"></label>

<aside id="dp-nav-overlay" class="dp-nav-overlay" aria-label="Site navigation">
  <div class="dp-nav-overlay-head">
    <label for="dp-nav-toggle" class="dp-icon-btn" role="button" tabindex="0" aria-label="Close menu">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </label>
    <a href="/" class="dp-wordmark">DubaiPoints<span class="dot">.</span></a>
    <a href="/search/" class="dp-icon-btn" aria-label="Search">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <line x1="16.5" y1="16.5" x2="21" y2="21" />
      </svg>
    </a>
  </div>

  <a href="/salary-transfer/" class="dp-nav-live-strip">
    <span class="dp-nav-live-strip-dot" aria-hidden="true"></span>
    Salary-transfer tracker · live
    <span class="dp-nav-live-strip-count">14 banks ›</span>
  </a>

  <nav class="dp-nav-overlay-body">

    <!-- Top-level rows -->
    {mobileTop.slice(0, 2).map((m) => (
      <a class={`dp-nav-row${m.subscribe ? " is-subscribe" : ""}`} href={m.href}>
        <span>{m.label}</span>
      </a>
    ))}

    <!-- Cards (expandable) -->
    <input type="checkbox" id="dp-nav-cards" class="dp-nav-expand" aria-hidden="true" />
    <label for="dp-nav-cards" class="dp-nav-row dp-nav-expand-label">
      <span>Cards</span>
      <span class="dp-nav-expand-arrow" aria-hidden="true">▾</span>
    </label>
    <div class="dp-nav-panel">
      {cardsPanel.map((g) => (
        <div class="dp-nav-grp">
          <div class="dp-nav-grp-t">{g.title}</div>
          {g.rows.map((r) => (
            <a class="dp-nav-sub" href={r.href}>
              <span class="lbl">{r.label}</span>
              {r.sub && <span class="sub">{r.sub}</span>}
            </a>
          ))}
        </div>
      ))}
    </div>

    <!-- Banks (top row only — section index lives at /banks/) -->
    <a class="dp-nav-row" href="/banks/"><span>Banks</span></a>

    <!-- Points + Miles (expandable) -->
    <input type="checkbox" id="dp-nav-points" class="dp-nav-expand" aria-hidden="true" />
    <label for="dp-nav-points" class="dp-nav-row dp-nav-expand-label">
      <span>Points + Miles</span>
      <span class="dp-nav-expand-arrow" aria-hidden="true">▾</span>
    </label>
    <div class="dp-nav-panel">
      {pointsPanel.map((g) => (
        <div class="dp-nav-grp">
          <div class="dp-nav-grp-t">{g.title}</div>
          {g.rows.map((r) => (
            <a class="dp-nav-sub" href={r.href}>
              <span class="lbl">{r.label}</span>
              {r.sub && <span class="sub">{r.sub}</span>}
            </a>
          ))}
        </div>
      ))}
    </div>

    <!-- Travel (expandable) -->
    <input type="checkbox" id="dp-nav-travel" class="dp-nav-expand" aria-hidden="true" />
    <label for="dp-nav-travel" class="dp-nav-row dp-nav-expand-label">
      <span>Travel</span>
      <span class="dp-nav-expand-arrow" aria-hidden="true">▾</span>
    </label>
    <div class="dp-nav-panel">
      {travelPanel.map((g) => (
        <div class="dp-nav-grp">
          <div class="dp-nav-grp-t">{g.title}</div>
          {g.rows.map((r) => (
            <a class="dp-nav-sub" href={r.href}>
              <span class="lbl">{r.label}</span>
              {r.sub && <span class="sub">{r.sub}</span>}
            </a>
          ))}
        </div>
      ))}
    </div>

    <!-- Remaining flat rows -->
    {mobileTop.slice(3).map((m) => (
      <a class="dp-nav-row" href={m.href}>
        <span>{m.label}</span>
      </a>
    ))}

    <!-- Tools block -->
    <div class="dp-nav-tools-block">
      <div class="dp-nav-grp-t">Tools</div>
      {toolRows.map((r) => (
        <a class="dp-nav-sub" href={r.href}>
          <span class="lbl">{r.label}</span>
          {r.sub && <span class="sub">{r.sub}</span>}
        </a>
      ))}
    </div>

    <!-- Publication block -->
    <div class="dp-nav-pub-block">
      <div class="dp-nav-grp-t is-muted">Publication</div>
      {publicationRows.map((r) => (
        <a class="dp-nav-sub" href={r.href}>
          <span class="lbl">{r.label}</span>
          {r.sub && <span class="sub">{r.sub}</span>}
        </a>
      ))}
    </div>

    <div class="dp-nav-foot">
      <span>EN · العربية</span>
      <span>© {new Date().getFullYear()} DubaiPoints</span>
    </div>
  </nav>
</aside>

<style>
/* ════════════════════════════════════════════════════════════════════════
   HEADER · Claude Design polished pass — sticky chrome + tracker strip
   ════════════════════════════════════════════════════════════════════════ */

/* Hidden state inputs (drawer + per-section expand) */
.dp-nav-toggle { position: absolute; opacity: 0; pointer-events: none; }
.dp-nav-expand { position: absolute; opacity: 0; pointer-events: none; }
.dp-nav-toggle:focus-visible ~ .dp-header .dp-icon-btn[aria-controls] {
  outline: 2px solid var(--green); outline-offset: 2px;
}

.dp-header {
  position: sticky; top: 0; z-index: 50;
  background: var(--paper);
  border-bottom: 1px solid var(--line);
}
.dp-header-inner {
  display: grid;
  grid-template-columns: 44px 1fr 44px;
  align-items: center;
  height: 56px;
  padding-inline: 8px;
}
.dp-icon-btn {
  width: 44px; height: 44px;
  display: inline-flex; align-items: center; justify-content: center;
  cursor: pointer;
  background: transparent; border: 0;
  color: var(--ink);
  border-radius: 6px;
  transition: background 0.15s ease;
  text-decoration: none;
}
.dp-icon-btn:hover { background: var(--cool, #f4f5f7); }

.dp-wordmark {
  font-family: 'DM Sans', system-ui, sans-serif;
  font-weight: 800;
  font-size: 20px;
  letter-spacing: -0.6px;
  color: var(--ink);
  text-align: center;
  text-decoration: none;
}
.dp-wordmark .dot { color: var(--green); }

/* Desktop-only blocks hidden by default; revealed at ≥768px below. */
.dp-header-nav,
.dp-header-actions { display: none; }

/* Tracker strip (always visible) */
.dp-tracker-strip {
  border-top: 1px solid var(--line-soft);
  background: var(--paper);
}
.dp-tracker-strip-inner {
  max-width: 1180px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 32px;
  padding-inline: 16px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2.5px;
  text-transform: uppercase;
}
.dp-tracker-live {
  color: var(--green);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  text-decoration: none;
}
.dp-tracker-live::before {
  content: ""; width: 6px; height: 6px; border-radius: 50%;
  background: var(--green);
  animation: dp-pulse 2.4s ease-in-out infinite;
}
@keyframes dp-pulse { 0%,100%{opacity:1} 50%{opacity:0.35} }

.dp-tracker-meta {
  color: var(--muted);
  letter-spacing: 1.5px;
  font-weight: 500;
  text-transform: none;
  flex: 1;
  min-width: 0;
  margin-left: 16px;
  text-align: right;
  overflow: hidden;
}
.dp-tracker-ticker {
  position: relative;
  display: inline-block;
  height: 14px;
  width: 100%;
  max-width: 38ch;
}
.dp-tracker-item {
  position: absolute;
  inset: 0;
  white-space: nowrap;
  text-align: right;
  opacity: 0;
  animation: dp-tracker-rotate 12s linear infinite;
}
.dp-tracker-item:nth-child(1) { animation-delay: 0s; }
.dp-tracker-item:nth-child(2) { animation-delay: 4s; }
.dp-tracker-item:nth-child(3) { animation-delay: 8s; }
@keyframes dp-tracker-rotate {
  0%, 2%   { opacity: 0; transform: translateY(6px); }
  6%, 30%  { opacity: 1; transform: translateY(0); }
  33%, 100% { opacity: 0; transform: translateY(-6px); }
}
@media (prefers-reduced-motion: reduce) {
  .dp-tracker-item { animation: none; }
  .dp-tracker-item:nth-child(1) { opacity: 1; }
  .dp-tracker-item:not(:nth-child(1)) { display: none; }
  .dp-tracker-live::before { animation: none; }
}

/* Hide truncation on very narrow viewports */
@media (max-width: 480px) {
  .dp-tracker-meta { display: none; }
}

/* ─── DESKTOP ≥768px ─────────────────────────────────────────────── */
@media (min-width: 768px) {
  .dp-header-inner {
    grid-template-columns: auto 1fr auto;
    height: 72px;
    gap: 24px;
    padding-inline: 24px;
    max-width: 1180px;
    margin: 0 auto;
  }
  .dp-mobile-only { display: none; }
  .dp-wordmark { text-align: left; font-size: 22px; }
  .dp-header-nav {
    display: flex;
    gap: 28px;
    justify-self: center;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }
  .dp-header-nav a {
    color: var(--ink);
    padding: 6px 0;
    text-decoration: none;
    transition: color 0.15s ease;
    border-bottom: 2px solid transparent;
  }
  .dp-header-nav a:hover { color: var(--green); }
  .dp-header-nav a.is-active {
    color: var(--green);
    border-bottom-color: var(--green);
  }
  .dp-header-actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .dp-header-subscribe {
    display: inline-flex;
    align-items: center;
    height: 36px;
    padding: 0 16px;
    margin-left: 4px;
    background: var(--ink);
    color: #fff;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .dp-header-subscribe:hover { background: var(--green); }
  .dp-tracker-strip-inner { padding-inline: 24px; }
}

@media (min-width: 1024px) {
  .dp-header-inner {
    height: 80px;
    padding-inline: 32px;
  }
  .dp-wordmark { font-size: 24px; }
  .dp-header-nav { gap: 32px; font-size: 14px; }
  .dp-tracker-strip-inner { padding-inline: 32px; }
}

/* ════════════════════════════════════════════════════════════════════════
   MOBILE OVERLAY · full-screen menu (Claude Design wireframe MobileMenu)
   ════════════════════════════════════════════════════════════════════════ */

.dp-nav-backdrop {
  position: fixed; inset: 0;
  background: rgba(13, 17, 25, 0.55);
  opacity: 0; pointer-events: none;
  transition: opacity 0.18s ease;
  z-index: 200;
  display: none;
}
.dp-nav-overlay {
  position: fixed; inset: 0;
  background: var(--paper);
  z-index: 201;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  transform: translateX(-100%);
  transition: transform 0.22s cubic-bezier(.2,.7,.3,1);
  display: flex;
  flex-direction: column;
}

/* Toggle states */
.dp-nav-toggle:checked ~ .dp-nav-backdrop { opacity: 1; pointer-events: auto; display: block; }
.dp-nav-toggle:checked ~ .dp-nav-overlay  { transform: translateX(0); }

/* Lock body scroll when overlay open */
:global(html:has(.dp-nav-toggle:checked)) { overflow: hidden; }
:global(body:has(.dp-nav-toggle:checked)) { overflow: hidden; }

@media (min-width: 1024px) {
  .dp-nav-overlay { display: none; }
}

.dp-nav-overlay-head {
  display: grid;
  grid-template-columns: 44px 1fr 44px;
  align-items: center;
  height: 64px;
  padding-inline: 8px;
  border-bottom: 1px solid var(--line);
  background: var(--paper);
  position: sticky; top: 0; z-index: 1;
}
.dp-nav-overlay-head .dp-wordmark { font-size: 22px; }

.dp-nav-live-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--navy);
  color: #fff;
  padding: 12px 20px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
