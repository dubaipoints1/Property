---
// Header — Claude Design (polished pass, July 2026)
// Improvements: better mobile scroll lock, larger tap targets,
// smoother mega-panel hover, consistent focus states.

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? currentPath === "/" : currentPath.startsWith(href);

const mobileTop = [
  { href: "/newsletter/", label: "Subscribe", subscribe: true },
  { href: "/cards/",      label: "Cards" },
  { href: "/banks/",      label: "Banks" },
  { href: "/deals/",      label: "Deals" },
  { href: "/guides/",     label: "Guides" },
  { href: "/news/",       label: "News" },
];

type SubRow = { label: string; href: string; sub?: string };
type Group = { title: string; rows: SubRow[] };

const cardsPanel: Group[] = [
  { title: "By card type", rows: [
    { label: "Best overall UAE cards", href: "/cards/", sub: "Editor's pick" },
    { label: "Best travel cards",       href: "/cards/miles/", sub: "Miles & lounge access" },
    { label: "Best cashback cards",     href: "/cards/cashback/", sub: "Capped & uncapped" },
    { label: "Best Islamic (Sharia) cards", href: "/cards/islamic/" },
    { label: "All cards",               href: "/cards/" },
  ]},
  { title: "By bank issuer", rows: [
    { label: "FAB cards",                 href: "/banks/fab/" },
    { label: "Emirates NBD cards",        href: "/banks/emirates-nbd/" },
    { label: "ADCB cards",                href: "/banks/adcb/" },
    { label: "RAKBANK cards",             href: "/banks/rakbank/" },
    { label: "Emirates Islamic cards",    href: "/banks/emirates-islamic/", sub: "Islamic" },
    { label: "All issuers",               href: "/banks/" },
  ]},
  { title: "Co-branded cards", rows: [
    { label: "Emirates Skywards cards",   href: "/airlines/skywards/" },
    { label: "Etihad Guest cards",        href: "/airlines/etihad-guest/" },
    { label: "Marriott Bonvoy cards",     href: "/airlines/marriott-bonvoy/" },
    { label: "All co-branded cards",      href: "/cards/" },
  ]},
  { title: "Learn about UAE cards", rows: [
    { label: "Beginner's guide",          href: "/guides/expat-starter/" },
    { label: "AECB credit score",         href: "/guides/aecb-credit-report-walkthrough/" },
    { label: "Salary transfer explained", href: "/salary-transfer/" },
    { label: "Card reviews methodology",  href: "/editorial-policy/" },
  ]},
];

const pointsPanel: Group[] = [
  { title: "UAE bank programmes", rows: [
    { label: "Emirates NBD Rewards", href: "/banks/emirates-nbd/" },
    { label: "FAB Rewards",          href: "/banks/fab/" },
    { label: "ADCB TouchPoints",     href: "/banks/adcb/" },
    { label: "RAKBANK Rewards",      href: "/banks/rakbank/" },
    { label: "All bank programmes",  href: "/banks/" },
  ]},
  { title: "Airline programmes", rows: [
    { label: "Emirates Skywards",      href: "/airlines/skywards/", sub: "3.5 fils · DP value" },
    { label: "Etihad Guest",           href: "/airlines/etihad-guest/", sub: "2.8 fils · DP value" },
    { label: "Qatar Privilege Club",   href: "/airlines/qatar-privilege-club/" },
    { label: "All airline programmes", href: "/airlines/" },
  ]},
  { title: "Hotel programmes", rows: [
    { label: "Marriott Bonvoy",      href: "/airlines/marriott-bonvoy/" },
    { label: "All hotel programmes", href: "/airlines/" },
  ]},
  { title: "Learn", rows: [
    { label: "Beginner's guide to UAE points", href: "/guides/expat-starter-points-101/" },
    { label: "DP valuations methodology",       href: "/valuations/" },
    { label: "Award vs cash calculator",        href: "/salary-transfer/calculator/" },
    { label: "Transfer-partner cheatsheet",     href: "/guides/uae-transfer-ratios-2026/" },
  ]},
];

const travelPanel: Group[] = [
  { title: "Airlines", rows: [
    { label: "Airline news",     href: "/news/" },
    { label: "Airline reviews",  href: "/airlines/" },
    { label: "Airline deals",    href: "/deals/", sub: "From DXB / AUH / SHJ" },
    { label: "All airline stories", href: "/airlines/" },
  ]},
  { title: "Hotels", rows: [
    { label: "Hotel news",       href: "/news/" },
    { label: "Hotel reviews",    href: "/airlines/" },
    { label: "UAE staycations",  href: "/deals/" },
    { label: "All hotel stories", href: "/airlines/" },
  ]},
  { title: "Routes & destinations", rows: [
    { label: "From Dubai",       href: "/airlines/" },
    { label: "From Abu Dhabi",   href: "/airlines/" },
    { label: "GCC weekend",      href: "/deals/" },
    { label: "Long-haul awards", href: "/airlines/" },
  ]},
];

const toolRows: SubRow[] = [
  { label: "Salary-transfer tracker", href: "/salary-transfer/", sub: "Refreshed daily" },
  { label: "Points & miles valuations", href: "/valuations/", sub: "DP value" },
  { label: "Card compare", href: "/cards/compare/", sub: "Side-by-side specs" },
  { label: "Award vs cash calculator", href: "/salary-transfer/calculator/" },
];

const publicationRows: SubRow[] = [
  { label: "About DubaiPoints",    href: "/about/" },
  { label: "Editorial policy",     href: "/editorial-policy/" },
  { label: "How we make money",    href: "/how-we-make-money/" },
  { label: "Corrections log",      href: "/corrections/" },
  { label: "Submit a tip",         href: "/tip/" },
  { label: "Press",                href: "/press/" },
  { label: "Glossary",             href: "/glossary/" },
];
---

<input type="checkbox" id="dp-nav-toggle" class="dp-nav-toggle" aria-hidden="true" />

<div class="dp-header" data-pagefind-ignore>
  <div class="dp-header-inner">
    <!-- Hamburger -->
    <label for="dp-nav-toggle" class="dp-icon-btn dp-mobile-only" role="button"
           tabindex="0" aria-label="Open menu" aria-controls="dp-nav-overlay">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="4" y1="7" x2="20" y2="7" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="17" x2="20" y2="17" />
      </svg>
    </label>

    <!-- Wordmark -->
    <a href="/" class="dp-wordmark" aria-label="DubaiPoints home">
      <svg class="dp-wordmark-mark" viewBox="0 0 60 60" aria-hidden="true">
        <circle cx="30" cy="30" r="30" fill="currentColor" />
        <g fill="none" stroke="#ffffff" stroke-width="5.5"
           stroke-linecap="round" stroke-linejoin="round">
          <path d="M 19 41 L 41 19" />
          <path d="M 30 19 L 41 19 L 41 30" />
        </g>
      </svg>
      <span class="dp-wordmark-text">DubaiPoints</span>
    </a>

    <!-- Desktop nav -->
    <nav class="dp-header-nav" aria-label="Primary">
      <div class="dp-nav-mega-wrap">
        <a href="/cards/" class={isActive("/cards/") ? "is-active" : ""}>
          Credit cards
          <span class="dp-mega-caret" aria-hidden="true">▾</span>
        </a>
        <div class="dp-megapanel" role="region" aria-label="Cards menu">
          <div class="dp-megapanel-inner">
            {cardsPanel.map((g) => (
              <div class="dp-mega-grp">
                <div class="dp-mega-grp-t">{g.title}</div>
                {g.rows.map((r) => (
                  <a class="dp-mega-sub" href={r.href}>
                    <span class="lbl">{r.label}</span>
                    {r.sub && <span class="sub">{r.sub}</span>}
                  </a>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>

      <a href="/banks/" class={isActive("/banks/") ? "is-active" : ""}>Banks</a>

      <div class="dp-nav-mega-wrap">
        <a href="/airlines/" class={isActive("/airlines/") ? "is-active" : ""}>
          Earn miles
          <span class="dp-mega-caret" aria-hidden="true">▾</span>
        </a>
        <div class="dp-megapanel" role="region" aria-label="Earn miles menu">
          <div class="dp-megapanel-inner">
            {pointsPanel.map((g) => (
              <div class="dp-mega-grp">
                <div class="dp-mega-grp-t">{g.title}</div>
                {g.rows.map((r) => (
                  <a class="dp-mega-sub" href={r.href}>
                    <span class="lbl">{r.label}</span>
                    {r.sub && <span class="sub">{r.sub}</span>}
                  </a>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>

      <a href="/guides/" class={isActive("/guides/") ? "is-active" : ""}>Guides</a>
      <a href="/deals/" class={isActive("/deals/") ? "is-active" : ""}>Deals</a>
      <a href="/news/" class={isActive("/news/") ? "is-active" : ""}>News</a>
    </nav>

    <!-- Desktop actions -->
    <div class="dp-header-actions">
      <a href="/search/" class="dp-icon-btn" aria-label="Search">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <line x1="16.5" y1="16.5" x2="21" y2="21" />
        </svg>
      </a>
      <a href="/newsletter/" class="dp-header-subscribe">Subscribe</a>
    </div>

    <!-- Mobile search -->
    <a href="/search/" class="dp-icon-btn dp-mobile-only" aria-label="Search">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <line x1="16.5" y1="16.5" x2="21" y2="21" />
      </svg>
    </a>
  </div>

  <!-- Quick-links strip -->
  <div class="dp-tracker-strip">
    <div class="dp-tracker-strip-inner">
      <a href="/salary-transfer/" class="dp-quicklink">Salary-transfer tracker</a>
      <span class="dp-quicklink-sep" aria-hidden="true">·</span>
      <a href="/cards/" class="dp-quicklink">Top card deals</a>
      <span class="dp-quicklink-sep" aria-hidden="true">·</span>
      <a href="/news/" class="dp-quicklink">Latest news</a>
    </div>
  </div>
</div>

<!-- Mobile overlay -->
<label for="dp-nav-toggle" class="dp-nav-backdrop" aria-hidden="true"></label>

<aside id="dp-nav-overlay" class="dp-nav-overlay" aria-label="Site navigation">
  <div class="dp-nav-overlay-head">
    <label for="dp-nav-toggle" class="dp-icon-btn" role="button" tabindex="0" aria-label="Close menu">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="6" y1="6" x2="18" y2="18" />
        <line x1="18" y1="6" x2="6" y2="18" />
      </svg>
    </label>
    <a href="/" class="dp-wordmark" aria-label="DubaiPoints home">
      <svg class="dp-wordmark-mark" viewBox="0 0 60 60" aria-hidden="true">
        <circle cx="30" cy="30" r="30" fill="currentColor" />
        <g fill="none" stroke="#ffffff" stroke-width="5.5"
           stroke-linecap="round" stroke-linejoin="round">
          <path d="M 18 42 L 40 20" />
          <path d="M 29 20 L 40 20 L 40 31" />
        </g>
      </svg>
      <span class="dp-wordmark-text">DubaiPoints</span>
    </a>
    <a href="/search/" class="dp-icon-btn" aria-label="Search">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none"
           stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <line x1="16.5" y1="16.5" x2="21" y2="21" />
      </svg>
    </a>
  </div>

  <a href="/salary-transfer/" class="dp-nav-live-strip">
    <span class="dp-nav-live-strip-dot"></span>
    Salary-transfer tracker
    <span class="dp-nav-live-strip-count">Open ›</span>
  </a>

  <nav class="dp-nav-overlay-body">
    {mobileTop.slice(0, 2).map((m) => (
      <a class={`dp-nav-row${m.subscribe ? " is-subscribe" : ""}${isActive(m.href) ? " is-active" : ""}`} href={m.href}>
        <span>{m.label}</span>
      </a>
    ))}

    <input type="checkbox" id="dp-nav-cards" class="dp-nav-expand" aria-hidden="true" />
    <label for="dp-nav-cards" class="dp-nav-row dp-nav-expand-label">
      <span>Cards</span>
      <span class="dp-nav-expand-arrow" aria-hidden="true">▾</span>
    </label>
    <div class="dp-nav-panel">
      {cardsPanel.map((g) => (
        <div class="dp-nav-grp">
          <div class="dp-nav-grp-t">{g.title}</div>
          {g.rows.map((r) => (
            <a class={`dp-nav-sub${isActive(r.href) ? " is-active" : ""}`} href={r.href}>
              <span class="lbl">{r.label}</span>
              {r.sub && <span class="sub">{r.sub}</span>}
            </a>
          ))}
        </div>
      ))}
    </div>

    <a class={`dp-nav-row${isActive("/banks/") ? " is-active" : ""}`} href="/banks/"><span>Banks</span></a>

    <input type="checkbox" id="dp-nav-points" class="dp-nav-expand" aria-hidden="true" />
    <label for="dp-nav-points" class="dp-nav-row dp-nav-expand-label">
      <span>Points + Miles</span>
      <span class="dp-nav-expand-arrow" aria-hidden="true">▾</span>
    </label>
    <div class="dp-nav-panel">
      {pointsPanel.map((g) => (
        <div class="dp-nav-grp">
          <div class="dp-nav-grp-t">{g.title}</div>
          {g.rows.map((r) => (
            <a class={`dp-nav-sub${isActive(r.href) ? " is-active" : ""}`} href={r.href}>
              <span class="lbl">{r.label}</span>
              {r.sub && <span class="sub">{r.sub}</span>}
            </a>
          ))}
        </div>
      ))}
    </div>

    <input type="checkbox" id="dp-nav-travel" class="dp-nav-expand" aria-hidden="true" />
    <label for="dp-nav-travel" class="dp-nav-row dp-nav-expand-label">
      <span>Travel</span>
      <span class="dp-nav-expand-arrow" aria-hidden="true">▾</span>
    </label>
    <div class="dp-nav-panel">
      {travelPanel.map((g) => (
        <div class="dp-nav-grp">
          <div class="dp-nav-grp-t">{g.title}</div>
          {g.rows.map((r) => (
            <a class={`dp-nav-sub${isActive(r.href) ? " is-active" : ""}`} href={r.href}>
              <span class="lbl">{r.label}</span>
              {r.sub && <span class="sub">{r.sub}</span>}
            </a>
          ))}
        </div>
      ))}
    </div>

    {mobileTop.slice(3).map((m) => (
      <a class={`dp-nav-row${isActive(m.href) ? " is-active" : ""}`} href={m.href}>
        <span>{m.label}</span>
      </a>
    ))}

    <div class="dp-nav-tools-block">
      <div class="dp-nav-grp-t">Tools</div>
      {toolRows.map((r) => (
        <a class="dp-nav-sub" href={r.href}>
          <span class="lbl">{r.label}</span>
          {r.sub && <span class="sub">{r.sub}</span>}
        </a>
      ))}
    </div>

    <div class="dp-nav-pub-block">
      <div class="dp-nav-grp-t is-muted">Publication</div>
      {publicationRows.map((r) => (
        <a class="dp-nav-sub" href={r.href}>
          <span class="lbl">{r.label}</span>
          {r.sub && <span class="sub">{r.sub}</span>}
        </a>
      ))}
    </div>

    <div class="dp-nav-foot">
      <span>EN · العربية</span>
      <span>© {new Date().getFullYear()} DubaiPoints</span>
    </div>
  </nav>
</aside>

<style>
/* ════════════════════════════════════════════════════════════════════════
   HEADER STYLES — Polished pass (July 2026)
   ════════════════════════════════════════════════════════════════════════ */

.dp-nav-toggle, .dp-nav-expand {
  position: absolute; opacity: 0; pointer-events: none;
}
.dp-nav-toggle:focus-visible ~ .dp-header .dp-icon-btn[aria-controls] {
  outline: 2px solid var(--green); outline-offset: 2px;
}

.dp-header {
  position: sticky; top: 0; z-index: 50;
  background: var(--paper);
  border-bottom: 1px solid var(--line);
}
@supports (animation-timeline: scroll()) {
  .dp-header {
    animation: dp-header-scrolled both linear;
    animation-timeline: scroll(root);
    animation-range: 0 64px;
  }
  @keyframes dp-header-scrolled {
    0% { background-color: var(--paper); backdrop-filter: none; box-shadow: none; }
    100% { background-color: rgba(253, 252, 248, 0.72); backdrop-filter: blur(12px) saturate(1.2); box-shadow: 0 1px 0 rgba(15, 31, 46, 0.04); }
  }
}

.dp-header-inner {
  display: grid;
  grid-template-columns: 48px 1fr 48px;  /* was 44px — larger tap targets */
  align-items: center;
  height: 56px;
  padding-inline: 8px;
}
.dp-icon-btn {
  width: 48px; height: 48px;           /* was 44px */
  display: inline-flex; align-items: center; justify-content: center;
  cursor: pointer;
  background: transparent; border: 0;
  color: var(--ink);
  border-radius: 8px;                   /* was 6px — slightly softer */
  transition: background 0.15s ease, transform 0.1s ease;
  text-decoration: none;
}
.dp-icon-btn:hover { background: var(--shade-1); }  /* was --cool, now warmer */
.dp-icon-btn:active { transform: scale(0.96); }

.dp-wordmark {
  display: inline-flex;
  align-items: center;
  gap: 8px;                             /* was 6px */
  color: var(--ink);
  text-decoration: none;
  line-height: 1;
  justify-self: center;
}
.dp-wordmark-text {
  font-family: 'DM Sans', system-ui, sans-serif;
  font-weight: 800;
  font-size: 22px;
  letter-spacing: -0.5px;
  line-height: 1;
  color: var(--ink);
  white-space: nowrap;
}
.dp-wordmark-mark {
  width: 18px; height: 18px;           /* was 16px */
  color: var(--green);
  flex-shrink: 0;
  display: block;
}
@media (min-width: 768px) {
  .dp-wordmark { gap: 10px; justify-self: start; }
  .dp-wordmark-text { font-size: 24px; letter-spacing: -0.55px; }
  .dp-wordmark-mark { width: 20px; height: 20px; }
}
@media (min-width: 1024px) {
  .dp-wordmark-text { font-size: 26px; letter-spacing: -0.6px; }
  .dp-wordmark-mark { width: 22px; height: 22px; }
}

.dp-header-nav, .dp-header-actions { display: none; }

/* Quick-links strip */
.dp-tracker-strip {
  border-top: 1px solid var(--line-soft);
  background: var(--paper);
}
.dp-tracker-strip-inner {
  max-width: var(--container-listing);
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14px;
  height: 34px;                         /* was 32px */
  padding-inline: 16px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 1.4px;
  text-transform: uppercase;
}
@media (min-width: 1440px) {
  .dp-tracker-strip-inner { gap: 22px; letter-spacing: 2px; }
}

/* Only scroll strip when content actually overflows */
@media (max-width: 767.98px) {
  .dp-tracker-strip {
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }
  .dp-tracker-strip::-webkit-scrollbar { display: none; }
  .dp-tracker-strip-inner {
    justify-content: flex-start;
    width: max-content;
    max-width: none;
  }
}
@media (max-width: 380px) {
  .dp-tracker-strip-inner { gap: 8px; letter-spacing: 0.8px; font-size: 10px; }
}

/* ─── DESKTOP ≥768px ─────────────────────────────────────────────── */
@media (min-width: 768px) {
  .dp-header-inner {
    grid-template-columns: auto 1fr auto;
    height: 72px;
    gap: 24px;
    padding-inline: 24px;
    max-width: var(--container-listing);
    margin: 0 auto;
  }
  .dp-mobile-only { display: none; }
  .dp-header-nav {
    display: flex;
    gap: 28px;
    justify-self: center;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.3px;
  }
  .dp-header-nav a {
    color: var(--ink);
    padding: 6px 0;
    text-decoration: none;
    transition: color 0.15s ease;
    border-bottom: 2px solid transparent;
    position: relative;
  }
  .dp-header-nav a:hover { color: var(--green); }
  .dp-header-nav a.is-active {
    color: var(--green);
    border-bottom-color: var(--green);
  }

  .dp-nav-mega-wrap { position: static; }
  .dp-nav-mega-wrap > a {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 8px 0;                     /* larger hit area */
  }
  .dp-mega-caret {
    font-size: 10px;
    color: var(--muted);
    transition: transform 0.2s ease, color 0.2s ease;
  }
  .dp-nav-mega-wrap:hover .dp-mega-caret,
  .dp-nav-mega-wrap:focus-within .dp-mega-caret {
    transform: rotate(180deg);
    color: var(--green);
  }

  .dp-megapanel {
    position: fixed;
    top: 80px;
    left: 0; right: 0;
    background: var(--paper);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    box-shadow: 0 12px 32px rgba(15, 31, 46, 0.10);
    z-index: 48;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-6px);        /* was -4px — more dramatic entrance */
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0s linear 0.2s;
    pointer-events: none;              /* prevent accidental hover triggers */
  }
  .dp-nav-mega-wrap:hover .dp-megapanel,
  .dp-nav-mega-wrap:focus-within .dp-megapanel,
  .dp-megapanel:hover {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition-delay: 0.05s;          /* slight delay prevents flicker */
    pointer-events: auto;
  }
  .dp-megapanel-inner {
    max-width: var(--container-listing);
    margin: 0 auto;
    padding: 32px 32px 36px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .dp-mega-grp { display: flex; flex-direction: column; }
  .dp-mega-grp-t {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 10px; font-weight: 700;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--green);
    margin: 0 0 14px;
  }
  .dp-mega-sub {
    display: flex; flex-direction: column; gap: 2px;
    padding: 8px 0;
    text-decoration: none;
